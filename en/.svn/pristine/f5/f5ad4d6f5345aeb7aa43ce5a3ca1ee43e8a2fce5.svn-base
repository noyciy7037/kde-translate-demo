      <termEntry id='CA'>
        <descrip type='definition'>他者に対して電子証明書を発行する権限を持つ機関 (CA)</descrip>
        <langSet xml:lang='ja'>
          <ntig>
            <termGrp>
              <term>認証局</term>
            </termGrp>
          </ntig>
        </langSet>
        <langSet xml:lang='en'>
          <ntig>
            <termGrp>
              <term>certificate authority</term>
            </termGrp>
          </ntig>
        </langSet>
      </termEntry>

      <termEntry id='CRL'>
