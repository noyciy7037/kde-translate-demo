#. +> trunk5
#: ../../user_manual/endtour.rst:3
msgid "End of the Tour"
msgstr ""

#. +> trunk5
#: ../../user_manual/endtour.rst:5
msgid ""
"This concludes the tour of the KStars skymap, although we have only "
"scratched the surface of the available features. KStars includes many "
"useful :doc:`astronomy tools  <tools>`, it can directly :doc:`control your "
"telescope  <indi>`, and it offers a wide variety of :doc:`configuration and "
"customization options  <config>`. In addition, this Handbook includes "
"the :doc:`AstroInfo Project  <astroinfo>`, a series of short, interlinked "
"articles explaining some of the celestial and astrophysical concepts behind "
"KStars."
msgstr ""
