msgid "Project Cache Data"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_settings/tab_cache_data.rst:24
msgid ""
"The Cache Data tab shows the data used in the project including the timeline "
"preview, proxy clips, audio thumbnails, and video thumbnails."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_settings/tab_cache_data.rst:33
msgid "The Project Settings Cache Data dialog window"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_settings/tab_cache_data.rst:37
msgid ""
"Click on the |trash-empty| icon beside the categories to clear the cache "
"data for that category."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_settings/tab_cache_data.rst:39
msgid ""
"Click on the link below the project total cache data information to open "
"that location with the standard file manager of your OS."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_settings/tab_cache_data.rst:42
msgid ""
"This tab is only available from :menuselection:`Menu --> File --> Project "
"Settings`."
msgstr ""

#. +> trunk5
