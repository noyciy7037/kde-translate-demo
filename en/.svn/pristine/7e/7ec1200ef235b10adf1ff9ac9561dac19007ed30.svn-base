#. +> trunk6 stable6
#: contents/logout/Logout.qml:152
#, kde-format
msgid "Installing software updates and restarting in 1 second"
msgid_plural "Installing software updates and restarting in %1 seconds"
msgstr[0] "%1秒後に更新をインストールして再起動"

#. +> trunk6 stable6 stable5
#: contents/logout/Logout.qml:153
#, kde-format
msgid "Restarting in 1 second"
msgid_plural "Restarting in %1 seconds"
msgstr[0] "%1秒後に再起動"

#. +> trunk6 stable6 stable5
#: contents/logout/Logout.qml:155
#, kde-format
msgid "Logging out in 1 second"
msgid_plural "Logging out in %1 seconds"
msgstr[0] "%1秒後にログアウト"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:158
#, kde-format
msgid "Installing software updates and shutting down in 1 second"
msgid_plural "Installing software updates and shutting down in %1 seconds"
msgstr[0] "%1秒後に更新をインストールしてシャットダウン"

#. +> trunk6 stable6 stable5
#: contents/logout/Logout.qml:159
#, kde-format
msgid "Shutting down in 1 second"
msgid_plural "Shutting down in %1 seconds"
msgstr[0] "%1秒後にシャットダウン"

#. +> trunk6 stable6 stable5
#: contents/logout/Logout.qml:174
#, kde-format
msgid ""
"One other user is currently logged in. If the computer is shut down or "
"restarted, that user may lose work."
msgid_plural ""
"%1 other users are currently logged in. If the computer is shut down or "
"restarted, those users may lose work."
msgstr[0] ""
"現在、他に%1人のユーザがログインしています。コンピュータがシャットダウンもし"
"くは再起動された場合、そのユーザは作業中のデータを失う可能性があります。"

#. +> trunk6
#: contents/logout/Logout.qml:191
#, fuzzy, kde-format
#| msgid "When restarted, the computer will enter the firmware setup screen."
msgid "When restarted, the computer will enter UEFI firmware settings."
msgstr "再起動すると、コンピュータはファームウェア設定画面に入ります。"

#. +> trunk6 stable6 stable5
#: contents/logout/Logout.qml:193
#, kde-format
msgid "When restarted, the computer will enter the firmware setup screen."
msgstr "再起動すると、コンピュータはファームウェア設定画面に入ります。"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:208
#, kde-format
msgid "When restarted, the computer will enter the boot loader menu."
msgstr "再起動すると、コンピュータはブートローダメニューに入ります。"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:221
#, fuzzy, kde-format
#| msgid "When restarted, the computer will enter the boot loader menu."
msgctxt "%1 is a boot loader entry"
msgid "When restarted, the computer will switch to %1."
msgstr "再起動すると、コンピュータはブートローダメニューに入ります。"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:243
#, kde-format
msgctxt "Suspend to RAM"
msgid "Slee&p"
msgstr "スリープ(&P)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:244
#, kde-format
msgctxt "Suspend to RAM"
msgid "Slee&p Now"
msgstr "今すぐスリープ(&P)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:253
#, kde-format
msgid "&Hibernate"
msgstr "ハイバネート(&H)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:254
#, kde-format
msgid "&Hibernate Now"
msgstr "今すぐハイバネート(&H)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:265
#, kde-format
msgctxt "@action:button Keep short"
msgid "Install Updates and Restart"
msgstr "更新をインストールして再起動"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:267 contents/logout/Logout.qml:286
#, kde-format
msgid "&Restart"
msgstr "再起動(&R)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:268 contents/logout/Logout.qml:287
#, kde-format
msgid "&Restart Now"
msgstr "今すぐ再起動(&R)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:300
#, kde-format
msgctxt "@action:button Keep short"
msgid "Install Updates and Shut Down"
msgstr "更新をインストールしてシャットダウン"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:302 contents/logout/Logout.qml:321
#, kde-format
msgid "&Shut Down"
msgstr "シャットダウン(&S)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:303 contents/logout/Logout.qml:322
#, kde-format
msgid "&Shut Down Now"
msgstr "今すぐシャットダウン(&S)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:334
#, kde-format
msgid "&Log Out"
msgstr "ログアウト(&L)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:335
#, kde-format
msgid "&Log Out Now"
msgstr "今すぐログアウト(&L)"

#. +> trunk6 stable6
#: contents/logout/Logout.qml:345
#, kde-format
msgid "&Cancel"
msgstr "キャンセル(&C)"

#. +> trunk6 stable6 stable5
#: contents/splash/Splash.qml:79
#, kde-format
msgctxt ""
"This is the first text the user sees while starting in the splash screen, "
"should be translated as something short, is a form that can be seen on a "
"product. Plasma is the project name so shouldn't be translated."
msgid "Plasma made by KDE"
msgstr "Plasma made by KDE"

