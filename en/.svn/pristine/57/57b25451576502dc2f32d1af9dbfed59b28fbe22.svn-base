#. +> trunk6 stable6
#, kde-format
msgctxt "NAME OF TRANSLATORS"
msgid "Your names"
msgstr "Taiki Komoda"

#. +> trunk6 stable6
#, kde-format
msgctxt "EMAIL OF TRANSLATORS"
msgid "Your emails"
msgstr "kom@kde.gr.jp"

#. +> trunk6 stable6
#: calligraconverter.cpp:179
#, kde-format
msgid "CalligraConverter"
msgstr "CalligraConverter"

#. +> trunk6 stable6
#: calligraconverter.cpp:181
#, kde-format
msgid "Calligra Document Converter"
msgstr "Calligra 文書コンバータ"

#. +> trunk6 stable6
#: calligraconverter.cpp:183
#, fuzzy, kde-format
#| msgid "(c) 2001-2011 Calligra developers"
msgid "Copyright 2001-%1 Calligra developers"
msgstr "(c) 2001-2011 Calligra 開発チーム"

#. +> trunk6 stable6
#: calligraconverter.cpp:184
#, kde-format
msgid "David Faure"
msgstr "David Faure"

#. +> trunk6 stable6
#: calligraconverter.cpp:185
#, kde-format
msgid "Nicolas Goutte"
msgstr "Nicolas Goutte"

#. +> trunk6 stable6
#: calligraconverter.cpp:186
#, kde-format
msgid "Dan Leinir Turthra Jensen"
msgstr "Dan Leinir Turthra Jensen"

#. +> trunk6 stable6
#: calligraconverter.cpp:193
#, kde-format
msgid "Input file"
msgstr "入力ファイル"

#. +> trunk6 stable6
#: calligraconverter.cpp:194
#, kde-format
msgid "Output file"
msgstr "出力ファイル"

#. +> trunk6 stable6
#: calligraconverter.cpp:195
#, kde-format
msgid "Make a backup of the destination file"
msgstr "変換先ファイルのバックアップを作成"

#. +> trunk6 stable6
#: calligraconverter.cpp:196
#, kde-format
msgid "Batch mode: do not show dialogs"
msgstr "バッチモード: ダイアログを表示しない"

#. +> trunk6 stable6
#: calligraconverter.cpp:197
#, kde-format
msgid "Interactive mode: show dialogs (default)"
msgstr "対話型モード: ダイアログを表示 (標準)"

#. +> trunk6 stable6
#: calligraconverter.cpp:198
#, kde-format
msgid "Mimetype of the output file"
msgstr "出力ファイルの MIME タイプ"

#. +> trunk6 stable6
#: calligraconverter.cpp:202
#, kde-format
msgid "The print orientation. This could be either Portrait or Landscape."
msgstr "印刷方向です。横向きまたは縦向きから選択します。"

#. +> trunk6 stable6
#: calligraconverter.cpp:205
#, kde-format
msgid "The paper size. A4, Legal, Letter, ..."
msgstr "用紙サイズ(A4、リーガル、レターなど)です。"

#. +> trunk6 stable6
#: calligraconverter.cpp:207
#, kde-format
msgid "The size of the paper margin. By default this is 0.2."
msgstr "用紙のマージンの大きさです。デフォルトでは 0.2 です。"

#. +> trunk6 stable6
#: calligraconverter.cpp:215
#, kde-format
msgid "Two arguments required"
msgstr "二つの引数が必要です"

#. +> trunk6 stable6
#: calligraconverter.cpp:243
#, kde-format
msgid "Mimetype for input file %1 not found!"
msgstr "入力ファイル ‘%1’ の MIME タイプが見つかりません。"

#. +> trunk6 stable6
#: calligraconverter.cpp:252
#, kde-format
msgid "Mimetype not found %1"
msgstr "MIME タイプ %1 が見つかりません"

#. +> trunk6 stable6
#: calligraconverter.cpp:258
#, kde-format
msgid "Mimetype not found, try using the -mimetype option"
msgstr "MIME タイプが見つかりません、-mimetype オプションを試してください"

#. +> trunk6 stable6
#: calligraconverter.cpp:282
#, kde-format
msgid "*** The conversion failed! ***"
msgstr "*** 変換に失敗しました ***"

