#. +> trunk6 stable6
#: debuggerplugin.cpp:35 gdbconfigpage.cpp:94
#, kde-format
msgid "GDB"
msgstr "GDB"

#. i18n: ectx: property (windowTitle), widget (QDialog, DebuggerTracingDialog)
#. +> trunk6 stable6
#: debuggertracingdialog.ui:14
#, fuzzy, kde-format
#| msgid "Tracing Configuration"
msgctxt "@title:window"
msgid "Tracing Configuration"
msgstr "トレースの設定"

#. i18n: ectx: property (whatsThis), widget (QLineEdit, customFormat)
#. +> trunk6 stable6
#: debuggertracingdialog.ui:26
#, no-c-format, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<b>Custom format string</b>\n"
"<p>Specify a C-style format string that will be used when printing the "
"chosen expression. For example:\n"
"<p align=\"center\"> <tt>Tracepoint 1: g = %d</tt></p>\n"
"If custom format string is not enabled, names and values of all expressions "
"will be printed, using \"%d\" as format specifier for all expressions."
msgstr ""

#. i18n: ectx: property (text), widget (QLabel, expressionsLabel)
#. +> trunk6 stable6
#: debuggertracingdialog.ui:36
#, kde-format
msgctxt "@label"
msgid "Expressions to print:"
msgstr ""

#. i18n: ectx: property (whatsThis), widget (QCheckBox, enable)
#. +> trunk6 stable6
#: debuggertracingdialog.ui:47
#, kde-format
msgctxt "@info:whatthis"
msgid ""
"<b>Enable tracing</b>\n"
"<p>Tracing is a mechanism to automatically print values of the chosen "
"expressions and continue execution when breakpoint is hit. You can think of "
"it as printf debugging that does not require modifying the source.</p>"
msgstr ""

#. i18n: ectx: property (text), widget (QCheckBox, enable)
#. +> trunk6 stable6
#: debuggertracingdialog.ui:50
#, fuzzy, kde-format
#| msgid "Enable tracing"
msgctxt "@option:check"
msgid "Enable tracing"
msgstr "トレースを有効にする"

#. i18n: ectx: property (text), widget (QCheckBox, enableCustomFormat)
#. +> trunk6 stable6
#: debuggertracingdialog.ui:60
#, kde-format
msgctxt "@option:check"
msgid "Custom format string"
msgstr ""

