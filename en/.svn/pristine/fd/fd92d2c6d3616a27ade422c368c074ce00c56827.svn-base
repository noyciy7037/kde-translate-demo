#: gdbconfigpage.ui:190
#, fuzzy, kde-format
#| msgctxt "Shell script to be executed at run time"
#| msgid "R&un shell script:"
msgctxt "@label:chooser Shell script to be executed at run time"
msgid "R&un shell script:"
