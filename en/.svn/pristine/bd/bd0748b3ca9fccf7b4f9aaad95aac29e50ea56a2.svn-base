msgid "Not VS-NfD Compliant"
msgstr "VS-NfD 準拠ではない"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:889 src/libkleopatrarc.desktop:1027
msgctxt "Description"
msgid "Certificates that are not VS-NfD compliant (except disabled ones)"
msgstr "VS-NfD 準拠ではない証明書 (使用禁止を除く)"

