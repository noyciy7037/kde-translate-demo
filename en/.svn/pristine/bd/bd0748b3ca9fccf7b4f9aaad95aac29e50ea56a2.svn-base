msgctxt "Description"
msgid ""
"Certificates that are invalid because they have been revoked (except "
"disabled ones)"
msgstr "取り消しされたたために無効な証明書 (使用禁止のものを除く)"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:352 src/libkleopatrarc.desktop:490
msgctxt "Name"
msgid "Trusted Root Certificates"
msgstr "信頼されたルート証明書"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:385 src/libkleopatrarc.desktop:523
msgctxt "Description"
msgid "S/MIME root certificates that are trusted"
msgstr "信頼された S/MIME のルート証明書"

