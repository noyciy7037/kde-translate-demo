msgstr "使用禁止"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:1106 src/libkleopatrarc.desktop:1244
msgctxt "Description"
msgid "Certificates that are disabled"
msgstr "使用禁止とされた証明書"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:1144 src/libkleopatrarc.desktop:1282
msgctxt "Name"
msgid "My Own"
msgstr "自分自身"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:1176 src/libkleopatrarc.desktop:1314
msgctxt "Description"
msgid "My own certificates"
msgstr "自分自身の証明書"

