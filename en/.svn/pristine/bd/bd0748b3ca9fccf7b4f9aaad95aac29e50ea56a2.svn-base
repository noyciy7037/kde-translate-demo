#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:965 src/libkleopatrarc.desktop:1103
msgctxt "Description"
msgid ""
"Expired certificates (if VS-NfD compliance mode is active, except disabled "
"ones)"
msgstr "失効した証明書 (VS-NfD 準拠モードが有効の場合。使用禁止を除く)"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:1005 src/libkleopatrarc.desktop:1143
msgctxt "Name"
msgid "Not VS-NfD Compliant (Revoked)"
msgstr "VS-NfD 準拠ではない (取り消し済)"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:1040 src/libkleopatrarc.desktop:1178
msgctxt "Description"
msgid ""
"Revoked certificates (if VS-NfD compliance mode is active, except disabled "
"ones)"
msgstr "取り消しされた証明書 (VS-NfD 準拠モードが有効の場合。使用禁止を除く)"

#. +> trunk6 stable6
#: src/libkleopatrarc-win32.desktop:1076 src/libkleopatrarc.desktop:1214
msgctxt "Name"
