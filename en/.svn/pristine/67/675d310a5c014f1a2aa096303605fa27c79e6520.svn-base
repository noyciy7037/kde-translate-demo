msgid ""
msgstr ""
"Project-Id-Version: AutocorrectPlugin\n"
"Report-Msgid-Bugs-To: https://bugs.kde.org\n"
"POT-Creation-Date: 2024-11-09 11:24+0100\n"
"PO-Revision-Date: 2010-09-25 20:16-0700\n"
"Last-Translator: Fumiaki Okushi <okushi@kde.gr.jp>\n"
"Language-Team: Japanese <kde-jp@kde.org>\n"
"Language: ja\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=1; plural=0;\n"
"X-Accelerator-Marker: &\n"
"X-Text-Markup: kde4\n"

#. +> trunk6 stable6
#: Autocorrect.cpp:26
#, kde-format
msgid "Configure &Autocorrection..."
msgstr "自動修正を設定(&A)..."

#. +> trunk6 stable6
#: Autocorrect.cpp:30
#, fuzzy, kde-format
#| msgid "Autocorrection"
msgid "Enable Autocorrection"
msgstr "自動修正"

#. +> trunk6 stable6
#: AutocorrectFactory.cpp:16
#, kde-format
msgid "Autocorrect"
msgstr "自動修正"

#, kde-format
#~ msgid "Autocorrection"
#~ msgstr "自動修正"

#, kde-format
#~ msgid "Si&mple Autocorrection"
#~ msgstr "単純な自動修正(&M)"

#, kde-format
#~ msgid ""
#~ "Detect when a new sentence is started and always ensure that the first "
#~ "character is an uppercase character"
#~ msgstr ""
#~ "新しい文の始まりを検知し、最初の文字が必ず大文字になるようにします。"

#, kde-format
#~ msgid ""
#~ "Convert &first letter of a sentence automatically to uppercase\n"
#~ "(e.g. \"my house. in this town\" to \"my house. In this town\")"
#~ msgstr ""
#~ "文の最初の文字を自動的に大文字にする(&F)\n"
#~ "(例 “my house. in this town” を “my house. In this town” に)"

#, kde-format
#~ msgid ""
#~ "All words are checked for the common mistake of holding the shift key "
#~ "down a bit too long. If some words must have two uppercase characters, "
#~ "then those exceptions should be added in the 'Exceptions' tab."
#~ msgstr ""
#~ "すべての単語をチェックして、Shift キーを長く押し過ぎることで起こる間違いが"
#~ "発生していないか確認します。大文字を 2 文字含む単語があれば、例外として"
#~ "「例外」タブに追加してください。"

#, kde-format
#~ msgid ""
#~ "Convert &two uppercase characters to one uppercase and one lowercase "
#~ "character\n"
#~ " (e.g. PErfect to Perfect)"
#~ msgstr ""
#~ "大文字 2 文字を大文字 1 文字と小文字 1 文字にする(&T)\n"
#~ "(例 PErfect を Perfect に)"

#, kde-format
#~ msgid ""
#~ "Detect when a URL (Uniform Resource Locator) is typed and provide "
#~ "formatting that matches the way an Internet browser would show a URL."
#~ msgstr ""
#~ "URL (Uniform Resource Locator) の入力を検知し、インターネットブラウザが "
#~ "URL を表示する形にフォーマットします。"

#, kde-format
#~ msgid "Autoformat &URLs"
#~ msgstr "URL を自動フォーマットする(&U)"

#, kde-format
#~ msgid ""
#~ "Make sure that more than one space cannot be typed, as this is a common "
#~ "mistake which is quite hard to find in formatted text."
#~ msgstr ""
#~ "フォーマットされたテキストでは見つけにくい 2 文字以上のスペースを入力でき"
#~ "ないようにします。"

#, kde-format
#~ msgid "&Suppress double spaces"
#~ msgstr "二重スペースを抑制する(&S)"

#, kde-format
#~ msgid ""
#~ "Keep correct formatting and indenting of sentences by automatically "
#~ "removing spaces typed at the beginning and end of a paragraph."
#~ msgstr ""
#~ "段落の最初と最後に入力されたスペースを自動的に削除し、正しいフォーマットと"
#~ "字下げを保ちます。"

#, kde-format
#~ msgid "R&emove spaces at the beginning and end of paragraphs"
#~ msgstr "段落の最初と最後のスペースを削除する(&E)"

#, kde-format
#~ msgid ""
#~ "When you use _underline_ or *bold*, the text between the underscores or "
#~ "asterisks will be converted to underlined or bold text."
#~ msgstr ""
#~ "「_下線_」や「*ボールド*」とすると、アンダースコア (_) やアスタリスク (*) "
#~ "間のテキストが自動的に下線付きまたはボールドになります。"

#, kde-format
#~ msgid "Automatically do &bold and underline formatting"
#~ msgstr "自動的にボールドや下線のフォーマットを行う(&B)"

#, kde-format
#~ msgid "Most standard fraction notations will be converted when available"
#~ msgstr "利用可能であれば最も標準的な分数表記に変換します。"

#, kde-format
#~ msgid "Re&place 1/2... with ½..."
#~ msgstr "1/2... を ½... に置換する(&P)"

#, kde-format
#~ msgid ""
#~ "When typing '1)' or similar in front of a paragraph, automatically "
#~ "convert the paragraph to use that numbering style. This has the advantage "
#~ "that further paragraphs will also be numbered and the spacing is done "
#~ "correctly."
#~ msgstr ""
#~ "“1)” またはこれに類似するものを段落の最初に入力すると、段落にそのスタイル"
#~ "の番号付けが適用されます。このオプションを使うと、続く段落にも自動的に番号"
#~ "が付き、段落の間隔も正しく設定されます。"

#, kde-format
#~ msgid "Use &autonumbering for numbered paragraphs"
#~ msgstr "段落に自動的に番号を付ける(&A)"

#, kde-format
#~ msgid "Rep&lace 1st... with 1^st..."
#~ msgstr "1st... を 1^st... に置換する(&L)"

#, kde-format
#~ msgid "Capitalize name of days"
#~ msgstr "曜日名を大文字にする"

#, kde-format
#~ msgid ""
#~ "When typing '*' or '-' in front of a paragraph, automatically convert the "
#~ "paragraph to use that list-style. Using a list-style formatting means "
#~ "that a correct bullet is used to draw the list."
#~ msgstr ""
#~ "アスタリスク (*) やハイフン (-) を段落の最初に入力すると、段落にそのリスト"
#~ "スタイルが適用されます。このオプションを使うと、自動的にリストに正しいビュ"
#~ "レットが付きます。"

#, kde-format
#~ msgid "Use l&ist-formatting for bulleted paragraphs"
#~ msgstr "ビュレット付きの段落に自動的にリストフォーマットを適用する(&I)"

#, kde-format
#~ msgid "Default"
#~ msgstr "デフォルト"

#, kde-format
#~ msgid "Custom &Quotes"
#~ msgstr "カスタム引用符(&Q)"

#, kde-format
#~ msgid "Replace &double quotes with typographical quotes"
#~ msgstr "二重引用符を活版印刷の引用符に置換する(&D)"

#, kde-format
#~ msgid "Replace &single quotes with typographical quotes"
#~ msgstr "一重引用符を活版印刷の引用符に置換する(&S)"

#, kde-format
#~ msgid "Ad&vanced Autocorrection"
#~ msgstr "高度な自動修正(&V)"

#, kde-format
#~ msgid "Replacements and exceptions for language:"
#~ msgstr "置換と例外を適用する言語:"

#, kde-format
#~ msgid "All Languages"
#~ msgstr "すべての言語"

#, kde-format
#~ msgid "&Enable word replacement"
#~ msgstr "単語置換を有効にする(&E)"

#, kde-format
#~ msgid "Replace &text with format"
#~ msgstr "テキストを書式付きで置換する(&T)"

#, kde-format
#~ msgid "&Find"
#~ msgstr "検索(&F)"

#, kde-format
#~ msgid "..."
#~ msgstr "..."

#, kde-format
#~ msgid "Re&place"
#~ msgstr "置換(&P)"

#, kde-format
#~ msgid "&Add"
#~ msgstr "追加(&A)"

#, kde-format
#~ msgid "Remove"
#~ msgstr "削除"

#, kde-format
#~ msgid "C&hange Format..."
#~ msgstr "書式を変更(&H)..."

#, kde-format
#~ msgid "C&lear Format"
#~ msgstr "書式をクリア(&L)"

#, kde-format
#~ msgid "Find"
#~ msgstr "検索"

#, kde-format
#~ msgid "Replace"
#~ msgstr "置換"

#, kde-format
#~ msgid "E&xceptions"
#~ msgstr "例外(&X)"

#, kde-format
#~ msgid "Do not treat as the end of a sentence:"
#~ msgstr "文の終わりとして扱わない文字列:"

#, kde-format
#~ msgid "Autoinclude"
#~ msgstr "自動取り込み"

#, kde-format
#~ msgid "R&emove"
#~ msgstr "削除(&E)"

#, kde-format
#~ msgid "Accept two uppercase letters in:"
#~ msgstr "2 文字の大文字を誤りとしない単語:"

#, kde-format
#~ msgid "A&dd"
#~ msgstr "追加(&D)"

#, kde-format
#~ msgid "&Modify"
#~ msgstr "変更(&M)"

#, kde-format
#~ msgid "Select Character"
#~ msgstr "文字を選択"

