#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:50
#, kde-format
msgctxt "@info"
msgid ""
"If you're using this setting to work around an application that demands "
"attention too often, first look for a setting in the app to disable that "
"behavior. If you don't find one, consider reporting this as a bug to the "
"app's developer."
msgstr ""
"アプリケーションが頻繁に注意を促すためにこの設定を使用している場合は、まずそ"
"のアプリで動作を無効にできないか確認してください。もし見つからない場合、バグ"
"としてアプリの開発者に報告することをおすすめします。"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:66
#, kde-format
msgctxt "@label:listbox how to group tasks"
msgid "Group:"
msgstr "グループ化:"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:70
#, kde-format
msgctxt "@item:inlistbox how to group tasks"
msgid "Do not group"
msgstr "グループ化しない"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:71
#, kde-format
msgctxt "@item:inlistbox how to group tasks"
msgid "By program name"
msgstr "プログラム名で"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:77
#, kde-format
msgctxt "@label:listbox completes sentence like: … cycles through tasks"
msgid "Clicking grouped task:"
msgstr "グループ化されたタスクをクリックしたとき:"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:84
#, kde-format
msgctxt ""
"@item:inlistbox Completes the sentence 'Clicking grouped task cycles through "
"tasks' "
msgid "Cycles through tasks"
msgstr "タスクを循環"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:85
#, kde-format
msgctxt ""
"@item:inlistbox Completes the sentence 'Clicking grouped task shows small "
"window previews' "
msgid "Shows small window previews"
msgstr "小さなウィンドウプレビューを表示"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:86
#, kde-format
msgctxt ""
"@item:inlistbox Completes the sentence 'Clicking grouped task shows large "
"window previews' "
msgid "Shows large window previews"
msgstr "大きなウィンドウプレビューを表示"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:87
#, kde-format
msgctxt ""
"@item:inlistbox Completes the sentence 'Clicking grouped task shows textual "
"list' "
msgid "Shows textual list"
msgstr "テキストリストを表示"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:98
#, kde-format
msgctxt "@info displayed as InlineMessage"
msgid ""
"The compositor does not support displaying windows side by side, so a "
"textual list will be displayed instead."
msgstr ""
"コンポジタがウィンドウを並べる表示をサポートしていないため、代わりにテキスト"
"リストが表示されます。"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:108
#, kde-format
msgctxt "@option:check grouped task"
msgid "Combine into single button"
msgstr "1つのボタンに結合する"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:115
#, kde-format
msgctxt "@option:check grouped task"
msgid "Group only when the Task Manager is full"
msgstr "タスクマネージャがいっぱいのときのみグループ化"

#. +> trunk6 stable6
#: qml/ConfigBehavior.qml:127
#, kde-format
