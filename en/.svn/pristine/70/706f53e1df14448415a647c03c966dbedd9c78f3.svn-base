#. +> trunk6 stable6
#: deletedialog.cpp:78
#, kde-format
msgid ""
"<qt>These items will be <b>permanently deleted</b> from your hard disk.</qt>"
msgstr "<qt>これらのアイテムはハードディスクから「完全に削除」されます。</qt>"

#. +> trunk6 stable6
#: deletedialog.cpp:84
#, kde-format
msgid "<qt>These items will be moved to the Trash Bin.</qt>"
msgstr "<qt>これらのアイテムはごみ箱に移動されます。</qt>"

#. +> trunk6 stable6
#: deletedialog.cpp:96
#, fuzzy, kde-format
#| msgid "&Send to Trash"
