msgid "No, Save As <filename>%1</filename>"
msgstr "いいえ、ファイル <filename>%1</filename> として保存します"

#. +> trunk6 stable6
#: src/crypto/decryptverifyfilescontroller.cpp:644
#, kde-kuit-format
msgctxt "@action:button"
msgid "Yes, Save As <filename>%1</filename>"
msgstr "はい、ファイル <filename>%1</filename> として保存します"

#. +> trunk6 stable6
#: src/crypto/decryptverifyfilescontroller.cpp:667
#, kde-kuit-format
msgctxt "@info"
