#: src/dialogs/setinitialpindialog.ui:71
#, kde-format
msgid ""
"Step 2: Set the initial PIN for the qualified signature certificate "
"(\"SigG\"):"
msgstr "ステップ 2: 資格のある署名の証明書の初期 PIN の設定 (\"SigG\"):"

