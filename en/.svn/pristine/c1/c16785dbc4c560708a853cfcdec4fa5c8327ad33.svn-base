#. i18n: ectx: ToolBar (mainToolBar)
#. +> trunk6 stable6
#: src/kleopatra.rc:111 src/kwatchgnupg/kwatchgnupgui.rc:13
#, kde-format
msgid "Main Toolbar"
msgstr "メインツールバー"

#. +> trunk6 stable6
#: src/kleopatra_options.h:20
#, kde-format
msgctxt "@info:shell"
msgid "Use OpenPGP for the following operation"
msgstr "次の操作に OpenPGP を使う"

#. +> trunk6 stable6
#: src/kleopatra_options.h:21
#, kde-format
msgctxt "@info:shell"
msgid "Use CMS (X.509, S/MIME) for the following operation"
msgstr "次の操作に CMS (X.509, S/MIME) を使う"

#. +> trunk6 stable6
#: src/kleopatra_options.h:23
#, kde-format
msgctxt "@info:shell"
msgid "Location of the socket the ui server is listening on"
msgstr "UI サーバが待ち受けするソケットの場所"

#. +> trunk6 stable6
#: src/kleopatra_options.h:25
#, kde-format
msgctxt "@info:shell"
msgid "Run UI server only, hide main window"
msgstr "メインウィンドウを表示せずに UI サーバのみを実行"

#. +> trunk6 stable6
#: src/kleopatra_options.h:26
#, kde-format
msgctxt "@info:shell"
msgid "Import certificate file(s)"
msgstr "証明書ファイルをインポート"

#. +> trunk6 stable6
#: src/kleopatra_options.h:27
#, kde-format
msgctxt "@info:shell"
msgid "Encrypt file(s)"
msgstr "ファイルを暗号化"

#. +> trunk6 stable6
#: src/kleopatra_options.h:28
#, kde-format
msgctxt "@info:shell"
msgid "Sign file(s)"
msgstr "ファイルに署名"

#. +> trunk6 stable6
#: src/kleopatra_options.h:29
#, kde-format
msgctxt "@info:shell"
msgid "Sign and/or encrypt file(s)"
msgstr "ファイルに署名/暗号化"

#. +> trunk6 stable6
#: src/kleopatra_options.h:30
#, kde-format
msgctxt "@info:shell"
msgid "Same as --sign-encrypt, do not use"
msgstr "--sign-encrypt と同じ (使わないで)"

#. +> trunk6 stable6
#: src/kleopatra_options.h:31
#, kde-format
msgctxt "@info:shell"
msgid "Decrypt file(s)"
msgstr "ファイルを復号"

#. +> trunk6 stable6
#: src/kleopatra_options.h:32
#, kde-format
msgctxt "@info:shell"
msgid "Verify file/signature"
msgstr "ファイル/署名を検証"

#. +> trunk6 stable6
#: src/kleopatra_options.h:33
#, kde-format
msgctxt "@info:shell"
msgid "Decrypt and/or verify file(s)"
msgstr "ファイルを復号/検証"

#. +> trunk6 stable6
#: src/kleopatra_options.h:34
#, kde-format
msgctxt "@info:shell"
msgid "Search for a certificate on a keyserver"
msgstr "鍵サーバでの証明書の検索"

#. +> trunk6 stable6
#: src/kleopatra_options.h:35
#, kde-format
msgctxt "@info:shell"
msgid "Create or check a checksum file"
msgstr "チェックサムファイルを作成/チェックする"

#. +> trunk6 stable6
#: src/kleopatra_options.h:39
#, kde-format
msgctxt ""
"If a certificate is already known it shows the certificate details dialog. "
"Otherwise it brings up the certificate search dialog."
msgid ""
"Show details of a local certificate or search for it on a keyserver by "
"fingerprint"
msgstr "手元の証明書の詳細を表示またはフィンガープリントで鍵サーバを検索"

#. +> trunk6 stable6
#: src/kleopatra_options.h:40
#, kde-format
msgctxt "@info:shell"
msgid "Create a new key pair or certificate signing request"
msgstr "鍵ペアの作成、または証明書署名要求の作成"

#. +> trunk6 stable6
#: src/kleopatra_options.h:41
#, kde-format
msgctxt "@info:shell"
msgid "Parent Window Id for dialogs"
msgstr "ダイアログの親のウィンドウ ID"

#. +> trunk6 stable6
#: src/kleopatra_options.h:42
#, kde-format
msgctxt "@info:shell"
msgid "Open the config dialog"
msgstr "設定ダイアログを開く"

#. +> trunk6 stable6
#: src/kleopatra_options.h:43
#, kde-format
msgctxt "@info:shell"
msgid "Run as standalone app without system tray icon"
msgstr ""

#. +> trunk6 stable6
#: src/kleopatra_options.h:54
#, kde-format
msgctxt "@info:shell"
msgid "File(s) to process"
msgstr "処理するファイル"

#. +> trunk6 stable6
#: src/kleopatra_options.h:55
#, kde-format
msgctxt "@info:shell"
msgid "String or Fingerprint for query and search"
msgstr "問い合わせと検索のための文字列またはフィンガープリント"

#. +> trunk6 stable6
#: src/kleopatraapplication.cpp:458
#, kde-format
msgctxt "@title:window"
msgid "Failed to execute command"
msgstr "コマンド実行に失敗"

#. +> trunk6 stable6
#: src/kleopatraapplication.cpp:481
#, kde-kuit-format
msgctxt "@info"
msgid ""
"For technical reasons you can only use this option if <application>%1</"
"application> is not already running."
msgstr ""

#. +> trunk6 stable6
#: src/kleopatraapplication.cpp:518
#, kde-format
msgid "Ambiguous protocol: --openpgp and --cms"
