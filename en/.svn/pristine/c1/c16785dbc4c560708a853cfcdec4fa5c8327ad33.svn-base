msgid "One unknown recipient"
msgstr "不明な受信者一人"

#. +> trunk6 stable6
#: src/crypto/decryptverifytask.cpp:157
#, kde-format
msgid "One unknown recipient"
msgid_plural "%1 unknown recipients"
msgstr[0] "不明な受信者 %1 人"

