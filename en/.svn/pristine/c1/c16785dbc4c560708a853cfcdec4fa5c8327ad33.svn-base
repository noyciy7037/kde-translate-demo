#. +> trunk6 stable6
#: src/dialogs/weboftrustwidget.cpp:94
#, kde-format
msgid "User IDs and certifications"
msgstr "ユーザ ID と保証"

#. +> trunk6 stable6
#: src/dialogs/weboftrustwidget.cpp:100
#, kde-format
msgctxt "@info"
msgid "Certifications are not available before the certificate is imported."
msgstr "この証明書がインポートされる前には保証は利用可能ではありません。"

