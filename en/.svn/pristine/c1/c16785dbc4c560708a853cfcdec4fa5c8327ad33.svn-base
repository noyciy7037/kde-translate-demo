msgstr "コンプライアンス・チェック"

#. +> trunk6 stable6
#: src/selftest/compliancecheck.cpp:44
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para><application>GnuPG</application> is not configured for <icode>de-vs</"
