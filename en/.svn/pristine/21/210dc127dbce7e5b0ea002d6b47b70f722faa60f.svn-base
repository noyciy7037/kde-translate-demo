#. +> trunk6 stable6
#, kde-format
msgctxt "NAME OF TRANSLATORS"
msgid "Your names"
msgstr "Tadashi Jokagi,Shinsaku Nakagawa"

#. +> trunk6 stable6
#, kde-format
msgctxt "EMAIL OF TRANSLATORS"
msgid "Your emails"
msgstr "elf2000@users.sourceforge.net,shinsaku@users.sourceforge.jp"

#. +> trunk6 stable6
#: main.cpp:25
#, kde-format
msgid "Sweeper"
msgstr "Sweeper"

#. +> trunk6 stable6
#: main.cpp:27
#, kde-format
msgid "Helps clean unwanted traces the user leaves on the system."
msgstr "ユーザがシステム上に残す不要な痕跡を消去します。"

#. +> trunk6 stable6
#: main.cpp:29
#, fuzzy, kde-format
#| msgid "(c) 2003-2005, Ralf Hoelzer"
msgid "© 2003-2005, Ralf Hoelzer"
msgstr "(c) 2003-2005, Ralf Hoelzer"

#. +> trunk6 stable6
#: main.cpp:33
#, kde-format
msgid "Ralf Hoelzer"
msgstr "Ralf Hoelzer"

#. +> trunk6 stable6
#: main.cpp:33
#, kde-format
msgid "Original author"
msgstr "オリジナルの作者"

#. +> trunk6 stable6
#: main.cpp:34
#, kde-format
msgid "Brian S. Stephan"
msgstr "Brian S. Stephan"

#. +> trunk6 stable6
#: main.cpp:34
#, kde-format
msgid "Maintainer"
msgstr "メンテナ"

#. +> trunk6 stable6
#: main.cpp:35
#, kde-format
msgid "Benjamin Meyer"
msgstr "Benjamin Meyer"

#. +> trunk6 stable6
#: main.cpp:35 privacyfunctions.h:65
#, kde-format
msgid "Thumbnail Cache"
msgstr "サムネイルのキャッシュ"

#. +> trunk6 stable6
#: main.cpp:43
#, kde-format
msgid "Sweeps without user interaction"
msgstr ""

#. +> trunk6 stable6
#: privacyfunctions.cpp:44 privacyfunctions.cpp:53 privacyfunctions.cpp:62
#, kde-format
msgid "A thumbnail could not be removed."
msgstr "サムネイルを削除できませんでした。"

#. +> trunk6 stable6
#: privacyfunctions.cpp:131
#, kde-format
msgid "The file exists but could not be removed."
msgstr "ファイルは存在しますが、削除できませんでした。"

#. +> trunk6 stable6
#: privacyfunctions.cpp:210
#, kde-format
msgid "A favicon could not be removed."
msgstr "ファビコンを削除できませんでした。"

#. +> trunk6 stable6
#: privacyfunctions.h:22
#, kde-format
msgid "Cookies"
msgstr "クッキー"

#. +> trunk6 stable6
#: privacyfunctions.h:22
#, kde-format
msgid "Clears all stored cookies set by websites"
msgstr "ウェブサイトからセットされたクッキー消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:37
#, kde-format
msgid "Cookie Policies"
msgstr "クッキーポリシー"

#. +> trunk6 stable6
#: privacyfunctions.h:37
#, kde-format
msgid "Clears the cookie policies for all visited websites"
msgstr "訪問したすべてのウェブサイトに対するクッキーポリシーを消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:51
#, kde-format
msgid "Saved Clipboard Contents"
msgstr "クリップボードの内容"

#. +> trunk6 stable6
#: privacyfunctions.h:51
#, kde-format
msgid "Clears the clipboard contents stored by Klipper"
msgstr "Klipper に保存されたクリップボードの内容を消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:65
#, kde-format
msgid "Clears all cached thumbnails"
msgstr "キャッシュされたサムネイルをすべて消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:79
#, kde-format
msgid "Run Command History"
msgstr "実行したコマンドの履歴"

#. +> trunk6 stable6
#: privacyfunctions.h:79
#, kde-format
msgid ""
"Clears the history of commands run through the Run Command tool on the "
"desktop"
msgstr ""
"デスクトップの「コマンドを実行」ツールから実行したコマンドの履歴を消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:93
#, kde-format
msgid "Form Completion Entries"
msgstr "フォーム補完侯補"

#. +> trunk6 stable6
#: privacyfunctions.h:93
#, kde-format
msgid "Clears values which were entered into forms on websites"
msgstr "ウェブサイトのフォームに入力した値を消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:107
#, kde-format
msgid "Web History"
msgstr "ウェブ履歴"

#. +> trunk6 stable6
#: privacyfunctions.h:107
#, kde-format
msgid "Clears the history of visited websites"
msgstr "ウェブサイトの訪問履歴を消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:121
#, kde-format
msgid "Web Cache"
msgstr "ウェブのキャッシュ"

#. +> trunk6 stable6
#: privacyfunctions.h:121
#, kde-format
msgid "Clears the temporary cache of websites visited"
msgstr "訪問したウェブサイトの一時キャッシュを消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:135
#, kde-format
msgid "Recent Documents"
msgstr "最近の文書"

#. +> trunk6 stable6
#: privacyfunctions.h:135
#, kde-format
msgid ""
"Clears the list of recently used documents from the KDE applications menu"
msgstr ""
"最近使用した文書のリストを KDE のアプリケーションメニューから消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:149
#, kde-format
msgid "Favorite Icons"
msgstr "お気に入りアイコン"

#. +> trunk6 stable6
#: privacyfunctions.h:149
#, kde-format
msgid "Clears the FavIcons cached from visited websites"
msgstr "訪問したウェブサイトからキャッシュされたファビコンを消去します"

#. +> trunk6 stable6
#: privacyfunctions.h:163
#, kde-format
msgid "Recent Applications"
msgstr "最近使用したアプリケーション"

#. +> trunk6 stable6
#: privacyfunctions.h:163
#, kde-format
msgid "Clears the list of recently used applications from KDE menu"
msgstr "最近使用したアプリケーションのリストを KDE のメニューから消去します"

#. +> trunk6 stable6
#: sweeper.cpp:22
#, kde-format
msgctxt "General system content"
msgid "General"
msgstr "全般"

#. +> trunk6 stable6
#: sweeper.cpp:23
#, kde-format
msgctxt "Web browsing content"
msgid "Web Browsing"
msgstr "ウェブ閲覧"

#. +> trunk6 stable6
#: sweeper.cpp:100
#, kde-format
msgid ""
"You are deleting data that is potentially valuable to you. Are you sure?"
msgstr ""
"場合によってはあなたにとって貴重なデータを削除しようとしています。本当によろ"
"しいですか？"

#. +> trunk6 stable6
#: sweeper.cpp:107
#, kde-format
msgid "Starting cleanup..."
msgstr "クリーンアップ開始..."

#. +> trunk6 stable6
#: sweeper.cpp:111
#, kde-format
msgid "Clearing %1..."
msgstr "%1を消去..."

#. +> trunk6 stable6
#: sweeper.cpp:116
#, kde-format
msgid "Clearing of %1 failed: %2"
msgstr "%1の消去に失敗しました: %2"

#. +> trunk6 stable6
#: sweeper.cpp:122
#, kde-format
msgid "Clean up finished."
msgstr "クリーンアップが完了しました。"

#. i18n: ectx: property (whatsThis), widget (QTreeWidget, privacyListView)
#. +> trunk6 stable6
#: sweeperdialog.ui:27
#, kde-format
msgid ""
"Check all cleanup actions you would like to perform. These will be executed "
"by pressing the button below."
msgstr ""
"実行するクリーンアップアクションにチェックを入れてください。「クリーンアッ"
"プ」ボタンを押すと開始します。"

#. i18n: ectx: property (text), widget (QTreeWidget, privacyListView)
#. +> trunk6 stable6
#: sweeperdialog.ui:37
#, kde-format
msgid "Privacy Settings"
msgstr "プライバシー設定"

#. i18n: ectx: property (text), widget (QTreeWidget, privacyListView)
#. +> trunk6 stable6
#: sweeperdialog.ui:42
#, kde-format
msgid "Description"
msgstr "説明"

#. i18n: ectx: property (text), widget (QPushButton, selectAllButton)
#. +> trunk6 stable6
#: sweeperdialog.ui:58
#, kde-format
msgid "Select &All"
msgstr "すべて選択(&A)"

#. i18n: ectx: property (text), widget (QPushButton, selectNoneButton)
#. +> trunk6 stable6
#: sweeperdialog.ui:65
#, kde-format
msgid "Select &None"
msgstr "すべて選択解除(&N)"

#. i18n: ectx: property (whatsThis), widget (QPushButton, cleanupButton)
#. +> trunk6 stable6
#: sweeperdialog.ui:88
#, kde-format
msgid "Immediately performs the cleanup actions selected above"
msgstr "選択されたクリーンアップアクションを直ちに実行します"

#. i18n: ectx: property (text), widget (QPushButton, cleanupButton)
#. +> trunk6 stable6
#: sweeperdialog.ui:91
#, kde-format
msgid "&Clean Up"
msgstr "クリーンアップ(&C)"

#~ msgid "(c) 2003-2005, Ralf Hoelzer"
#~ msgstr "(c) 2003-2005, Ralf Hoelzer"

#~ msgid ""
#~ "Check all cleanup actions you would like to perform. These will be "
#~ "executed by pressing the button below"
#~ msgstr ""
#~ "実行するクリーンアップアクションにチェックを入れてください。「クリーンアッ"
#~ "プ」ボタンを押すと開始します。"

#~ msgid "Network privacy level:"
#~ msgstr "ネットワークのプライバシーレベル:"

#~ msgid "Low"
#~ msgstr "低"

#~ msgid "Medium"
#~ msgstr "中"

#~ msgid "High"
#~ msgstr "高"

#~ msgid "Custom"
#~ msgstr "カスタム"

#~ msgid "Financial Information"
#~ msgstr "金融情報"

#~ msgid ""
#~ "Warn me when I visit a site that uses my financial or purchase "
#~ "information:"
#~ msgstr ""
#~ "私の金融や買い物に関する情報を使用するサイトを訪れた場合、警告してくださ"
#~ "い:"

#~ msgid "For marketing or advertising purposes"
#~ msgstr "マーケティングや広告の目的で"

#~ msgid "To share with other companies"
#~ msgstr "他の会社と共有するために"

#~ msgid "Health Information"
#~ msgstr "健康に関する情報"

#~ msgid ""
#~ "Warn me when I visit a site that uses my health or medical information: "
#~ msgstr "私の健康に関する情報を使用するサイトを訪れた場合、警告してください:"

#~ msgid "Demographics"
#~ msgstr "人口統計"

#~ msgid ""
#~ "Warn me when I visit a site that uses my non-personally identifiable "
#~ "information:"
#~ msgstr ""
#~ "個人を特定できない私に関する情報を使用するサイトを訪れた場合、警告してくだ"
#~ "さい:"

#~ msgid "To determine my interests, habits or general behavior"
#~ msgstr "私の興味、習慣または全般的な行動を知るために"

#~ msgid ""
#~ "Warn me when I visit a site that shares my personal information with "
#~ "other companies"
#~ msgstr ""
#~ "私の個人情報を他の会社と共有するサイトを訪れた場合、警告してください"

#~ msgid ""
#~ "Warn me when I visit a site that does not let me know what information "
#~ "they have about me"
#~ msgstr ""
#~ "私に関してどのような情報を収集しているかを明らかにしないサイトを訪れた場"
#~ "合、警告してください"

#~ msgid "Personal Information"
#~ msgstr "個人情報"

#~ msgid ""
#~ "Warn me when I visit a site that may contact me about other products or "
#~ "services:"
#~ msgstr ""
#~ "他の製品あるいはサービスに関して私と連絡を取る可能性のあるサイトを訪れた場"
#~ "合、警告してください:"

#~ msgid "Warn me when I visit a site that may use my personal information to:"
#~ msgstr ""
#~ "私の個人情報を以下の目的で使用する可能性のあるサイトを訪れた場合、警告して"
#~ "ください:"

#~ msgid "Determine my habits, interests or general behavior"
#~ msgstr "私の習慣、興味または全般的な行動を知るため"

#~ msgid "Via telephone"
#~ msgstr "電話で"

#~ msgid "Via mail"
#~ msgstr "郵便物で"

#~ msgid "Via email"
#~ msgstr "メールで"

#~ msgid "And do not allow me to remove my contact information"
#~ msgstr "そして、私の連絡先情報を削除させない"
