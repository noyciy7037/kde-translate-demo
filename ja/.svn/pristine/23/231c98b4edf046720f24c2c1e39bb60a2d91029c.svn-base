#~ "right:0px; -qt-block-indent:0; text-indent:0px;\">The maximum number of "
#~ "outgoing connections ktorrent will try to setup simultaneously.</p>\n"
#~ "<p style=\"-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; "
