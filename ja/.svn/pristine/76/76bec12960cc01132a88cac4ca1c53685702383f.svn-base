"Banding detection range in pixels. Default is 16.<br>\n"
"        If positive, random number in range 0 to set value will be used. If "
"negative, exact absolute value will be used. The range defines square of "
"four pixels around current pixel."
msgstr ""

#. +> stable6
#: data/effects/avfilter/avfilter_deband.xml:30
#, kde-format
msgid ""
"<![CDATA[Banding detection range in pixels. Default is 16.<br>\n"
"        If positive, random number in range 0 to set value will be used. If "
"negative, exact absolute value will be used. The range defines square of "
"four pixels around current pixel.]]>"
msgstr ""

#. +> trunk6 stable6
#: data/effects/avfilter/avfilter_deband.xml:33
#: data/effects/avfilter/avfilter_transpose.xml:8
#: data/effects/frei0r/frei0r_aech0r.xml:12 data/effects/timer.xml:66
#: data/transitions/slide.xml:8
#, kde-format
msgid "Direction"
msgstr "方向"

#. +> trunk6
#: data/effects/avfilter/avfilter_deband.xml:35
#, kde-format
msgid ""
"Sets direction in degrees from which four pixel will be compared.<br>\n"
"        If positive, random direction from 0 to set direction will be "
"picked. If negative, exact of absolute value will be picked. For example "
"direction 0°, -180°, or -360° will pick only pixels on same row and -90° "
"will pick only pixels on same column"
msgstr ""

#. +> stable6
#: data/effects/avfilter/avfilter_deband.xml:35
#, kde-format
msgid ""
"<![CDATA[Sets direction in degrees from which four pixel will be compared."
"<br>\n"
"        If positive, random direction from 0 to set direction will be "
"picked. If negative, exact of absolute value will be picked. For example "
"direction 0°, -180°, or -360° will pick only pixels on same row and -90° "
"will pick only pixels on same column]]>"
msgstr ""

