#. +> trunk6 stable6
#: src/monitor/view/MonitorRuler.qml:237
#, fuzzy, kde-kuit-format
#| msgid ""
#| "<b>Wheel</b> or <b>arrows</b> to seek 1 frame, <b>Shift</b> to seek 1 "
