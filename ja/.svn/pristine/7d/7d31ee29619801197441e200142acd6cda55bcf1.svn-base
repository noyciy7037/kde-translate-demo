#. home.laptop.oldcomputer
#. +> trunk5
#: i18n/en.yaml:44
msgid "YOUR OLD<br>COMPUTER"
msgstr "あなたの古い<br>コンピューター"

#~ msgid "Support for Windows 10 ends on October 14, 2025."
#~ msgstr "Windows 10 のサポートは2025年10月14日で終わります。"

#~ msgid ""
#~ "Put repair cafes and independent computer shops offering Linux support in "
#~ "touch with us"
#~ msgstr ""
#~ "Linux のサポートを提供するリペアカフェや独立系コンピュータショップを私たち"
#~ "に紹介してください"

#~ msgid "Organize an installation event and let us know about it"
#~ msgstr "インスタレーションイベントを企画して私たちに知らせてください"

#~ msgid ""
#~ "Design materials for new users such as guides, promotional flyers, etc."
#~ msgstr "ガイドや販促チラシなど、新規ユーザー向けの資料をデザインします。"

#~ msgid ""
#~ "Distribute materials in cafes, shops, universities, schools in your area"
#~ msgstr "地域のカフェ、ショップ、大学、学校で資料を配布する"

#~ msgid ""
#~ "Boost the campaign's online presence by sharing our social media posts"
#~ msgstr ""
#~ "ソーシャルメディアの投稿を共有してキャンペーンのオンラインプレゼンスを高め"
#~ "ましょう"

#~ msgid "You can find a leaflet in various languages here:"
#~ msgstr "さまざまな言語のリーフレットは、こちらからご覧いただけます。"

#~ msgid ""
#~ "https://invent.kde.org/teams/eco/opt-green/-/tree/master/materials/"
#~ "leaflets"
#~ msgstr ""
#~ "https://invent.kde.org/teams/eco/opt-green/-/tree/master/materials/"
#~ "leaflets"

#~ msgid "We are working on posters. Check here again soon."
#~ msgstr "ポスターの制作に取り組んでいます。またここを確認してください。"

#~ msgid ""
#~ "The End Of 10 website and outreach are intentionally distro-agnostic. The "
#~ "goal is to speak as a big FOSS family. We want the campaign and "
#~ "activities to represent all of our communities."
#~ msgstr ""
#~ "End Of 10 のウェブサイトとアウトリーチは、意図的にディストリビューションに"
#~ "依存しません。我々の目標は、大きな FOSS ファミリーとして発言することです。"
#~ "私たちはキャンペーンと活動を私たちのコミュニティすべてを代表するために。"

#~ msgid ""
#~ "For example, one of the planned activities is a \"Lists of 10\" social "
#~ "media campaign with the hashtag `#EndOf10`. In this context:"
#~ msgstr ""
#~ "例えば、計画されている活動のひとつに、`#EndOf10` というハッシュタグを使っ"
#~ "た「10のリスト」ソーシャルメディアキャンペーンがあります。この文脈では:"

#~ msgid ""
#~ "The official End Of 10 social media account remains as neutral as "
#~ "possible (e.g., \"10 reasons to switch to Linux\") and does not promote "
#~ "any specific distro."
#~ msgstr ""
#~ "公式の「End Of 10」ソーシャルメディアアカウントは、できるだけ中立的な立場"
#~ "を保ちます (例えば、「Linux に乗り換える10の理由」といった内容などです)。"
#~ "特定のディストリビューション (Linux の種類) を推奨することはありません。"

#~ msgid ""
#~ "Your community does outreach on social media with a \"10 reasons to "
#~ "switch to \\<YOUR PROJECT\\>\" with the `#EndOf10` hashtag. In the list "
#~ "of reasons you promote your own work. However, it would be unacceptable "
#~ "to speak negatively about any other FOSS community's work."
#~ msgstr ""
#~ "あなたのコミュニティがソーシャルメディアで「\\<YOUR PROJECT\\>に乗り換える"
#~ "10の理由」という形で #EndOf10 ハッシュタグを使って情報発信するのは歓迎され"
#~ "ます。そのリストの中で自分たちのプロジェクトの良さをアピールするのは問題あ"
#~ "りません。ただし、他の FOSS コミュニティの活動やプロジェクトを否定的に語る"
#~ "ことは許されません。"
