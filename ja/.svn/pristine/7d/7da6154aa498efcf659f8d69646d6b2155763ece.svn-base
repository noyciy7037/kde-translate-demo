msgid "KIO Client"
msgstr "KIO クライアント"

#. +> trunk6 stable6 stable5
#: kioclient.cpp:180
#, kde-format
msgid "Command-line tool for network-transparent operations"
msgstr "ネットワーク透過な操作のためのコマンドラインツール"

