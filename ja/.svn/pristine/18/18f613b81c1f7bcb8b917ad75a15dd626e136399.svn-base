#. +> trunk6 stable6 stable5
#: app/ExternalAppModule.cpp:26
#, kde-format
msgid "%1 is an external application and has been automatically launched"
msgstr "外部アプリケーション %1 を自動的に起動しました"

#. +> trunk6 stable6 stable5
#: app/ExternalAppModule.cpp:27
#, kde-format
msgid "Relaunch %1"
msgstr "%1 を再起動"

#. i18n: ectx: property (windowTitle), widget (QWidget, ExternalModule)
#. +> trunk6 stable6 stable5
#: app/externalModule.ui:14
#, kde-format
msgid "Dialog"
msgstr "ダイアログ"

#. +> trunk6 stable6 stable5
#: app/main.cpp:54 app/SettingsBase.cpp:53
#, kde-format
msgid "Info Center"
msgstr "情報センター"

#. +> trunk6 stable6 stable5
#: app/main.cpp:56
#, kde-format
msgid "Centralized and convenient overview of system information."
msgstr "システム情報の概要"

#. +> trunk6 stable6 stable5
#: app/main.cpp:58 app/main.cpp:69
#, kde-format
msgid "(c) 2009, Ben Cooksley"
msgstr "(c) 2009, Ben Cooksley"

#. +> trunk6 stable6 stable5
#: app/main.cpp:65 app/qml/IntroPage.qml:51 app/SettingsBase.cpp:56
#: runner/systemsettingsrunner.cpp:112
#, kde-format
msgid "System Settings"
msgstr "KDE システム設定"

#. +> trunk6 stable6 stable5
#: app/main.cpp:67
#, kde-format
msgid "Central configuration center by KDE."
msgstr "KDE のシステム設定センター"

#. +> trunk6 stable6 stable5
#: app/main.cpp:80
#, kde-format
msgid "Ben Cooksley"
msgstr "Ben Cooksley"

#. +> trunk6 stable6 stable5
#: app/main.cpp:80
#, kde-format
msgid "Maintainer"
msgstr "メンテナ"

#. +> trunk6 stable6 stable5
#: app/main.cpp:81
#, kde-format
msgid "Marco Martin"
msgstr "Marco Martin"

#. +> trunk6 stable6 stable5
#: app/main.cpp:81
#, kde-format
msgid "Author"
msgstr "作者"

#. +> trunk6 stable6 stable5
#: app/main.cpp:82
#, kde-format
msgid "Mathias Soeken"
msgstr "Mathias Soeken"

#. +> trunk6 stable6 stable5
#: app/main.cpp:82
#, kde-format
msgid "Developer"
msgstr "開発者"

#. +> trunk6 stable6 stable5
#: app/main.cpp:83
#, kde-format
msgid "Will Stephenson"
msgstr "Will Stephenson"

#. +> trunk6 stable6 stable5
#: app/main.cpp:83
#, kde-format
msgid "Internal module representation, internal module model"
msgstr "内部モジュール表現、内部モジュールモデル"

#. +> trunk6 stable6 stable5
#: app/main.cpp:91
#, kde-format
msgid "List all possible modules"
msgstr "利用可能なモジュールをすべて表示"

#. +> trunk6 stable6 stable5
#: app/main.cpp:92 app/main.cpp:153
#, kde-format
msgid "Configuration module to open"
msgstr "モジュール設定"

#. +> trunk6 stable6 stable5
#: app/main.cpp:93 app/main.cpp:154
#, kde-format
msgid "Arguments for the module"
msgstr "モジュールの引数"

#. +> trunk6 stable6 stable5
#: app/main.cpp:101
#, kde-format
msgid "The following modules are available:"
msgstr "以下のモジュールが用意されています:"

#. +> trunk6 stable6 stable5
#: app/main.cpp:119
#, kde-format
msgid "No description available"
msgstr "利用可能な説明はありません"

#. +> trunk6 stable6 stable5
#: app/ModuleView.cpp:185
#, kde-format
msgid "Reset all current changes to previous values"
msgstr "現在のすべての変更を元の値に戻します"

#. +> trunk6 stable6
#: app/ModuleView.cpp:278
#, kde-format
msgctxt "@info:whatsthis"
msgid "Scrollable area"
msgstr "スクロールできるエリア"

#. +> trunk6 stable6
#: app/ModuleView.cpp:368
#, kde-format
msgid ""
"The current page has unsaved changes.\n"
"Apply the changes or discard them?"
msgstr ""
"現在のページには保存されていない変更があります。\n"
"変更を適用しますか？それとも破棄しますか？"

#. +> trunk6 stable6 stable5
#: app/ModuleView.cpp:373
#, kde-format
msgid "Apply Settings"
msgstr "設定を適用"

#. +> trunk6 stable6 stable5
#: app/qml/CategoriesPage.qml:106
#, kde-format
msgctxt "A search yielded no results"
msgid "No items matching your search"
msgstr "検索にヒットするアイテムはありません"

#. +> trunk6 stable6 stable5
#: app/qml/HamburgerMenuButton.qml:25
#, kde-format
msgid "Show menu"
msgstr "メニューの表示"

#. +> trunk6 stable6 stable5
#: app/qml/IntroPage.qml:44
#, kde-format
msgid "Plasma"
msgstr "Plasma"

#. +> trunk6
#: app/qml/SubCategoryPage.qml:71
#, kde-format
msgctxt "@action:button go back"
msgid "Back"
msgstr "戻る"

#. +> stable5
#: app/SettingsBase.cpp:60
#, kde-format
msgctxt "Search through a list of control modules"
msgid "Search"
msgstr "検索"

#. +> trunk6 stable6 stable5
#: app/SettingsBase.cpp:144
#, kde-format
msgid "Highlight Changed Settings"
msgstr "変更された設定を強調表示"

#. +> trunk6 stable6
#: app/SettingsBase.cpp:152
#, kde-format
msgctxt ""
"@option:check the pages being referred to here are System Settings KCMs"
msgid "Show Inapplicable Pages"
msgstr "利用できないページを表示"

#. +> stable5
#: app/SettingsBase.cpp:157
#, kde-format
msgid "Switch to Icon View"
msgstr "アイコン表示に切り替え"

#. +> trunk6 stable6 stable5
#: app/SettingsBase.cpp:163
#, kde-format
msgid "Report a Bug in the Current Page…"
msgstr "現在のページのバグを報告..."

#. +> stable5
#: app/SettingsBase.cpp:164
#, kde-format
msgid "Switch to Sidebar View"
msgstr "サイドバー表示に切り替え"

#. +> stable5
#: app/SettingsBase.cpp:211
#, kde-format
msgid "Help"
msgstr "ヘルプ"

#. +> stable5
#: app/SettingsBase.cpp:368
#, kde-format
msgid ""
"System Settings was unable to find any views, and hence has nothing to "
"display."
msgstr "システム設定がビューを見つけられなかったので表示するものはありません。"

#. +> stable5
#: app/SettingsBase.cpp:369
#, kde-format
msgid "No views found"
msgstr "ビューが見つかりません"

#. +> stable5
#: app/SettingsBase.cpp:427
#, kde-format
msgid "About Active View"
msgstr "現在のビューについて"

#. +> stable5
#: app/SettingsBase.cpp:498
#, kde-format
msgid "About %1"
msgstr "%1 について"

#. +> trunk6 stable6 stable5
#: app/SidebarMode.cpp:600
#, kde-format
msgid "Sidebar"
msgstr "サイドバー"

#. +> trunk6 stable6 stable5
#: app/SidebarMode.cpp:669
#, kde-format
msgid "Most Used"
msgstr "よく使う設定"

#. +> trunk6 stable6 stable5
#: runner/systemsettingsrunner.cpp:32
#, kde-format
msgid "Finds system settings modules whose names or descriptions match :q:"
msgstr "名前または説明が :q: に一致するシステム設定モジュールを検索します。"

#. +> trunk6 stable6 stable5
#: runner/systemsettingsrunner.cpp:110
#, kde-format
msgid "System Information"
msgstr "システム情報"

#. i18n: ectx: label, entry (ActiveView), group (Main)
#. +> stable5
#: app/systemsettings.kcfg:9
#, kde-format
msgid "Internal name for the view used"
msgstr "使用されるビューの内部名"

#. i18n: ectx: ToolBar (mainToolBar)
#. +> stable5
#: app/systemsettingsui.rc:15
#, kde-format
msgid "About System Settings"
msgstr "KDE システム設定について"

#. +> stable5
#: app/ToolTips/tooltipmanager.cpp:188
#, kde-format
msgid "Contains 1 item"
msgid_plural "Contains %1 items"
msgstr[0] "%1 アイテムを含む"

#. +> stable5
#: core/ModuleView.cpp:331
#, kde-format
msgid ""
"The settings of the current module have changed.\n"
"Do you want to apply the changes or discard them?"
msgstr ""
"現在のモジュールの設定が変更されました。\n"
"変更を適用しますか？それとも破棄しますか？"

#. +> stable5
#: icons/IconMode.cpp:54
#, kde-format
msgid "Icon View"
msgstr "アイコン表示"

#. +> stable5
#: icons/IconMode.cpp:56
#, kde-format
msgid "Provides a categorized icons view of control modules."
msgstr "設定モジュールをカテゴリ別にアイコンで表示します。"

#. +> stable5
#: icons/IconMode.cpp:63
#, kde-format
msgid "All Settings"
msgstr "すべての設定"

#. +> stable5
#: icons/IconMode.cpp:64
#, kde-format
msgid "Keyboard Shortcut: %1"
msgstr "キーボードショートカット: %1"

#. +> stable5
#: sidebar/package/contents/ui/CategoriesPage.qml:56
#, kde-format
msgid "Show intro page"
msgstr "初期ページを表示"

#. +> stable5
#: sidebar/SidebarMode.cpp:166
#, kde-format
msgid "Sidebar View"
msgstr "サイドバー表示"

#. +> stable5
#: sidebar/SidebarMode.cpp:168
#, kde-format
msgid "Provides a categorized sidebar for control modules."
msgstr "設定モジュールのためのカテゴリ別のサイドバーを提供します。"

#. +> stable5
#: sidebar/SidebarMode.cpp:170
#, kde-format
msgid "(c) 2017, Marco Martin"
msgstr "(c) 2017, Marco Martin"

