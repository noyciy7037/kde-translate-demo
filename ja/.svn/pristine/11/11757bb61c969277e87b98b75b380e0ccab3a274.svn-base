#. i18n: ectx: property (text), item, widget (QComboBox, kcfg_SignMenu)
#. i18n: ectx: property (text), item, widget (QComboBox, kcfg_DecryptMenu)
#. +> trunk6 stable6
#: conf_misc.ui:139 conf_misc.ui:178 keysmanager.cpp:296
#, kde-format
