#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/grayworld.rst:47
msgid ""
"This effect/filter is color constancy filter that applies color correction "
"(adjusting the white balance) based on the gray-world assumption\\ [1]_."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/grayworld.rst:49
msgid ""
"The LAB gray-world algorithm uses linear light, so input data should be "
"linearized beforehand (and possibly correctly tagged)."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/grayworld.rst:58
msgid ""
"For more details refer to the |grayworld| publication at researchgate.net"
msgstr ""

