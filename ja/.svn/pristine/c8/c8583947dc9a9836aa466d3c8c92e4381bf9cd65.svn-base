#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:122
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"This wallpaper provider does not filter out images that may be sensitive or "
"objectionable. Use caution if these images will be displayed in public."
msgstr ""
"この壁紙プロバイダは、不快に思われる可能性のある画像を除外しません。壁紙が公"
"共の場で表示される可能性がある場合は、注意して使用してください。"

#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:131
#, kde-format
msgctxt "@option:check"
msgid "Update when using metered network connection"
msgstr "従量課金制ネットワークを使用しているときも更新する"

#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:146
#, kde-format
msgctxt "@label"
msgid "Today's picture:"
msgstr "今日の写真:"

#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:162
#, kde-format
msgctxt "@label"
msgid "Title:"
msgstr "タイトル:"

#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:177
#, kde-format
msgctxt "@label"
msgid "Author:"
msgstr "作者:"

#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:196
#, kde-format
msgctxt "@action:button"
msgid "Open Containing Folder"
msgstr "保存されているフォルダを開く"

#. +> trunk6 stable6 stable5
#: package/contents/ui/config.qml:200
#, kde-format
msgctxt "@info:whatsthis for a button"
msgid "Open the destination folder where the wallpaper image was saved."
msgstr "壁紙の画像が保存されているフォルダを開く"

#. +> trunk6 stable6
#: package/contents/ui/main.qml:22
#, kde-format
msgid "Open Wallpaper Image"
msgstr "壁紙画像を開く"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperDelegate.qml:137
#, kde-format
msgctxt "@info:whatsthis"
msgid "Today's picture"
msgstr "今日の写真"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperDelegate.qml:138
#, kde-format
msgctxt "@info:whatsthis"
msgid "Loading"
msgstr "読み込み中"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperDelegate.qml:139
#, kde-format
msgctxt "@info:whatsthis"
msgid "Unavailable"
msgstr "利用できません"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperDelegate.qml:140
#, kde-format
msgctxt "@info:whatsthis for an image %1 title %2 author"
msgid "%1 Author: %2. Right-click on the image to see more actions."
msgstr ""
"%1 作者: %2。さらなるアクションを表示するには画像を右クリックしてください。"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperDelegate.qml:141
#, kde-format
msgctxt "@info:whatsthis"
msgid "The wallpaper is being fetched from the Internet."
msgstr "壁紙がインターネットから取得されています。"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperDelegate.qml:142
#, kde-format
msgctxt "@info:whatsthis"
msgid "Failed to fetch the wallpaper from the Internet."
msgstr "インターネットからの壁紙の取得に失敗しました。"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperPreview.qml:48
#, kde-format
msgctxt "@action:inmenu wallpaper preview menu"
msgid "Save Image as…"
msgstr "名前を付けて保存..."

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperPreview.qml:51
#, kde-format
msgctxt "@info:whatsthis for a button and a menu item"
msgid "Save today's picture to local disk"
msgstr "今日の写真をローカルディスクに保存する"

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperPreview.qml:57
#, kde-format
msgctxt ""
"@action:inmenu wallpaper preview menu, will open the website of the wallpaper"
msgid "Open Link in Browser…"
msgstr "リンクをブラウザで開く..."

#. +> trunk6 stable6 stable5
#: package/contents/ui/WallpaperPreview.qml:60
#, kde-format
msgctxt "@info:whatsthis for a menu item"
msgid "Open the website of today's picture in the default browser"
msgstr "今日の写真のウェブサイトをデフォルトのブラウザで開く"

#. +> trunk6 stable6 stable5
#: plugins/potdbackend.cpp:213
#, kde-format
msgctxt "@title:window"
msgid "Save Today's Picture"
msgstr "今日の写真を保存"

#. +> trunk6 stable6 stable5
#: plugins/potdbackend.cpp:215
#, kde-format
msgctxt "@label:listbox Template for file dialog"
msgid "JPEG image (*.jpeg *.jpg *.jpe)"
msgstr "JPEG 画像 (*.jpeg *.jpg *.jpe)"

#. +> trunk6 stable6 stable5
#: plugins/potdbackend.cpp:232
#, kde-format
msgctxt "@info:status after a save action"
msgid "The image was not saved."
msgstr "画像は保存されませんでした。"

#. +> trunk6 stable6 stable5
#: plugins/potdbackend.cpp:239
#, kde-format
msgctxt "@info:status after a save action %1 file path %2 basename"
msgid "The image was saved as <a href=\"%1\">%2</a>"
msgstr "画像は <a href=\"%1\">%2</a> として保存されました。"

