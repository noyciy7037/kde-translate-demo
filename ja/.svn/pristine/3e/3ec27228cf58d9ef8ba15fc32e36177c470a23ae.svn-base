#. (itstool) path: component/name
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:11
msgid "Ark"
msgstr "Ark"

#. (itstool) path: component/summary
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:12
msgid "Archiving Tool"
msgstr "アーカイブツール"

#. (itstool) path: description/p
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:14
msgid ""
"Ark is a graphical file compression/decompression utility with support for "
"multiple formats, including tar, gzip, bzip2, rar and zip, as well as CD-ROM "
"images. Ark can be used to browse, extract, create, and modify archives."
msgstr ""
"Ark はグラフィカルなファイル圧縮/展開ユーティリティで、tar、gzip、bzip2、"
"rar、zip、および CD-ROM イメージを含む複数の形式をサポートしています。Ark は"
"アーカイブの閲覧、展開、作成、および変更に使用できます。"

#. (itstool) path: description/p
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:19
msgid "Features:"
msgstr "機能:"

#. (itstool) path: ul/li
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:21
msgid "Several formats supported: gzip, bzip2, zip, rar, 7z and more"
msgstr "さまざまな形式をサポート: gzip、bzip2、zip、rar、7z など"

#. (itstool) path: ul/li
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:22
msgid "Preview file contents without extracting files"
msgstr "ファイルを展開せずにファイルの内容をプレビュー"

#. (itstool) path: screenshot/caption
#. +> trunk6 stable6
#: org.kde.ark.appdata.xml:27
msgid "Managing archives with Ark"
msgstr "Ark によるアーカイブの管理"
