#~ msgid ""
#~ "<h3>Rules of Game</h3><p>You are the system administrator and your goal "
#~ "is to connect each terminal and each cable to the central server.</"
#~ "p><p>Click the right mouse button to turn the cable in a clockwise "
#~ "direction, and the left mouse button to turn the cable in a "
#~ "counterclockwise direction.</p><p>Start the LAN with as few turns as "
#~ "possible!</p>"
#~ msgstr ""
#~ "<h3>ゲームのルール</h3><p>あなたはシステム管理者となり、すべてのターミナル"
#~ "とケーブルを中央サーバに接続することを目標とします。右クリックでケーブルを"
#~ "時計回りに曲げ、左クリックで反時計回りに曲げます。</p><p>できるだけ少ない"
#~ "回数で LAN を構築しましょう!</p>"

#~ msgid "New Game"
#~ msgstr "新しいゲーム"

#~ msgid "The graphical theme to be used."
#~ msgstr "使用するグラフィックテーマ"

#~ msgid "The difficulty level."
#~ msgstr "難易度"

#~ msgid "Start with Easy difficulty level"
#~ msgstr "難易度「簡単」で開始"

#~ msgid "Start with Medium difficulty level"
#~ msgstr "難易度「普通」で開始"

#~ msgid "Start with Hard difficulty level"
#~ msgstr "難易度「難しい」で開始"

#~ msgid "Start with Very Hard difficulty level"
#~ msgstr "難易度「非常に難しい」で開始"

#~ msgid "Use &Keyboard"
#~ msgstr "キーボードを使う(&K)"

#~ msgid "Failed to load \"%1\" theme. Please check your installation."
#~ msgstr ""
#~ "テーマ “%1” を読み込めませんでした。インストールを確認してください。"

#~ msgid ""
#~ "<h3>Rules of Game</h3><p>You are the system administrator and your goal "
#~ "is to connect each terminal and each cable to the central server.</"
#~ "p><p>Click the right mouse's button for turning the cable in a clockwise "
#~ "direction, and left mouse's button for turning the cable in a counter-"
#~ "clockwise direction.</p><p>Start the LAN with as few turns as possible!</"
#~ "p>"
#~ msgstr ""
#~ "<h3>ゲームのルール</h3><p>あなたはシステム管理者となり、すべてのターミナル"
#~ "とケーブルを中央サーバに接続することを目標とします。右クリックでケーブルを"
#~ "時計回りに曲げ、左クリックで反時計回りに曲げます。</p><p>できるだけ少ない"
#~ "回数で LAN を構築しましょう!</p>"

#~ msgid "Your score was %1, you did not make it to the highScore list"
#~ msgid_plural "Your score was %1, you did not make it to the highScore list"
