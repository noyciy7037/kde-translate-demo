msgid "system error: %1"
msgstr "システムエラー: %1"

#. +> trunk5
#: kdecore/k3resolver.cpp:556
#, kde-format
msgid "request was canceled"
msgstr "要求はキャンセルされました"

#. +> trunk5
#: kdecore/k3socketaddress.cpp:631
#, kde-format
msgctxt "1: the unknown socket address family number"
msgid "Unknown family %1"
msgstr "未知のファミリ %1"

#. +> trunk5
#: kdecore/k3socketbase.cpp:215
#, kde-format
msgctxt "Socket error code NoError"
msgid "no error"
msgstr "エラーなし"

#. +> trunk5
#: kdecore/k3socketbase.cpp:220
#, kde-format
msgctxt "Socket error code LookupFailure"
msgid "name lookup has failed"
msgstr "名前検索は失敗しました"

#. +> trunk5
#: kdecore/k3socketbase.cpp:225
#, kde-format
msgctxt "Socket error code AddressInUse"
msgid "address already in use"
msgstr "アドレスは既に使用されています"

#. +> trunk5
#: kdecore/k3socketbase.cpp:230
#, kde-format
msgctxt "Socket error code AlreadyBound"
msgid "socket is already bound"
msgstr "ソケットは既にバインドされています"

#. +> trunk5
#: kdecore/k3socketbase.cpp:235
#, kde-format
msgctxt "Socket error code AlreadyCreated"
msgid "socket is already created"
msgstr "ソケットは既に作成されています"

#. +> trunk5
#: kdecore/k3socketbase.cpp:240
#, kde-format
msgctxt "Socket error code NotBound"
msgid "socket is not bound"
msgstr "ソケットはバインドされていません"

#. +> trunk5
#: kdecore/k3socketbase.cpp:245
#, kde-format
msgctxt "Socket error code NotCreated"
msgid "socket has not been created"
msgstr "ソケットは作成されていません"

#. +> trunk5
#: kdecore/k3socketbase.cpp:250
#, kde-format
msgctxt "Socket error code WouldBlock"
msgid "operation would block"
msgstr "操作がブロックされます"

#. +> trunk5
#: kdecore/k3socketbase.cpp:255
#, kde-format
msgctxt "Socket error code ConnectionRefused"
msgid "connection actively refused"
msgstr "接続は積極的に拒否されました"

#. +> trunk5
#: kdecore/k3socketbase.cpp:260
#, kde-format
msgctxt "Socket error code ConnectionTimedOut"
msgid "connection timed out"
msgstr "接続タイムアウト"

#. +> trunk5
#: kdecore/k3socketbase.cpp:265
#, kde-format
msgctxt "Socket error code InProgress"
msgid "operation is already in progress"
msgstr "操作は既に実行中です"

#. +> trunk5
#: kdecore/k3socketbase.cpp:270
#, kde-format
msgctxt "Socket error code NetFailure"
msgid "network failure occurred"
msgstr "ネットワーク障害が発生しました"

#. +> trunk5
#: kdecore/k3socketbase.cpp:275
#, kde-format
msgctxt "Socket error code NotSupported"
msgid "operation is not supported"
msgstr "操作はサポートされていません"

#. +> trunk5
#: kdecore/k3socketbase.cpp:280
#, kde-format
msgctxt "Socket error code Timeout"
msgid "timed operation timed out"
msgstr "操作はタイムアウトしました"

#. +> trunk5
#: kdecore/k3socketbase.cpp:285
#, kde-format
msgctxt "Socket error code UnknownError"
msgid "an unknown/unexpected error has happened"
msgstr "未知の/予期しないエラーが発生しました"

#. +> trunk5
#: kdecore/k3socketbase.cpp:290
#, kde-format
msgctxt "Socket error code RemotelyDisconnected"
msgid "remote host closed connection"
msgstr "リモートホストは接続を閉じました"

