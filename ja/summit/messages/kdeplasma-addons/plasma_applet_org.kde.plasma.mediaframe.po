#. +> trunk6 stable6 stable5
#: qml/ConfigBehavior.qml:48
#, kde-format
msgid "Change picture every:"
msgstr "次の間隔で画像を変更:"

#. +> trunk6 stable6 stable5
#: qml/ConfigBehavior.qml:65
#, kde-format
msgid "Hours"
msgstr "時"

#. +> trunk6 stable6 stable5
#: qml/ConfigBehavior.qml:79
#, kde-format
msgid "Minutes"
msgstr "分"

#. +> trunk6 stable6 stable5
#: qml/ConfigBehavior.qml:93
#, kde-format
