msgid "Randomize order"
msgstr "並び順をランダム化"

#. +> trunk6 stable6 stable5
#: qml/ConfigBehavior.qml:192
#, kde-format
msgctxt "@option:check"
msgid "Pause slideshow when cursor is over image"
msgstr "カーソルが画像の上に来たときにスライドショーを一時停止"

#. +> trunk6 stable6 stable5
#: qml/ConfigBehavior.qml:197
#, kde-format
msgctxt "@option:check"
msgid "Click on image to open in external application"
msgstr "画像をクリックして他のアプリケーションを開く"

