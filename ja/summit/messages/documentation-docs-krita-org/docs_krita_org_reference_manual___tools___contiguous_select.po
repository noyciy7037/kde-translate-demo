#: ../../reference_manual/tools/contiguous_select.rst:72
msgid "Select which layers to use as a reference for the contiguous select tool. The options are:"
msgstr "連続領域選択ツールが判定に使用するレイヤーを選択します。オプションは:"

#. +> trunk5
#: ../../reference_manual/tools/contiguous_select.rst:74
msgid "Current Layer"
msgstr "現在のレイヤー"

#. +> trunk5
#: ../../reference_manual/tools/contiguous_select.rst:75
msgid "Only use the currently selected layer."
msgstr "現在のレイヤーのみを使用します。"

#. +> trunk5
#: ../../reference_manual/tools/contiguous_select.rst:76
msgid "All layers"
msgstr "全レイヤー"

#. +> trunk5
