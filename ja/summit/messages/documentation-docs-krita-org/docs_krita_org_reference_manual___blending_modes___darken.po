#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:195
msgid "Shade"
msgstr "色調"

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:199
msgid "Shade (IFS Illusions)"
msgstr "色調 (IFS Illusions)"

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:203
msgid "This blending mode is called \"Shade (IFS Illusions)\" in English."
msgstr ""

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:205
msgid ""
"Basically, the blending mode only ends in shades of shades. This means that "
"it's very useful for painting shading colors while still in the range of "
"shades."
msgstr ""
"基本的に、この合成モードは影の影にしかなりません。つまり影の範囲の中に影色を"
"塗っていくのにとても便利です。"

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:211
msgid ""
