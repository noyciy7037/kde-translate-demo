#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:133
#: ../../reference_manual/blending_modes/darken.rst:137
msgid "Gamma Dark"
msgstr "ガンマダーク"

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:141
msgid "This blending mode is called \"Gamma Dark\" in English."
msgstr ""

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:143
msgid ""
"Divides 1 by the upper layer, and calculates the end result using that as "
"the power of the lower layer."
msgstr ""
"1を上のレイヤーで割り算し、それを下のレイヤーの指数として結果を計算します。"

#. +> trunk5
#: ../../reference_manual/blending_modes/darken.rst:145
msgid ""
"Darker Gray(0.4, 0.4, 0.4)^[1 / Lighter Gray(0.5, 0.5, 0.5)] = Even Darker "
"Gray(0.1600, 0.1600, 0.1600)"
msgstr ""
"暗いグレー(0.4, 0.4, 0.4)^[1 / 明るいグレー(0.5, 0.5, 0.5)] = より暗いグレー"
"(0.1600, 0.1600, 0.1600)"

