#. +> trunk5
#: ../../reference_manual/blending_modes/arithmetic.rst:125
msgid "Multiply"
msgstr "乗算"

#. +> trunk5
#: ../../reference_manual/blending_modes/arithmetic.rst:129
msgid "This blending mode is called \"Multiply\" in English."
msgstr ""

#. +> trunk5
#: ../../reference_manual/blending_modes/arithmetic.rst:131
msgid "Multiplies the two colors with each other, but does not go beyond the upper limit."
msgstr "二つの色を掛け算しますが、上限を超えることはありません。"

#. +> trunk5
#: ../../reference_manual/blending_modes/arithmetic.rst:133
msgid ""
"This is often used to color in a black and white lineart. One puts the black and white lineart on top, sets the layer to 'Multiply', and then draws in color on a layer beneath. Multiply will allow "
"all the color to go through."
msgstr "白と黒の線画に色を付ける時にしばしば使われます。一番上に置いた白黒線画のレイヤーを'乗算'に設定し、下のレイヤーに色を塗っていきます。乗算はすべての色を通過させることができます。"

#. +> trunk5
#: ../../reference_manual/blending_modes/arithmetic.rst:136
msgid "White(1,1,1) x White(1, 1, 1) = White(1, 1, 1)"
msgstr "白(1,1,1) x 白(1, 1, 1) = 白(1, 1, 1)"

#. +> trunk5
