#. +> trunk6 stable6
#, kde-format
msgctxt "EMAIL OF TRANSLATORS"
msgid "Your emails"
msgstr ""

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:138
#, kde-format
msgid ""
"This type of file can harm your computer. If you want to keep it, accept "
"this download from the browser window."
msgstr ""
"この種類のファイルはコンピュータに害を与える恐れがあります。続行する場合は、"
"ブラウザのウィンドウからダウンロードを承諾してください。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:235
#, kde-format
msgid "Access denied."
msgstr "アクセスが拒否されました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:236
#, kde-format
msgid "Insufficient free space."
msgstr "空き容量が不足しています。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:237
#, kde-format
msgid "The file name you have chosen is too long."
msgstr "指定したファイル名が長すぎます。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:238
#, kde-format
msgid "The file is too large to be downloaded."
msgstr "ファイルが大きすぎてダウンロードできません。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:240
#, kde-format
msgid "The file possibly contains malicious contents."
msgstr "ファイルに悪意のあるコンテンツが含まれている可能性があります。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:241
#, kde-format
msgid "A temporary error has occurred. Please try again later."
msgstr "一時的なエラーが発生しました。しばらくたってからやり直してください。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:243
#, kde-format
msgid "A network error has occurred."
msgstr "ネットワークエラーが発生しました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:244
#, kde-format
msgid "The network operation timed out."
msgstr "ネットワーク操作がタイムアウトしました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:245
#, kde-format
msgid "The network connection has been lost."
msgstr "ネットワーク接続が失われました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:246
#, kde-format
msgid "The server is no longer reachable."
msgstr "サーバに到達できなくなりました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:248
#, kde-format
msgid "A server error has occurred."
msgstr "サーバエラーが発生しました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:252
#, kde-format
msgid "The server does not have the requested data."
msgstr "要求されたデータがサーバ上にありません。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:254
#, kde-format
msgid "The browser application closed unexpectedly."
msgstr "ブラウザアプリケーションが異常終了しました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:260
#, kde-format
msgid "An unknown error occurred while downloading."
msgstr "ダウンロード中に不明なエラーが発生しました。"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:298
#, kde-format
msgctxt "Job heading, like 'Copying'"
msgid "Downloading"
msgstr "ダウンロード中"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:299
#, kde-format
msgctxt "The URL being downloaded"
msgid "Source"
msgstr "ダウンロード元"

#. +> trunk6 stable6 stable5
#: downloadjob.cpp:300
#, kde-format
msgctxt "The location being downloaded to"
msgid "Destination"
msgstr "保存先"

#. +> trunk6 stable6 stable5
#: historyrunnerplugin.cpp:108
#, kde-format
msgctxt "Dummy search result"
msgid "Additional permissions are required"
msgstr "追加の承認が必要です"

