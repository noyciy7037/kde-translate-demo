#. +> trunk6 stable6
#: src/messagepart.cpp:438
#, fuzzy, kde-format
#| msgctxt "display name for an unnamed attachment"
#| msgid "Unnamed"
msgctxt "display name for an unnamed attachment"
msgid "Unnamed"
msgstr "名前なし"

#. +> trunk6 stable6
#: src/messagepart.cpp:704 src/messagepart.cpp:749 src/messagepart.cpp:988
#, kde-format
msgid "Wrong Crypto Plug-In."
msgstr "暗号化プラグインが不正です。"

#. +> trunk6 stable6
#: src/messagepart.cpp:815 src/messagepart.cpp:1207
#, kde-format
msgid "No appropriate crypto plug-in was found."
msgstr "適切な暗号化プラグインが見つかりません。"

#. +> trunk6 stable6
#: src/messagepart.cpp:817
#, kde-format
msgctxt "%1 is either 'OpenPGP' or 'S/MIME'"
msgid "No %1 plug-in was found."
msgstr "%1 プラグインが見つかりません。"

#. +> trunk6 stable6
#: src/messagepart.cpp:820
#, kde-format
msgid "Crypto plug-in \"%1\" cannot verify signatures."
msgstr "暗号化プラグイン “%1” は署名を検証できません。"

#. +> trunk6 stable6
#: src/messagepart.cpp:823
#, kde-format
msgid ""
"The message is signed, but the validity of the signature cannot be verified."
"<br />Reason: %1"
msgstr ""
"<qt>このメッセージは署名されていますが、署名の有効性は検証できませんでした。"
"<br />理由: %1</qt>"

#. +> trunk6 stable6
#: src/messagepart.cpp:1209
#, kde-format
msgid "Crypto plug-in \"%1\" cannot decrypt messages."
msgstr "暗号化プラグイン “%1” はメッセージを復号できません。"

#. +> trunk6 stable6
#: src/messagepart.cpp:1211
#, kde-format
msgid "Crypto plug-in \"%1\" could not decrypt the data."
msgstr "暗号化プラグイン “%1” はデータを復号できませんでした。"

#. +> trunk6 stable6
#: src/messagepart.cpp:1212
#, kde-format
msgid "Error: %1"
msgstr "エラー: %1"

