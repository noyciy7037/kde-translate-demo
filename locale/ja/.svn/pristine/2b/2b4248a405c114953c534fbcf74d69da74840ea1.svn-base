#. +> trunk6 stable6
#: app/ark_dndextract.json.cmake
msgctxt "Name"
msgid "Ark Extract Here"
msgstr "Ark で展開"

#. +> trunk6 stable6
#: app/compressfileitemaction.json
msgctxt "Name"
msgid "'Compress' service menu"
msgstr "'圧縮' サービスメニュー"

#. +> trunk6 stable6
#: app/extractfileitemaction.json
msgctxt "Name"
msgid "'Extract' service menu"
msgstr "'展開' サービスメニュー"

#. +> trunk6 stable6
#: part/ark_part.json.cmake
msgctxt "Name"
msgid "Archiver"
msgstr "アーカイバ"

#. +> trunk6 stable6
#: part/ark_part.json.cmake
msgctxt "Description"
msgid "Archive Handling Tool"
msgstr "アーカイブ処理ツール"

#. +> trunk6 stable6
#: plugins/cli7zplugin/kerfuffle_cli7z.json.cmake
msgctxt "Name"
msgid "7z plugin"
msgstr "7z プラグイン"

#. +> trunk6 stable6
#: plugins/cli7zplugin/kerfuffle_cli7z.json.cmake
msgctxt "Description"
msgid "Full support for the zip and 7z archive formats"
msgstr "zip および 7z アーカイブ形式のフルサポート"

#. +> trunk6 stable6
#: plugins/cliarjplugin/kerfuffle_cliarj.json.cmake
msgctxt "Name"
msgid "ARJ plugin"
msgstr "ARJ プラグイン"

#. +> trunk6 stable6
#: plugins/cliarjplugin/kerfuffle_cliarj.json.cmake
msgctxt "Description"
msgid "Full support for the ARJ archive formats"
msgstr "ARJ アーカイブ形式のフルサポート"

#. +> trunk6 stable6
#: plugins/clirarplugin/kerfuffle_clirar.json.cmake
msgctxt "Name"
msgid "RAR plugin"
msgstr "RAR プラグイン"

#. +> trunk6 stable6
#: plugins/clirarplugin/kerfuffle_clirar.json.cmake
msgctxt "Description"
msgid "Full support for the RAR archive format"
msgstr "RAR アーカイブ形式のフルサポート"

#. +> trunk6 stable6
#: plugins/cliunarchiverplugin/kerfuffle_cliunarchiver.json.cmake
msgctxt "Name"
msgid "The Unarchiver plugin"
msgstr "Unarchiver プラグイン"

#. +> trunk6 stable6
#: plugins/cliunarchiverplugin/kerfuffle_cliunarchiver.json.cmake
msgctxt "Description"
msgid "Open and extract RAR and LHA archives"
msgstr "RAR および LHA アーカイブの閲覧と展開"

#. +> trunk6 stable6
#: plugins/clizipplugin/kerfuffle_clizip.json.cmake
msgctxt "Name"
msgid "Info-zip plugin"
msgstr "Info-zip プラグイン"

#. +> trunk6 stable6
#: plugins/clizipplugin/kerfuffle_clizip.json.cmake
msgctxt "Description"
msgid "Legacy support for the zip archive format"
msgstr "zip アーカイブ形式のレガシーサポート"

#. +> trunk6 stable6
#: plugins/libarchive/kerfuffle_libarchive.json.cmake
msgctxt "Name"
msgid "Libarchive plugin"
msgstr "Libarchive プラグイン"

#. +> trunk6 stable6
#: plugins/libarchive/kerfuffle_libarchive.json.cmake
msgctxt "Description"
msgid "Full support for compressed TAR archives"
msgstr "圧縮された TAR アーカイブのフルサポート"

#. +> trunk6 stable6
#: plugins/libarchive/kerfuffle_libarchive_readonly.json.cmake
msgctxt "Name"
msgid "Libarchive plugin (read-only formats)"
msgstr "Libarchive プラグイン (読み取り専用形式)"

