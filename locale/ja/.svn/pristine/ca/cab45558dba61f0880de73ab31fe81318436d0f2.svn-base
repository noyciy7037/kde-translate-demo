msgid "Toolbar:"
msgstr "ツールバー:"

#. +> trunk6 stable6 stable5
#: ui/main.qml:204
#, kde-format
msgid "Select toolbar font"
msgstr "ツールバーフォントを選択"

#. +> trunk6 stable6 stable5
