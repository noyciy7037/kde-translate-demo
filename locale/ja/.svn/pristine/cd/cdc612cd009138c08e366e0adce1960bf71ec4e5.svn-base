#. +> trunk6 stable6
#: interpreter/executer.cpp:804
#, kde-format
msgid "'Or' needs two variables"
msgstr "or には 2 つの変数が必要です"

#. +> trunk6 stable6
#: interpreter/executer.cpp:815
#, kde-format
