#: interpreter/executer.cpp:1275
#, kde-format
msgid "Can't do a sqrt of a negative number"
msgstr ""

#. +> trunk6 stable6
#: interpreter/parser.cpp:38
#, kde-format
msgid "Expected a command, instead got '%1'"
msgstr "コマンドが必要なところに %1 がありました"

#. +> trunk6 stable6
#: interpreter/parser.cpp:69
#, kde-format
msgid "Could not understand '%1'"
msgstr "%1 を理解できませんでした"

#. +> trunk6 stable6
#: interpreter/parser.cpp:104
#, kde-format
msgid "A comma was expected here..."
msgstr "ここにはコンマが必要です..."

#. +> trunk6 stable6
#: interpreter/parser.cpp:107
#, kde-format
msgid "Did not expect '%1', instead expected the line to end after %2"
msgstr ""

#. +> trunk6 stable6
#: interpreter/parser.cpp:110
#, kde-format
msgid "Expected an assignment, '=', after the variable '%1'"
msgstr "変数 %1 の後に = が必要です"

#. +> trunk6 stable6
#: interpreter/parser.cpp:113
#, kde-format
msgid "Did not expect '%1', instead expected a closing parenthesis, ')'"
msgstr "右括弧 “)” が必要なところに “%1” がありました"

#. +> trunk6 stable6
#: interpreter/parser.cpp:116
#, kde-format
msgid "Expected 'to' after 'for'"
msgstr "for の後には to が必要です"

#. +> trunk6 stable6
#: interpreter/parser.cpp:119
#, kde-format
msgid "Expected a name for a command after 'learn' command"
msgstr "learn コマンドの後にはコマンドの名前が必要です"

#. +> trunk6 stable6
#: interpreter/parser.cpp:273
#, kde-format
msgid "You cannot put '%1' here."
msgstr "ここに %1 を入れることはできません。"

#. +> trunk6 stable6
#: interpreter/parser.cpp:308
#, kde-format
msgid ""
"Text string was not properly closed, expected a double quote, ' \" ', to "
"close the string."
msgstr ""
"文字列が正しく閉じられていません。文字列は二重引用符 (\") で囲まなければなり"
"ません。"

#. +> trunk6 stable6
#: interpreter/parser.cpp:635
#, kde-format
msgid "'for' was called wrongly"
msgstr "for の使い方が間違っています"

#. +> trunk6 stable6
#: interpreter/parser.cpp:706
#, kde-format
msgid "Expected a scope after the 'learn' command"
msgstr "learn コマンドの後にはスコープが必要です"

