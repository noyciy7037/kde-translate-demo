#, fuzzy, kde-format
#| msgid ""
#| "*.png *.jpg *.jpeg *.gif *.htm *.html|Web File\n"
#| "*.png *.jpg *.jpeg *.gif *.bmp *.xbm *.xpm *.pnm *.mng|Images\n"
#| "*.htm *.html|HTML Files\n"
#| "*.png|PNG Images\n"
#| "*.jpg *.jpeg|JPEG Images\n"
#| "*.gif|GIF-Images\n"
#| "*|All Files"
msgid ""
"Web File (*.png *.jpg *.jpeg *.gif *.htm *.html);;Images (*.png *.jpg *.jpeg "
"*.gif *.bmp *.xbm *.xpm *.pnm *.mng);;HTML Files (*.htm *.html);;All Files "
"(*)"
msgstr ""
"*.png *.jpg *.jpeg *.gif *.htm *.html|ウェブファイル\n"
"*.png *.jpg *.jpeg *.gif *.bmp *.xbm *.xpm *.pnm *.mng|イメージ\n"
"*.htm *.html|HTML ファイル\n"
"*.png|PNG イメージ\n"
"*.jpg *.jpeg|JPEG イメージ\n"
"*.gif|GIF イメージ\n"
"*|すべてのファイル"

