#. +> trunk5
#: ../../user_manual/indi.rst:3
msgid "Chapter 9. Astronomical Device Control with INDI"
msgstr ""

#. +> trunk5
#: ../../user_manual/indi.rst:5
msgid ""
"KStars provides an interface to configure and control astronomical "
"instruments via the :ref:`INDI <indi-faq-what-is-indi>` protocol."
msgstr ""

#. +> trunk5
#: ../../user_manual/indi.rst:9
msgid ""
"The INDI protocol supports a variety of astronomical instruments such as CCD "
"cameras and focusers. For an up to date list of supported devices, please "
"visit INDI `supported devices page <https://indilib.org/index.php?"
"title=Devices>`__."
msgstr ""
