msgctxt "Tool Tip"
msgid "Binary comparison of each file. (Default)"
msgstr "それぞれのファイルをバイナリ比較します。(標準)"

#. +> trunk6 stable6
#: optiondialog.cpp:1211
#, kde-format
msgid "Full analysis"
msgstr "完全分析"

#. +> trunk6 stable6
#: optiondialog.cpp:1213
#, fuzzy, kde-format
#| msgid ""
#| "Do a full analysis and show statistics information in extra columns.\n"
