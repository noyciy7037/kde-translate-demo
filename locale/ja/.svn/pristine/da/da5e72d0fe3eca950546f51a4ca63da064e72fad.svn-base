msgid "File Encoding for A:"
msgstr "A のファイルのエンコーディング:"

#. +> trunk6
#: optiondialog.cpp:1325
#, fuzzy, kde-format
#| msgid ""
#| "If enabled then Unicode (UTF-16 or UTF-8) encoding will be detected.\n"
