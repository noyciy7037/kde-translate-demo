msgstr "中心地から地域をあてる(&R)"

#. +> trunk6 stable6
#: kgeography.cpp:67
#, kde-format
msgid "In this quiz you have to guess the division name given its capital"
msgstr "このクイズでは、行政の中心地からその地域をあてます"

# Button
#. +> trunk6 stable6
#: kgeography.cpp:68
#, kde-format
