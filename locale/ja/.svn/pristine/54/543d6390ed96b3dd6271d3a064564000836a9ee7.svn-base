# 未登録: 自治体 (リヒテンシュタイン)、行政区 (サンマリノ)
# Question: %1=capital name
#. +> trunk6 stable6
#: map.cpp:22
#, kde-format
msgctxt "@title:group"
msgid "%1 is the capital of..."
msgstr ""
"%1を行政の中心地とするのは？|/|$[~case $[~get ~regionType] \n"
"   国     $[~spacerR $[~getForm %1 ~city]]を首都とするのは？ \n"
"   州     $[~spacerR $[~getForm %1 ~city]]を州都とするのは？ \n"
"   県     $[~spacerR $[~getForm %1 ~city]]を県庁所在地とするのは？ \n"
"   都道府県     $[~getForm %1 ~city]を都道府県庁所在地とするのは？ \n"
"   省     $[~spacerR $[~getForm %1 ~city]]を省都とするのは？ \n"
"   郡     $[~spacerR $[~getForm %1 ~city]]を行政の中心地とするのは？ \n"
"   地方自治体     $[~spacerR $[~getForm %1 ~city]]を行政の中心地とするの"
"は？ \n"
"   地区     $[~spacerR $[~getForm %1 ~city]]を行政の中心地とするのは？ \n"
"   教区     $[~spacerR $[~getForm %1 ~city]]を中心地とするのは？ \n"
"   地方     $[~spacerR $[~getForm %1 ~city]]を行政の中心地とするのは？ \n"
"   地域     $[~spacerR $[~getForm %1 ~city]]を行政の中心地とするのは？ \n"
"        $[~spacerR $[~getForm %1 ~city]]を行政の中心地とするのは？ \n"
"]"

# 未登録: 自治体 (リヒテンシュタイン)、行政区 (サンマリノ)
# Question: %1=region name
#. +> trunk6 stable6
#: map.cpp:23
#, kde-format
msgctxt "@title:group"
msgid "The capital of %1 is..."
msgstr ""
"%1の行政の中心地は？|/|$[~case \n"
"   $[~first $[~getProp %1 ~regionType] $[~get ~regionType]] \n"
"   国     $[~spacerR $[~getForm %1 ~region]]の首都は？ \n"
"   州     $[~spacerR $[~getForm %1 ~region]]の州都は？ \n"
"   県     $[~spacerR $[~getForm %1 ~region]]の県庁所在地は？ \n"
"   都道府県     $[~getForm %1 ~region]の県庁所在地は？ \n"
"   都     $[~getForm %1 ~region]の都庁所在地は？ \n"
"   道     $[~getForm %1 ~region]の道庁所在地は？ \n"
"   府     $[~getForm %1 ~region]の府庁所在地は？ \n"
"   省     $[~spacerR $[~getForm %1 ~region]]の省都は？ \n"
"   郡     $[~spacerR $[~getForm %1 ~region]]の行政の中心地は？ \n"
"   地方自治体     $[~spacerR $[~getForm %1 ~region]]の行政の中心地は？ \n"
"   地区     $[~spacerR $[~getForm %1 ~region]]の行政の中心地は？ \n"
"   教区     $[~spacerR $[~getForm %1 ~region]]の中心地は？ \n"
"   共和国     $[~spacerR $[~getForm %1 ~region]]の首都は？ \n"
"   自治区     $[~spacerR $[~getForm %1 ~region]]の区都は？ \n"
"   地方     $[~spacerR $[~getForm %1 ~region]]の行政の中心地は？ \n"
"   地域     $[~spacerR $[~getForm %1 ~region]]の行政の中心地は？ \n"
"        $[~spacerR $[~getForm %1 ~region]]の行政の中心地は？ \n"
"]"

