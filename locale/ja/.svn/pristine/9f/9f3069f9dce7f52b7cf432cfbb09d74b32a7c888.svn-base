#. +> trunk6 stable6
#: kcm/kcm_screenlocker.json
msgctxt "X-KDE-Keywords"
msgid ""
"lock,resume,screensaver,screenlock,locking,block,blocking,password,sleep,close "
"lid,lock automatically,screen lock appearance,screen lock theme,screen lock "
"wallpaper,lockscreen,lock screen"
msgstr ""
"lock,resume,screensaver,screenlock,locking,block,blocking,password,sleep,close "
"lid,lock automatically,screen lock appearance,screen lock theme,screen lock "
"wallpaper,lockscreen,lock screen ロック,再開,スクリーンセーバー,画面ロック,ス"
"クリーンロック,パスワード,スリープ,蓋,ふた,カバー,自動ロック,外観,テーマ,壁"
"紙,ロックスクリーン,ロック画面"

#. +> stable5
#: kcm/kcm_screenlocker.json
