#, kde-format
msgid ""
"<html><head/><body><p>If the shutdown script terminates INDI server, enable "
"this option so that no disconnection errors are generated.</p></body></html>"
msgstr ""

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_ShutdownScriptTerminatesINDI)
#. +> trunk5
#: ekos/scheduler/opsscriptssettings.ui:51
#, kde-format
msgid "Shutdown script terminates INDI"
msgstr ""

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_SchedulerWeather)
#. +> trunk5
#: ekos/scheduler/opsweathersettings.ui:43
#, kde-format
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Enable Weather-Based "
"Scheduling:</span> Prevents new jobs from starting during weather warnings "
"or alerts. Existing jobs continue during warnings, but are aborted during "
"alerts. System initiates a soft shutdown and waits for improved conditions "
"or grace period expiration, after which the current job is terminated.</p></"
"body></html>"
msgstr ""

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_SchedulerWeather)
#. +> trunk5
#: ekos/scheduler/opsweathersettings.ui:46
#, fuzzy, kde-format
#| msgid "Constellations"
msgid "Weather grace period"
msgstr "星座"

