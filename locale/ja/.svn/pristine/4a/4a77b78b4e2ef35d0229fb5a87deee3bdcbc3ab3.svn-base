#. +> trunk5
#: ekos/focus/opsfocusmechanics.ui:210
#, kde-format
msgid ""
"<html><head/><body><p>The maximum single step size the algorithm is allowed "
"to command as it searches for the critical focus zone. The calculated step "
"size would be limited to this maximum value.</p></body></html>"
msgstr ""

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusAFOverscan)
#. +> trunk5
#: ekos/focus/opsfocusmechanics.ui:232
#, kde-format
msgid ""
"<html><head/><body><p>Provides backlash overscan in ticks for outward "
"focuser movements during an Autofocus run. This is in addition to any Driver "
"Backlash provided by the device driver and set in the Driver Backlash field. "
"Set to 0 to disable. </p><p>If set, AF Overscan is applied to all focuser "
"movements initiated by the Focus module.</p><p>Typically either Focuser "
"Backlash or AF Overscan is set.</p></body></html>"
msgstr ""

