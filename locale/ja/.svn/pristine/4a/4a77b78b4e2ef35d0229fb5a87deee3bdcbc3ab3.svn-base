#. i18n: ectx: property (toolTip), widget (QComboBox, kcfg_DECGuidePulseAlgorithm)
#. +> trunk5
#: ekos/guide/opsguide.ui:119
#, kde-format
msgid ""
"<html><head/><body><p>Select the guide pulse algorithms for DEC.</p><ul "
"style=\"margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: "
"0px; -qt-list-indent: 1;\"><li style=\" margin-top:12px; margin-bottom:0px; "
"margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"
"\"><span style=\" font-weight:600;\">Standard</span>: The traditional "
"proportional guide algorithm. It computes a pulse to correct the computed "
"guide drift. The aggressiveness parameter decides what proportion of the "
"error is corrected. Errors smaller than MinError won't be corrected. Max "
"response limits the largest correction. The hysteresis parameter is not used."
"</li><li style=\" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0; text-indent:0px;\"><span style=\" font-"
"weight:600;\">Hysteresis</span>: Hysteresis is like the standard algorithm "
"but weights in the previous correction according to the hysteresis "
"parameter. Integral gain does not apply.</li><li style=\" margin-top:0px; "
"margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; "
"text-indent:0px;\"><span style=\" font-weight:600;\">Linear</span>: This is "
"similar to the PHD2 Lowpass2 algorithm. It computes the error pulses based "
"on a short history of recent errors. This may be applicable to very stable "
"mounts. Hysteresis and Integral gain do not apply.</li></ul></body></html>"
msgstr ""

#. i18n: ectx: property (toolTip), widget (QLabel, l_12)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_RAIntegralGain)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_DECIntegralGain)
#. +> trunk5
#: ekos/guide/opsguide.ui:150 ekos/guide/opsguide.ui:254
#: ekos/guide/opsguide.ui:283
#, kde-format
msgid ""
"<html><head/><body><p>This adds a correction term based on the average of "
"the past 50 guide deviations. For example, if the deviation is consistently "
"negative, this will attempt to compensate. Best to start with 0.0 (no "
"effect) and only use this if necessary. (Only applies to the standard "
"algorithm.)</p></body></html>"
msgstr ""

#. i18n: ectx: property (text), widget (QLabel, l_12)
#. +> trunk5
#: ekos/guide/opsguide.ui:153
#, fuzzy, kde-format
#| msgctxt "Region/state in Russia"
#| msgid "Central Region"
msgid "Integral gain (deprecated)"
msgstr "中央連邦管区"

#. i18n: ectx: property (toolTip), widget (QLabel, l_11)
#. +> trunk5
#: ekos/guide/opsguide.ui:176
#, kde-format
msgid ""
"<html><head/><body><p>How aggressively the guider attempts to correct the "
"guide deviations. 1.0 would attempt to fully correct the error. It's best to "
"use an aggressiveness less than 1.0 to avoid oscillations.</p></body></html>"
msgstr ""

#. i18n: ectx: property (text), widget (QLabel, l_11)
#. +> trunk5
#: ekos/guide/opsguide.ui:179
#, kde-format
msgid "Aggressiveness (0-1.0)"
msgstr ""

#. i18n: ectx: property (toolTip), widget (QLabel, l_14)
#. +> trunk5
#: ekos/guide/opsguide.ui:228
#, kde-format
msgid ""
"<html><head/><body><p>Maximum guide pulse that is generated by the guider "
"and sent to the mount in arc-second units. That is, the guider will not "
"attempt to move the mount more than this many arc-seconds at any given time."
"</p></body></html>"
msgstr ""

#. i18n: ectx: property (text), widget (QLabel, l_14)
#. +> trunk5
#: ekos/guide/opsguide.ui:231
#, kde-format
msgid "Max response (arcsec)"
msgstr ""

#. i18n: ectx: property (toolTip), widget (QLabel, l_15)
#. +> trunk5
#: ekos/guide/opsguide.ui:270
#, kde-format
msgid ""
"<html><head/><body><p>Minimum guide deviation, in arc-seconds, for which a "
"guide pulse would be sent to the mount. If the guide error is less than this "
"value, then no pulse is sent to the mount.</p></body></html>"
msgstr ""

#. i18n: ectx: property (text), widget (QLabel, l_15)
#. +> trunk5
#: ekos/guide/opsguide.ui:273
#, fuzzy, kde-format
#| msgctxt "angular size in arcseconds"
#| msgid "1 arcsec"
#| msgid_plural "%1 arcsec"
msgid "Min error (arcsec)"
msgstr "1 arcsec"

