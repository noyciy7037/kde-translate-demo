#: tools/scriptbuilder.cpp:634
#, kde-format
msgid "Skymap Options"
msgstr "天球図オプション"

#. +> trunk5
#: tools/scriptbuilder.cpp:635
#, kde-format
msgid "Use Horizontal coordinates? (otherwise, use Equatorial)"
msgstr "地平座標を使いますか？(しない場合は赤道座標)"

#. +> trunk5
#: tools/scriptbuilder.cpp:638
#, kde-format
msgid "Set the Zoom Factor"
msgstr "ズームの倍率を設定"

#. +> trunk5
#: tools/scriptbuilder.cpp:641
#, kde-format
msgid "Select angular size for the FOV symbol (in arcmin)"
msgstr "FOV 記号の角度を選択 (分角)"

#. +> trunk5
#: tools/scriptbuilder.cpp:644
#, kde-format
msgid ""
"Select shape for the FOV symbol (0=Square, 1=Circle, 2=Crosshairs, "
"4=Bullseye)"
msgstr "FOV 記号の形状を選択 (0=円, 1=正方形, 2=十字線, 4=多重円)"

#. +> trunk5
#: tools/scriptbuilder.cpp:645
#, kde-format
msgid "int"
msgstr "整数"

#. +> trunk5
#: tools/scriptbuilder.cpp:648
#, kde-format
msgid "Select color for the FOV symbol"
msgstr "FOV 記号の色を選択"

#. +> trunk5
#: tools/scriptbuilder.cpp:648
#, kde-format
msgid "string"
msgstr "文字列型"

#. +> trunk5
#: tools/scriptbuilder.cpp:651
#, kde-format
msgid "Use animated slewing? (otherwise, \"snap\" to new focus)"
msgstr ""
"旋回をアニメーション表示しますか？(しない場合は新しい場所に「素早く」フォーカ"
"ス)"

#. +> trunk5
#: tools/scriptbuilder.cpp:654
#, kde-format
msgid "Correct for atmospheric refraction?"
msgstr "大気差補正を使いますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:657
#, kde-format
msgid "Automatically attach name label to centered object?"
msgstr "中央に置かれている天体に自動的に名前ラベルを付けますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:660
#, kde-format
msgid "Attach temporary name label when hovering mouse over an object?"
msgstr "天体の上でマウスを停止したときに、一時的な名前ラベルを付けますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:667
#, kde-format
msgid "Planet trails fade to sky color? (otherwise color is constant)"
msgstr "惑星の光跡を背景色に減衰させますか？(しない場合は色は一様)"

