#: tools/scriptbuilder.cpp:599 tools/scriptbuilder.cpp:638
#: tools/scriptbuilder.cpp:641 tools/scriptbuilder.cpp:706
#: tools/scriptbuilder.cpp:709 tools/scriptbuilder.cpp:712
#: tools/scriptbuilder.cpp:716 tools/scriptbuilder.cpp:720
#, kde-format
msgid "double"
msgstr "実数型"

#. +> trunk5
#: tools/scriptbuilder.cpp:602
#, kde-format
msgid "Hide faint stars while slewing?"
msgstr "旋回している間は、暗い星を隠しますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:605
#, kde-format
msgid "Hide solar system bodies while slewing?"
msgstr "旋回している間は、太陽系の天体を隠しますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:608
#, kde-format
msgid "Hide Milky Way while slewing?"
msgstr "旋回している間は、天の川を隠しますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:611
#, kde-format
msgid "Hide constellation names while slewing?"
msgstr "旋回している間は、星座名を隠しますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:614
#, kde-format
msgid "Hide constellation lines while slewing?"
msgstr "旋回している間は、星座線を隠しますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:617
#, kde-format
msgid "Hide constellation boundaries while slewing?"
msgstr "旋回している間は、星座の境界線を隠しますか？"

#. +> trunk5
#: tools/scriptbuilder.cpp:620
#, kde-format
