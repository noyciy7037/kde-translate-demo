#. i18n: ectx: label, entry (ImagingPlannerShowPicked), group (ImagingPlanner)
#. +> trunk5
#: kstars.kcfg:1018
#, kde-format
msgid ""
"Show the objects that are marked picked (don't show those that are not "
"picked)."
msgstr ""

#. i18n: ectx: label, entry (ImagingPlannerShowNotPicked), group (ImagingPlanner)
#. +> trunk5
#: kstars.kcfg:1022
#, kde-format
msgid ""
"Show the objects that are not marked picked (don't show those that are "
"picked)."
msgstr ""

#. i18n: ectx: label, entry (ImagingPlannerDontCarePicked), group (ImagingPlanner)
#. +> trunk5
#: kstars.kcfg:1026
#, kde-format
msgid ""
"Object display doesn't depend on whether objects are marked picked or not."
msgstr ""

