#. +> trunk5
#: ekos/scheduler/scheduler.ui:1326
#, fuzzy, kde-format
#| msgid "Select all major bodies"
msgid "Repeat all jobs"
msgstr "すべての天体をチェック"

#. i18n: ectx: property (toolTip), widget (QSpinBox, executionSequenceLimit)
#. +> trunk5
#: ekos/scheduler/scheduler.ui:1333
#, fuzzy, kde-format
#| msgid ""
#| "<html><head></head><body><p>This wizard will help you set up some basic "
