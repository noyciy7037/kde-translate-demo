#. i18n: ectx: property (toolTip), widget (AlignmentPlot, targetPlot)
#. +> trunk5
#: ekos/align/pushtoassistant.ui:47
#, kde-format
msgid ""
"<html><head/><body><p><span style=\" font-weight:600;\">Description</span></"
"p><p>This assistant gives users of manual mounts (dobsons etc.) support "
"finding their targets using a finder scope equipped with a camera.</"
"p><p><span style=\" font-weight:600;\">Preparation</span></p><p>Open EKOS, "
"create a profile with the camera of your choice, the Telescope Simulator as "
"mount and add your finder scope as new telescope.</p><p><span style=\" font-"
"weight:600;\">Usage</span></p><ul style=\"margin-top: 0px; margin-bottom: "
"0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;\"><li style=\" "
"margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-"
"block-indent:0; text-indent:0px;\">Start EKOS</li><li style=\" margin-"
"top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-"
"indent:0; text-indent:0px;\">Position your mount as close as possible to "
"your target</li><li style=\" margin-top:0px; margin-bottom:0px; margin-"
"left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;\">Select "
"your target in the target finder and press the &quot;Select target&quot; "
"button</li><li style=\" margin-top:0px; margin-bottom:0px; margin-left:0px; "
"margin-right:0px; -qt-block-indent:0; text-indent:0px;\">Press the "
"&quot;Solve position&quot; button. This captures a frame through your finder "
"scope and solves the image against the star catalogs of KStars.</li><li "
"style=\" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0; text-indent:0px;\">As soon as plate solving "
"succeeds, the distance to the target is displayed. Arrows show the "
"directions how to correct your mount position.</li><li style=\" margin-"
"top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-"
"indent:0; text-indent:0px;\">Move your mount in the indicated position and "
"repeat solving.</li></ul><p><span style=\" font-weight:600;\">Hints</span></"
"p><ul style=\"margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-"
"right: 0px; -qt-list-indent: 1;\"><li style=\" margin-top:12px; margin-"
"bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-"
"indent:0px;\">If you press the &quot;Repeat&quot; button, capturing and "
"plate solving will be repeated after the configured delay.</li><li style=\" "
"margin-top:0px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-"
"block-indent:0; text-indent:0px;\">If plate solving fails, check if the "
"focal length of your finder scope is correctly configured and your telescope "
"is roughly pointing to the target that you have selected.</li></ul></body></"
"html>"
msgstr ""

