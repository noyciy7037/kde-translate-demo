msgstr "旋回している間、天体を隠すかどうか"

#. +> trunk5
#: tools/scriptbuilder.cpp:599
#, kde-format
msgid "Timestep threshold (in seconds) for hiding objects"
msgstr "天体を隠すタイムステップのしきい値 (秒)"

