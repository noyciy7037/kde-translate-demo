#: notifier/DiscoverNotifier.cpp:344
#, kde-format
msgid "New version: %1"
msgstr "新しいバージョン : %1"

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:365
#, kde-format
msgid "Security updates available"
msgstr "セキュリティの更新が利用可能です"

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:367
#, kde-format
msgid "Updates available"
msgstr "更新が利用可能です"

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:369
#, kde-format
msgid "System up to date"
msgstr "システムは最新です"

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:371
#, kde-format
msgid "Computer needs to restart"
msgstr "コンピュータを再起動する必要があります。"

