#: notifier/DiscoverNotifier.cpp:373
#, kde-format
msgid "Offline"
msgstr "オフライン"

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:375
#, kde-format
msgid "Applying unattended updates…"
msgstr "自動更新を適用中..."

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:400
#, kde-format
msgid "Restart is required"
msgstr "再起動が必要です。"

#. +> trunk6 stable6 stable5
#: notifier/DiscoverNotifier.cpp:401
#, kde-format
msgid "The system needs to be restarted for the updates to take effect."
msgstr "アップデートを有効にするには、システムを再起動する必要があります。"

#. +> trunk6 stable6
#: notifier/DiscoverNotifier.cpp:406
#, kde-format
