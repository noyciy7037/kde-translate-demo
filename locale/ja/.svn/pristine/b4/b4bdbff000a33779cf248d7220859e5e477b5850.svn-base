#: plugins/dockers/recorder/recorderdocker_dock.cpp:247
#, kde-format
msgctxt "Use original resolution for the frames when recording the canvas"
msgid "Original"
msgstr "オリジナル"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:248
#, kde-format
msgctxt ""
"Use the resolution two times smaller than the original resolution for the "
"frames when recording the canvas"
msgid "Half"
msgstr "1/2"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:249
#, kde-format
msgctxt ""
"Use the resolution four times smaller than the original resolution for the "
"frames when recording the canvas"
msgid "Quarter"
msgstr "1/4"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:274
#, kde-format
msgctxt "Stop recording the canvas"
msgid "Stop"
msgstr "停止"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:275
#, kde-format
msgctxt "Start recording the canvas"
msgid "Record"
msgstr "録画"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:323
#, kde-format
msgctxt "Recording symbol"
msgid "REC"
msgstr "REC"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:326
#, kde-format
msgid "Active recording with %1 of %2 available threads"
msgstr "録画中: 利用可能な %2 スレッドのうち %1 を使用中"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:326
#, kde-format
msgid "Recorder is paused"
msgstr "レコーダー停止中"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:350
#, kde-format
msgid ""
"Set the number of recording threads.\n"
"The number of threads exceeds the ideal max number of your hardware setup.\n"
"Please be aware, that a number greater than %1 probably won't give you any "
"performance boost."
msgstr ""
"録画スレッドの数を設定します。\n"
"スレッド数は、ハードウェアの最大数を超えます。\n"
"%1 より大きな数値は、パフォーマンス向上にはつながらないことに注意してくださ"
"い。"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:361
#, fuzzy, kde-format
#| msgid ""
#| "Set the number of recording threads.\n"
#| "Accordingly to your hardware setup you should record with no more than %1 "
#| "threads.\n"
#| "You can play around with one or two more threads, but keep an eye on your "
#| "overall system performance."
msgid ""
"Set the number of recording threads.\n"
"According to your hardware setup you should record with no more than %1 "
"threads.\n"
"You can play around with one or two more threads, but keep an eye on your "
"overall system performance."
msgstr ""
"録画スレッドの数を設定します。\n"
"ハードウェアの設定に応じて、%1 スレッドを超えて録画するべきではありません。\n"
"もう 1 つまたはもう 2 つスレッドを追加して試してみることもできますが、システ"
"ム全体のパフォーマンスに注意してください。"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:366
#, kde-format
msgid "Set the number of threads to be used for recording."
msgstr "録画に使用するスレッド数を設定します。"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:392
#, kde-format
msgctxt "Title of the docker"
msgid "Recorder"
msgstr "レコーダー"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:471
#, kde-format
msgid "Your system is not efficient enough for this feature"
msgstr "システムの性能がこの機能には十分ではありません"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:627
#, kde-format
msgid "Select a Directory for Recordings"
msgstr "録画ディレクトリを選択"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:748
#: plugins/dockers/recorder/recorderdocker_dock.cpp:754
#, kde-format
msgctxt "@title:window"
msgid "Recorder"
msgstr "レコーダー"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:749
#, kde-format
msgid ""
"The recorder has been stopped due to failure while writing a frame. Please "
"check free disk space and start the recorder again."
msgstr ""
"フレームの書き込み中にエラーが発生したため、レコーダーが停止しました。ディス"
"クの空き容量を確認して、レコーダーを再起動してください。"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:755
#, kde-format
msgid ""
"Krita was unable to stop the recorder probably. Please try to restart Krita."
msgstr ""
"Krita がレコーダーを停止できませんでした。Krita を再起動してみてください。"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:760
#, kde-format
msgid ""
"Low performance warning. The recorder is not able to write all the frames in "
"time during Real Time Capture mode.\n"
"Try to reduce the frame rate for the ffmpeg export or reduce the scaling "
"filtering in the canvas acceleration settings."
msgstr ""
"低パフォーマンス警告。リアルタイムキャプチャモード中に、レコーダーがすべての"
"フレームを時間内に書き込むことができません。\n"
"ffmpeg エクスポートのフレームレートを減らすか、キャンバスのアクセラレーション"
"設定でスケーリングフィルタを減らしてみてください。"

#. +> trunk6 stable6
#: plugins/dockers/recorder/recorderdocker_dock.cpp:762
#, kde-format
msgid ""
"Low performance warning. The recorder is not able to write all the frames in "
"time.\n"
"Try to increase the capture interval or reduce the scaling filtering in the "
"canvas acceleration settings."
msgstr ""
"低パフォーマンス警告。レコーダーがすべてのフレームを時間内に書き込むことがで"
"きません。\n"
"キャプチャ間隔を増やすか、キャンバスのアクセラレーション設定でスケーリング"
"フィルタを減らしてみてください。"

