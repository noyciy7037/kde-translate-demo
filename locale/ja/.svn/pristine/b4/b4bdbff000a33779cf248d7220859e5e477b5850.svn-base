#: libs/ui/dialogs/kis_dlg_hlg_import.ui:44
#, kde-format
msgid ""
"<html><head/><body><p>Display gamma. By default this is 1.2 for converting "
"from scene to display linear.</p></body></html>"
msgstr ""
"<html><head/><body><p>ガンマ値。デフォルトでは、シーンリニアからディスプレイ"
"リニアへの変換には 1.2 が使用されます。</p></body></html>"

