#~ msgctxt "(qtundo-format)"
#~ msgid ""
#~ "<html>\n"
#~ "<p><b>Note:</b> this is the same thing as the \"incremental\" option in "
#~ "the Krita 1.6 freehand tool options.</p></html>"
#~ msgstr ""
#~ "<html>\n"
