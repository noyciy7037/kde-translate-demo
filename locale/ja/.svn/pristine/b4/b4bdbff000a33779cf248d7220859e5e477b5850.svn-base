#. i18n: ectx: property (toolTip), widget (QCheckBox, chkZip64)
#. +> trunk6 stable6
#: libs/ui/forms/wdggeneralsettings.ui:187
#, kde-format
msgid ""
"<html><head/><body><p>Only use this option for <span style=\" font-"
"weight:600;\">very</span> large files: larger than 4 GiB on disk.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p><span style=\" font-weight:600;\">とても</span> 大きい"
"ファイルサイズの場合のみ使用するオプション : 4GB 以上のディスク領域</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkZip64)
#. +> trunk6 stable6
#: libs/ui/forms/wdggeneralsettings.ui:190
#, kde-format
msgid ""
"Use Zip64 (for very large files: cannot be opened in versions of Krita older "
"than 4.2.0)"
msgstr ""
"Zip64 を使用する (大容量ファイルの場合: 4.2.0 以前のバージョンの Krita では開"
"けません)"

#. i18n: ectx: property (text), widget (QCheckBox, m_chkCompressKra)
#. +> trunk6 stable6
#: libs/ui/forms/wdggeneralsettings.ui:197
#, kde-format
msgid "Compress .kra files more (slows loading/saving)"
msgstr ".kra ファイルの圧縮率を高める (読み込み・保存が遅くなります)"

#. i18n: ectx: property (text), widget (QCheckBox, m_chkTrimKra)
#. +> trunk6 stable6
#: libs/ui/forms/wdggeneralsettings.ui:207
#, kde-format
