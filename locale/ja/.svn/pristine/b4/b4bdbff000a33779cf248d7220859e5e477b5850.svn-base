#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:332
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "VCD & AHD"
msgstr "VCD & AHD"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:333
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "LMMSE"
msgstr "LMMSE"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:335
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "AMaZE"
msgstr "AMaZE"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:352
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Quality (interpolation)</title><p>Select here the demosaicing method "
"to use when decoding RAW images. A demosaicing algorithm is a digital image "
"process used to interpolate a complete image from the partial raw data "
"received from the color-filtered image sensor, internal to many digital "
"cameras, in form of a matrix of colored pixels. Also known as CFA "
"interpolation or color reconstruction, another common spelling is "
"demosaicing. The following methods are available for demosaicing RAW images:"
"</p><p><ul><li><emphasis strong='true'>Bilinear</emphasis>: use high-speed "
"but low-quality bilinear interpolation (default - for slow computers). In "
"this method, the red value of a non-red pixel is computed as the average of "
"the adjacent red pixels, and similarly for blue and green.</li><li><emphasis "
"strong='true'>VNG</emphasis>: use Variable Number of Gradients "
"interpolation. This method computes gradients near the pixel of interest and "
"uses the lower gradients (representing smoother and more similar parts of "
"the image) to make an estimate.</li><li><emphasis strong='true'>PPG</"
"emphasis>: use Patterned-Pixel-Grouping interpolation. Pixel Grouping uses "
"assumptions about natural scenery in making estimates. It has fewer color "
"artifacts on natural images than the Variable Number of Gradients method.</"
"li><li><emphasis strong='true'>AHD</emphasis>: use Adaptive Homogeneity-"
"Directed interpolation. This method selects the direction of interpolation "
"so as to maximize a homogeneity metric, thus typically minimizing color "
"artifacts.</li><li><emphasis strong='true'>DCB</emphasis>: DCB interpolation "
"from linuxphoto.org project.</li><li><emphasis strong='true'>AHD v2</"
"emphasis>: modified AHD interpolation using Variance of Color Differences "
"method.</li><li><emphasis strong='true'>AFD</emphasis>: Adaptive Filtered "
"Demosaicing interpolation through 5 pass median filter from PerfectRaw "
"project.</li><li><emphasis strong='true'>VCD</emphasis>: Variance of Color "
"Differences interpolation.</li><li><emphasis strong='true'>VCD & AHD</"
"emphasis>: Mixed demosaicing between VCD and AHD.</li><li><emphasis "
"strong='true'>LMMSE</emphasis>: color demosaicing via directional linear "
"minimum mean-square error estimation interpolation from PerfectRaw.</"
"li><li><emphasis strong='true'>AMaZE</emphasis>: Aliasing Minimization "
"interpolation and Zipper Elimination to apply color aberration removal from "
"RawTherapee project.</li></ul></p><p>Note: some methods can be unavailable "
"if RAW decoder have been built without extension packs.</p>"
msgstr ""
"<title>品質 (補間)</title><p>RAW 画像をデコードする際に使用するデモザイク方法"
"をここで選択します。デモザイクアルゴリズムはデジタル画像処理において、カラー"
"フィルタ付きイメージセンサから受信した部分的な生データから完全な画像を補間す"
"るために使用されます。これは多くのデジタルカメラ内部に存在し、カラーピクセル"
"の行列として表されます。CFA 補間や色再構成とも呼ばれ、デモザイクとも呼ばれま"
"す。以下の方法が RAW 画像のデモザイクに使用可能です:</p><p><ul><li><emphasis "
"strong='true'>バイリニア</emphasis>: 高速ですが低品質なバイリニア補間を使用し"
"ます (デフォルト - 低速なコンピュータ用)。この方法では、赤ではないピクセルの"
"赤の値は隣接する赤のピクセルの平均として計算され、青と緑も同様です。</"
"li><li><emphasis strong='true'>VNG</emphasis>: 可変勾配数補間を使用します。こ"
"の方法は、ピクセルの近くの勾配を計算し、対象となるピクセルの近くの勾配 (より"
"滑らかで似た部分の勾配) を使用して推定を行います。</li><li><emphasis "
"strong='true'>PPG</emphasis>: パターンピクセルグループ補間を使用します。ピク"
"セルグループにおいては推定を行う際に自然な風景についての仮定を用います。自然"
"な画像では、可変勾配数法よりも色のアーティファクトが少なくなります。</"
"li><li><emphasis strong='true'>AHD</emphasis>: 適応的均質性指向補間を使用しま"
"す。この方法は、均質性メトリックを最大化するように補間の方向を選択し、通常は"
"色に関するアーティファクトを最小限に抑えます。</li><li><emphasis "
"strong='true'>DCB</emphasis>: linuxphoto.org プロジェクトの DCB 補間。</"
"li><li><emphasis strong='true'>AHD v2</emphasis>: 分散色差法を使用した修正 "
"AHD 補間。</li><li><emphasis strong='true'>AFD</emphasis>: PerfectRaw プロ"
"ジェクトの5パス平均フィルタを使用した適応フィルタデモザイク補間。</"
"li><li><emphasis strong='true'>VCD</emphasis>: 色差の分散補間。</"
"li><li><emphasis strong='true'>VCD & AHD</emphasis>: VCD と AHD の混合デモザ"
"イク。</li><li><emphasis strong='true'>LMMSE</emphasis>: PerfectRaw の方向性"
"線形最小二乗誤差推定補間。</li><li><emphasis strong='true'>AMaZE</emphasis>: "
"RawTherapee プロジェクトのエイリアシング最小化補間とジッパー除去を適用した色"
"収差除去。</li></ul></p><p>注意: 一部のメソッドは、RAW デコーダが拡張パックな"
"しでビルドされている場合に使用できないことがあります。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:421
#, kde-format
msgctxt "@label:slider"
msgid "Pass:"
msgstr "パス:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:422
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Pass</title><p>Set here the passes used by the median filter applied "
"after interpolation to Red-Green and Blue-Green channels.</p><p>This setting "
"is only available for specific Quality options: <emphasis "
"strong='true'>Bilinear</emphasis>, <emphasis strong='true'>VNG</emphasis>, "
"<emphasis strong='true'>PPG</emphasis>, <emphasis strong='true'>AHD</"
"emphasis>, <emphasis strong='true'>DCB</emphasis>, and <emphasis "
"strong='true'>VCD & AHD</emphasis>.</p>"
msgstr ""
"<title>パス</title><p>赤-緑チャンネルと青-緑チャンネルに、補間後に適用される"
"メディアンフィルタで使用されるパスを設定します。</p><p>この設定は、特定の品質"
"オプション: <emphasis strong='true'>Bilinear</emphasis>、<emphasis "
"strong='true'>VNG</emphasis>、<emphasis strong='true'>PPG</emphasis>、"
"<emphasis strong='true'>AHD</emphasis>、<emphasis strong='true'>DCB</"
"emphasis>、および <emphasis strong='true'>VCD & AHD</emphasis> に使用可能で"
"す。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:434
#, kde-format
msgctxt "@option:check"
msgid "Refine interpolation"
msgstr "補間を改良"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:435
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Refine interpolation</title><p>This setting is available only for few "
"Quality options:</p><p><ul><li><emphasis strong='true'>DCB</emphasis>: turn "
"on the enhance interpolated colors filter.</li><li><emphasis "
"strong='true'>VCD & AHD</emphasis>: turn on the enhanced effective color "
"interpolation (EECI) refine to improve sharpness.</li></ul></p>"
msgstr ""
"<title>補間をリファイン</title><p>この設定は、次のいくつかの品質オプションで"
"のみ使用できます。</p><p><ul><li><emphasis strong='true'>DCB</emphasis>: 補間"
"された色フィルタを強化するをオンにします。</li><li><emphasis "
"strong='true'>VCD & AHD</emphasis>: シャープネスを向上させるために、拡張され"
"た効果的な色補間 (EECI) リファインを有効にします。</li></ul></p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:452
#, kde-format
msgctxt "@label"
msgid "Demosaicing"
msgstr "デモザイク"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:460
#, kde-format
msgctxt "@label:listbox"
msgid "Method:"
msgstr "方式:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:462
#, kde-format
msgctxt "@item:inlistbox"
msgid "Default D65"
msgstr "デフォルト D65"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:463
#, kde-format
msgctxt "@item:inlistbox"
msgid "Camera"
msgstr "カメラ"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:464
#, kde-format
msgctxt "@item:inlistbox set while balance automatically"
msgid "Automatic"
msgstr "自動"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:465
#, kde-format
msgctxt "@item:inlistbox set white balance manually"
msgid "Manual"
msgstr "マニュアル"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:467
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>White Balance</title><p>Configure the raw white balance:</"
"p><p><ul><li><emphasis strong='true'>Default D65</emphasis>: Use a standard "
"daylight D65 white balance.</li><li><emphasis strong='true'>Camera</"
"emphasis>: Use the white balance specified by the camera. If not available, "
"reverts to default neutral white balance.</li><li><emphasis "
"strong='true'>Automatic</emphasis>: Calculates an automatic white balance "
"averaging the entire image.</li><li><emphasis strong='true'>Manual</"
"emphasis>: Set a custom temperature and green level values.</li></ul></p>"
msgstr ""
"<title>ホワイトバランス</title><p>未処理のホワイトバランスを設定します。</"
"p><p><ul><li><emphasis strong='true'>デフォルト D65</emphasis>: 標準のデイラ"
"イト D65 ホワイトバランスを使用します。</li><li><emphasis strong='true'>カメ"
"ラ</emphasis>: カメラによって指定されたホワイトバランスを使用します。使用でき"
"ない場合は、デフォルトのニュートラルホワイトバランスに戻します。</"
"li><li><emphasis strong='true'>自動</emphasis>: 画像全体を平均化して自動ホワ"
"イトバランスを計算します。</li><li><emphasis strong='true'>マニュアル</"
"emphasis>: カスタムの温度およびグリーンレベル値を設定します。</li></ul></p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:482
#, kde-format
msgctxt "@label:slider"
msgid "T(K):"
msgstr "T(K):"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:483
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Temperature</title><p>Set here the color temperature in Kelvin.</p>"
msgstr "<title>温度</title><p>色温度をケルビンで設定します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:490
#, kde-format
msgctxt "@label:slider Green component"
msgid "Green:"
msgstr "緑(G):"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:491
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<p>Set here the green component to set magenta color cast removal level.</p>"
msgstr ""
"<p>ここで緑の要素を設定して、マゼンタ色の色キャストの除去レベルを設定します。"
"</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:494
#, kde-format
msgctxt "@label:listbox"
msgid "Highlights:"
msgstr "ハイライト:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:496
#, kde-format
msgctxt "@item:inlistbox"
msgid "Solid white"
msgstr "ソリッドホワイト"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:497
#, kde-format
msgctxt "@item:inlistbox"
msgid "Unclip"
msgstr "クリップ解除"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:498
#, kde-format
msgctxt "@item:inlistbox"
msgid "Blend"
msgstr "ブレンド"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:499
#, kde-format
msgctxt "@item:inlistbox"
msgid "Rebuild"
msgstr "再構築"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:501
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Highlights</title><p>Select here the highlight clipping method:</"
"p><p><ul><li><emphasis strong='true'>Solid white</emphasis>: clip all "
"highlights to solid white</li><li><emphasis strong='true'>Unclip</emphasis>: "
"leave highlights unclipped in various shades of pink</li><li><emphasis "
"strong='true'>Blend</emphasis>:Blend clipped and unclipped values together "
"for a gradual fade to white</li><li><emphasis strong='true'>Rebuild</"
"emphasis>: reconstruct highlights using a level value</li></ul></p>"
msgstr ""
"<title>ハイライト</title><p>ここでは、ハイライトのクリップ方法を選択します。"
"</p><p><ul><li><emphasis strong='true'>ソリッドホワイト</emphasis>: すべての"
"ハイライトをソリッドホワイトにクリップ</li><li><emphasis strong='true'>クリッ"
"プ解除</emphasis>: さまざまな色調のピンクでハイライトをクリップしない</"
"li><li><emphasis strong='true'>ブレンド</emphasis>: クリップした値とクリップ"
"していない値をブレンドして、徐々に白にフェード</li><li><emphasis "
"strong='true'>再構築</emphasis>: レベル値を使用してハイライトを再構築</li></"
"ul></p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:512
#, kde-format
msgctxt "@label:slider Highlight reconstruct level"
msgid "Level:"
msgstr "レベル:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:516
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Level</title><p>Specify the reconstruct highlight level. Low values "
"favor whites and high values favor colors.</p>"
msgstr ""
"<title>レベル</title><p>再構築のハイライトレベルを指定します。低い値は白に、"
"高い値は色を優先します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:520
#, kde-format
msgctxt "@option:check"
msgid "Exposure Correction (E.V)"
msgstr "露出の修正 (E.V)"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:521
#, kde-format
msgctxt "@info:whatsthis"
msgid "<p>Turn on the exposure correction before interpolation.</p>"
msgstr "<p>補間前に露出補正をオンにします。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:524
#, kde-format
msgctxt "@label:slider"
msgid "Linear Shift:"
msgstr "線形シフト:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:529
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Shift</title><p>Linear Shift of exposure correction before "
"interpolation in E.V</p>"
msgstr "<title>シフト</title><p>E.V で補間する前の露出補正を線形シフト</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:532
#, kde-format
msgctxt "@label:slider"
msgid "Highlight:"
msgstr "ハイライト:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:537
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Highlight</title><p>Amount of highlight preservation for exposure "
"correction before interpolation in E.V. Only take effect if Shift Correction "
"is > 1.0 E.V</p>"
msgstr ""
"<title>ハイライト</title><p>E.V. で補間する前の露出補正のための ハイライト保"
"存量。シフト補正が >1.0E.V の場合にのみ有効です。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:541
#, kde-format
msgctxt "@option:check"
msgid "Correct false colors in highlights"
msgstr "ハイライトの疑似色を修正する"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:542
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<p>If enabled, images with overblown channels are processed much more "
"accurately, without 'pink clouds' (and blue highlights under tungsten lamps)."
"</p>"
msgstr ""
"<p>このオプションを有効にすると、冗長なチャンネルの画像は、「ピンクの雲」(お"
"よびタングステンランプ以下の青色のハイライト) なしで、より正確に処理されま"
"す。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:546
#, kde-format
msgctxt "@option:check"
msgid "Auto Brightness"
msgstr "自動明度"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:547
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<p>If disable, use a fixed white level and ignore the image histogram to "
"adjust brightness.</p>"
msgstr ""
"<p>無効にした場合は、修正された白レベルを使用し、画像ヒストグラムを無視して明"
"度を調整します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:550
#, kde-format
msgctxt "@label:slider"
msgid "Brightness:"
msgstr "明度:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:555
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Brightness</title><p>Specify the brightness level of output image. "
"The default value is 1.0 (works in 8-bit mode only).</p>"
msgstr ""
"<title>明度</title><p>出力画像の明度レベルを指定します。デフォルト値は1.0で"
"す (8ビット・モードでのみ動作)。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:565
#, kde-format
msgctxt "@option:check Black point"
msgid "Black:"
msgstr "黒:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:566
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Black point</title><p>Use a specific black point value to decode RAW "
"pictures. If you set this option to off, the Black Point value will be "
"automatically computed.</p>"
msgstr ""
"<title>黒点</title><p>RAW 画像のデコードには、特定の黒点の値を使用します。こ"
"のオプションをオフに設定すると、黒点の値が自動的に計算されます。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:573
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Black point value</title><p>Specify specific black point value of the "
"output image.</p>"
msgstr "<title>黒点の値</title><p>出力画像の 特定の黒点の値を指定します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:576
#, kde-format
msgctxt "@option:check White point"
msgid "White:"
msgstr "白:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:577
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>White point</title><p>Use a specific white point value to decode RAW "
"pictures. If you set this option to off, the White Point value will be "
"automatically computed.</p>"
msgstr ""
"<title>白色点</title><p>RAW 画像のデコードには、特定の白色点の値を使用しま"
"す。このオプションを無効にすると、白色点の値が自動的に計算されます。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:584
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>White point value</title><p>Specify specific white point value of the "
"output image.</p>"
msgstr ""
"<title>白色点の値</title><p>出力画像の 特定の白色点の値を指定します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:623
#, fuzzy, kde-format
#| msgctxt "(qtundo-format) @label"
#| msgid "White Balance"
msgctxt "@label"
msgid "White Balance"
msgstr "ホワイトバランス:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:631
#, kde-format
msgctxt "@label:listbox"
msgid "Noise reduction:"
msgstr "ノイズリダクション:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:633
#, kde-format
msgctxt "@item:inlistbox Noise Reduction"
msgid "None"
msgstr "なし"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:634
#, kde-format
msgctxt "@item:inlistbox Noise Reduction"
msgid "Wavelets"
msgstr "ウェーブレット"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:635
#, kde-format
msgctxt "@item:inlistbox Noise Reduction"
msgid "FBDD"
msgstr "FBDD"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:636
#, kde-format
msgctxt "@item:inlistbox Noise Reduction"
msgid "CFA Line Denoise"
msgstr "CFA 線ノイズ除去"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:637
#, kde-format
msgctxt "@item:inlistbox Noise Reduction"
msgid "Impulse Denoise"
msgstr "Impulse ノイズ除去"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:639
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Noise Reduction</title><p>Select here the noise reduction method to "
"apply during RAW decoding.</p><p><ul><li><emphasis strong='true'>None</"
"emphasis>: no noise reduction.</li><li><emphasis strong='true'>Wavelets</"
"emphasis>: wavelets correction to erase noise while preserving real detail. "
"It's applied after interpolation.</li><li><emphasis strong='true'>FBDD</"
"emphasis>: Fake Before Demosaicing Denoising noise reduction. It's applied "
"before interpolation.</li><li><emphasis strong='true'>CFA Line Denoise</"
"emphasis>: Banding noise suppression. It's applied after interpolation.</"
"li><li><emphasis strong='true'>Impulse Denoise</emphasis>: Impulse noise "
"suppression. It's applied after interpolation.</li></ul></p>"
msgstr ""
"<title>ノイズリダクション</title><p>RAW デコード時に適用するノイズリダクショ"
"ン方法を選択します。</p><p><ul><li><emphasis strong='true'>なし</emphasis>: "
"ノイズリダクションは行われません。</li><li><emphasis strong='true'>ウェーブ"
"レット</emphasis>: ノイズを消去しながら実際の画像細部を保持するウェーブレット"
"補正です。補間後に適用されます。</li><li><emphasis strong='true'>FBDD</"
"emphasis>: Fake Before Demosaicing Denoising noise reduction (「モザイク除"
"去・ノイズ除去」ノイズリダクション前の模造) です。補間の前に適用されます。</"
"li><li><emphasis strong='true'>CFA 線ノイズ除去</emphasis>: バンディングノイ"
"ズの抑制。補間後に適用されます。</li><li><emphasis strong='true'>Impulse ノイ"
"ズ除去</emphasis>: Impulse ノイズの抑制。補間後に適用されます。</li></ul></p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:665
#, kde-format
msgctxt "@option:check"
msgid "Enable Chromatic Aberration correction"
msgstr "色収差補正を有効化"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:666
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Enable Chromatic Aberration correction</title><p>Enlarge the raw red-"
"green and blue-yellow axis by the given factors (automatic by default).</p>"
msgstr ""
"<title>色収差補正を有効化</title><p>赤-緑と青-黄の生データの軸を 指定した係数"
"だけ拡大します (デフォルトでは自動)。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:671
#, kde-format
msgctxt "@option:check"
msgid "Automatic color axis adjustments"
msgstr "色軸の自動調整"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:672
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Automatic Chromatic Aberration correction</title><p>If this option is "
"turned on, it will try to shift image channels slightly and evaluate "
"Chromatic Aberration change. Note that if you shot blue-red pattern, the "
"method may fail. In this case, disable this option and tune manually color "
"factors.</p>"
msgstr ""
"<title>色収差の自動補正</title><p>このオプションを有効にすると、画像チャンネ"
"ルがわずかにシフトされ、色収差の変化が評価されます。注意:青-赤のパターンを撮"
"影すると、この補正が失敗することがあります。その場合、このオプションを無効に"
"して、色係数を手動で調整します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:679
#, kde-format
msgctxt "@label:slider"
msgid "Red-Green:"
msgstr "赤-緑:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:684
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Red-Green multiplier</title><p>Set here the amount of correction on "
"red-green axis</p>"
msgstr "<title>赤-緑の乗数</title><p>赤-緑軸の補正量を設定します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:687
#, kde-format
msgctxt "@label:slider"
msgid "Blue-Yellow:"
msgstr "青-黄:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:692
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Blue-Yellow multiplier</title><p>Set here the amount of correction on "
"blue-yellow axis</p>"
msgstr "<title>青-黄の乗数</title><p>青-黄軸の補正量を設定します。</p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:712
#, kde-format
msgctxt "@label"
msgid "Corrections"
msgstr "修正"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:720
#, kde-format
msgctxt "@label:listbox"
msgid "Camera Profile:"
msgstr "カメラのプロファイル:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:722
#, kde-format
msgctxt "@item:inlistbox Camera Profile"
msgid "None"
msgstr "ショートカットは存在しません"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:723
#, fuzzy, kde-format
#| msgctxt "(qtundo-format) @item:inlistbox Camera Profile"
#| msgid "Embedded"
msgctxt "@item:inlistbox Camera Profile"
msgid "Embedded"
msgstr "埋め込み"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:724
#, kde-format
msgctxt "@item:inlistbox Camera Profile"
msgid "Custom"
msgstr "カスタム"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:726
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Camera Profile</title><p>Select here the input color space used to "
"decode RAW data.</p><p><ul><li><emphasis strong='true'>None</emphasis>: no "
"input color profile is used during RAW decoding.</li><li><emphasis "
"strong='true'>Embedded</emphasis>: use embedded color profile from RAW file, "
"if it exists.</li><li><emphasis strong='true'>Custom</emphasis>: use a "
"custom input color space profile.</li></ul></p>"
msgstr ""
"<title>カメラのプロファイル</title><p>RAW データのデコードに 使用する入力色空"
"間を選択します。</p><p><ul><li> <emphasis strong='true'>なし</emphasis>: RAW "
"デコード中に入力色プロファイルは使用されません。</li><li> <emphasis "
"strong='true'>埋め込み</emphasis>: RAW ファイルが存在する場合に埋め込み色プロ"
"ファイルを使用します。</li><li> <emphasis strong='true'>カスタム</emphasis>: "
"カスタム入力色空間プロファイルを使用します。</li></ul></p>"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:737
#, kde-format
msgid "ICC Files (*.icc; *.icm)"
msgstr "ICC ファイル (*.icc; *.icm)"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:739
#, kde-format
msgctxt "@label:listbox"
msgid "Workspace:"
msgstr "ワークスペース:"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:741
#, kde-format
msgctxt "@item:inlistbox Workspace"
msgid "Raw (no profile)"
msgstr "生 (プロファイルなし)"

#. +> trunk6 stable6
