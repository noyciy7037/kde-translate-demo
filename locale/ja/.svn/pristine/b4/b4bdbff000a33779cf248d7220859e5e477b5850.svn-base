msgid "VNG"
msgstr "VNG"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:324
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "PPG"
msgstr "PPG"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:325
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "AHD"
msgstr "AHD"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:328
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "DCB"
msgstr "DCB"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:329
#, kde-format
msgctxt "@item:inlistbox Quality"
msgid "AHD v2"
msgstr "AHD v2"

#. +> trunk6 stable6
#: plugins/impex/raw/3rdparty/libkdcraw/src/dcrawsettingswidget.cpp:330
#, kde-format
