# assistant は、いわゆる「ウィザード (対話型ユーザインタフェース)」ではなく、画像編集中に画面上に表示し、作画を補助するツールを指しています
#. i18n: ectx: property (text), widget (QLabel, lblAssistantsDrawMode)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:176
#, kde-format
msgid "Assistants Mode:"
msgstr "補助モード:"

#. i18n: ectx: property (toolTip), widget (QComboBox, cmbAssistantsDrawMode)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:193
#, kde-format
msgid ""
"<html><head/><body><p>Can be used to troubleshoot performance or artifacting "
"problems with drawing assistants.\n"
"              </p><p>Changing the pixmap cache size requires a restart.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>描画補助のパフォーマンスやアーティファクトの問題をトラ"
"ブルシュートするために使用できます。\n"
"              </p><p>Pixmap キャッシュサイズを変更するには再起動が必要です。"
"</p></body></html>"

#. i18n: ectx: property (text), item, widget (QComboBox, cmbAssistantsDrawMode)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:200
#, kde-format
msgid "Direct (Recommended)"
msgstr "ダイレクト (推奨)"

#. i18n: ectx: property (text), item, widget (QComboBox, cmbAssistantsDrawMode)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:205
#, kde-format
msgid "Pixmap Cache"
msgstr "Pixmap によるキャッシュ"

#. i18n: ectx: property (text), item, widget (QComboBox, cmbAssistantsDrawMode)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:210
#, kde-format
msgid "Large Pixmap Cache"
msgstr "大きな Pixmap によるキャッシュ"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkUseTextureBuffer)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:224
#, kde-format
msgid ""
"<html><head/><body><p>Use Texture Buffering. This can be faster on some GPU/"
"Driver combinations (like Intel) or broken on some others (like AMD/Radeon)."
"</p></body></html>"
msgstr ""
"<html><head/><body><p>テクスチャバッファリングを使用します。GPU とドライバの"
"組み合わせによっては、速くなったり (Intel など)、壊れてしまったり (AMD/"
"Radeon など) する可能性があります。</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkUseTextureBuffer)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:227
#, kde-format
msgid "Use texture buffer"
msgstr "テクスチャバッファを使用する"

#. i18n: ectx: attribute (title), widget (QWidget, tabHDR)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:261
#, kde-format
msgid "HDR Settings"
msgstr "HDR 設定"

#. i18n: ectx: property (text), widget (QLabel, lblCurrentDisplayFormat)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:267
#, kde-format
msgid "Current Display Format"
msgstr "現在のディスプレイ形式"

#. i18n: ectx: property (text), widget (QLabel, label_7)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdisplaysettings.ui:274
#, kde-format
