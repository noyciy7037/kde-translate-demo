#: plugins/paintops/colorsmudge/KisSmudgeOverlayModeOptionWidget.cpp:36
#, kde-format
msgid "Overlay Mode"
msgstr "オーバーレイモード"

#. +> trunk6 stable6
#: plugins/paintops/colorsmudge/KisSmudgeOverlayModeOptionWidget.cpp:47
#, kde-format
msgid ""
"Paints on the current layer\n"
