msgstr "BBD による Krita スクリプトのスターター"

#. i18n: ectx: property (text), widget (QLabel, label)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:54
#, kde-format
msgid "Name of Script:"
msgstr "スクリプト名:"

#. i18n: ectx: property (toolTip), widget (QLineEdit, e_name_of_script)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:67
#, kde-format
msgid ""
"<html><head/><body><p>Your name for your script. This is used to calculate "
"the name of your package, the name of the class in your package and the "
"associated directory.</p></body></html>"
msgstr ""
"<html><head/><body><p>スクリプト用の名前です。これはパッケージの名前、パッ"
"ケージ内のクラスの名前、および関連ディレクトリを判断するために使用されます。"
"</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_2)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:74
#, kde-format
msgid "Menu Entry for Script"
msgstr "スクリプトのメニュー項目"

#. i18n: ectx: property (toolTip), widget (QLineEdit, e_menu_entry)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:81
#, kde-format
msgid ""
"<html><head/><body><p>What you want to appear in the Tools-&gt; Scripts "
"menu. If you leave this blank a default entry will be created based on the "
"name of the script. </p></body></html>"
msgstr ""
"<html><head/><body><p> Tools-&gt; スクリプトのメニューに表示する内容です。空"
"白のままにすると、スクリプト名に基づいてデフォルトの項目が作成されます。</"
"p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_3)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:92
#, kde-format
msgid "Short Description"
msgstr "簡単な説明"

#. i18n: ectx: property (toolTip), widget (QLineEdit, e_comment)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:99
#, kde-format
msgid ""
"<html><head/><body><p>This will appear in the &quot;comment&quot; entry in "
"the dialog where a user can enable or disable Krita scripts. </p></body></"
"html>"
msgstr ""
"<html><head/><body><p>これはユーザが Krita スクリプトを 有効または無効にでき"
"るダイアログの「comment」項目に表示されます。</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_7)
#. +> trunk6 stable6
#: plugins/python/krita_script_starter/bbdkss.ui:112
#, kde-format
