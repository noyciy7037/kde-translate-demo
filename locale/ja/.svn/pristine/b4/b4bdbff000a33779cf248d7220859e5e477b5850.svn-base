#: plugins/impex/tiff/kis_tiff_import.cc:1146
#: plugins/impex/tiff/kis_tiff_import.cc:1329
#, kde-format
msgctxt "TIFF"
msgid "Subsampled YCbCr TIFF files compressed with JPEG cannot be loaded."
msgstr ""
"JPEG で圧縮された、サブサンプリングされた YCbCr TIFF ファイルは読み込むことが"
"できません。"

