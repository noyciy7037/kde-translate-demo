msgid "Display Mode:"
msgstr "表示:"

#. i18n: ectx: property (text), widget (QLabel, label_5)
#. +> trunk6 stable6
#: libs/ui/forms/wdgproofingoptions.ui:79
#, fuzzy, kde-format
#| msgid "Rendering Intent"
msgid "Rendering Intent:"
msgstr "色空間変換の方法"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkDoChromaticAdaptation)
#. +> trunk6 stable6
#: libs/ui/forms/wdgproofingoptions.ui:96
#, kde-format
msgid ""
"<html><head/><body><p>Enables chromatic adaptation for absolute rendering "
"intent. Effectively this will show how the colors would look if the image "
"was printed on a paper and viewed with the monitor as the only light source. "
"This is standard behaviour for a ICC v4 workflow.</p></body></html>"
msgstr ""

