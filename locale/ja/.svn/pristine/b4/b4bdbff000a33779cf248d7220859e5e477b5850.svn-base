#. i18n: ectx: property (text), widget (QLabel, lblWarning)
#. +> trunk6 stable6
#: libs/ui/forms/wdgdlgfilelayer.ui:87
#, kde-format
msgid ""
"<html><head/><body><p>Warning: Krita uses a relative path to store the "
"location of the file in the .kra. If you move the .kra but not the file, the "
"file layer may be broken.</p></body></html>"
msgstr ""
"<html><head/><body><p>警告: Krita は .kra にファイルの場所を保存するために相"
"対パスを使用します。.kra を移動したがファイルを移動しなかった場合、ファイルレ"
"イヤーが壊れる可能性があります。</p></body></html>"

