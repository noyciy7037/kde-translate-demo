msgstr "現在のブラシプリセットで領域を塗りつぶす"

#. i18n: ectx: property (toolTip), widget (QToolButton, fillLayer)
#. +> trunk6 stable6
#: libs/ui/forms/wdgpaintopsettings.ui:890
#, kde-format
msgid "Fill area with current image"
msgstr "現在の画像で領域を塗りつぶす"

#. i18n: ectx: property (toolTip), widget (QToolButton, fillGradient)
#. +> trunk6 stable6
#: libs/ui/forms/wdgpaintopsettings.ui:909
#, kde-format
msgid "Fill area with gradient"
msgstr "グラデーションで領域を塗りつぶす"

#. i18n: ectx: property (toolTip), widget (QToolButton, fillSolid)
#. +> trunk6 stable6
#: libs/ui/forms/wdgpaintopsettings.ui:928
#, kde-format
msgid "Fill area with background color"
msgstr "背景色で領域を塗りつぶす"

#. i18n: ectx: property (toolTip), widget (QToolButton, eraseScratchPad)
#. +> trunk6 stable6
#: libs/ui/forms/wdgpaintopsettings.ui:947
#, kde-format
msgid "Reset area to white"
msgstr "範囲を白へとリセット"

#. i18n: ectx: property (windowTitle), widget (QWidget, WdgPasteFormat)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:20
#, kde-format
msgid "Multiple Formats Detected"
msgstr "複数のフォーマットを検出"

#. i18n: ectx: property (text), widget (QLabel, label)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:32
#, kde-format
msgid ""
"There are multiple formats for the image you're trying to paste. Which one "
"do you want to use?"
msgstr ""
"貼り付けようとしている画像には複数のフォーマットがあります。どれを使用します"
"か？"

#. i18n: ectx: property (text), widget (QRadioButton, btnDownload)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:66
#, kde-format
msgid "&Download from the remote source"
msgstr "リモート先からダウンロード(&D)"

#. i18n: ectx: property (text), widget (QLabel, label_3)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:79
#, kde-format
msgid "Preserves the original metadata and color profile."
msgstr "元のメタデータとカラープロファイルを保持します。"

#. i18n: ectx: property (text), widget (QRadioButton, btnUseLocal)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:92
#, kde-format
msgid "Use &local file"
msgstr "ローカルファイルを使用(&L)"

#. i18n: ectx: property (text), widget (QLabel, label_5)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:105
#, kde-format
msgid ""
"Depending on the source application, it may not have all of the original's "
"metadata or color profile."
msgstr ""
"コピー元のアプリケーションによっては、元のメタデータやカラープロファイルがす"
"べて含まれていないことがあります。"

#. i18n: ectx: property (text), widget (QRadioButton, btnUseBitmap)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:118
#, kde-format
msgid "Paste the attached &bitmap"
msgstr "添付されたビットマップを貼り付け(&B)"

#. i18n: ectx: property (text), widget (QLabel, label_2)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:131
#, kde-format
msgid ""
"Use the bitmap provided by the source application. You will be asked for its "
"profile."
msgstr ""
"コピー元のアプリケーションが提供するビットマップを使用します。そのプロファイ"
"ルを求められます。"

#. i18n: ectx: property (text), widget (QCheckBox, chkRemember)
#. +> trunk6 stable6
#: libs/ui/forms/wdgPasteFormat.ui:144
#, kde-format
msgid "&Remember"
msgstr "記憶(&R)"

#. i18n: ectx: property (text), widget (QLabel, label_10)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:38
#, kde-format
msgid "Note: Krita will need to be restarted for changes to take effect"
msgstr "ノート: 変更を反映するには、Krita の再起動が必要です"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:55
#, kde-format
msgid "RAM"
msgstr "メモリ容量"

#. i18n: ectx: property (text), widget (QLabel, label_2)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:61
#, kde-format
msgid "Memory available:"
msgstr "利用可能なメモリ:"

#. i18n: ectx: property (text), widget (QLabel, lblTotalMemory)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:74
#, kde-format
msgid "XXX MiB"
msgstr "XXX MiB"

#. i18n: ectx: property (toolTip), widget (QLabel, label)
#. i18n: ectx: property (toolTip), widget (KisDoubleSliderSpinBox, sliderMemoryLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:84
#: libs/ui/forms/wdgperformancesettings.ui:102
#, kde-format
msgid "Krita will not use more memory than this limit."
msgstr "Krita はこの限界以上のメモリを使用できません"

#. i18n: ectx: property (text), widget (QLabel, label)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:87
#, kde-format
msgid "Memory Limit:"
msgstr "メモリの上限:"

#. i18n: ectx: property (suffix), widget (KisIntParseSpinBox, intMemoryLimit)
#. i18n: ectx: property (suffix), widget (KisIntParseSpinBox, intPoolLimit)
#. i18n: ectx: property (suffix), widget (KisIntParseSpinBox, intUndoLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:109
#: libs/ui/forms/wdgperformancesettings.ui:137
#: libs/ui/forms/wdgperformancesettings.ui:171
#, kde-format
msgid " MiB"
msgstr " MiB"

#. i18n: ectx: property (text), widget (QLabel, label_5)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:118
#, kde-format
msgid "Internal Pool:"
msgstr "キャンバス向け内部メモリプール:"

#. i18n: ectx: property (toolTip), widget (QLabel, label_4)
#. i18n: ectx: property (toolTip), widget (KisDoubleSliderSpinBox, sliderUndoLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:146
#: libs/ui/forms/wdgperformancesettings.ui:164
#, kde-format
msgid ""
"When undo information reaches this limit, it will be stored in a temporary "
"file and memory will be freed. Undo will be slower."
msgstr ""
"Undo 情報が上限に達した際には、一時ファイルに保存され、メモリが解放されます。"
"やりなおしは遅くなります。"

#. i18n: ectx: property (text), widget (QLabel, label_4)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:149
#, kde-format
msgid "Swap Undo After:"
msgstr "メモリ上に持つ編集履歴容量:"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_2)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:183
#, kde-format
msgid "Swap File"
msgstr "スワップファイル"

#. i18n: ectx: property (toolTip), widget (QLabel, label_6)
#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, sliderSwapSize)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:189
#: libs/ui/forms/wdgperformancesettings.ui:207
#, kde-format
msgid "The swap file will not be bigger than this limit."
msgstr "スワップファイルは上限以上の容量は持てません"

#. i18n: ectx: property (text), widget (QLabel, label_6)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:192
#, kde-format
msgid "Size Limit:"
msgstr "上限サイズ:"

#. i18n: ectx: property (text), widget (QLabel, label_3)
#. i18n: ectx: property (text), widget (QLabel, label_4)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:223
#: plugins/extensions/resourcemanager/WdgDlgResourceManager.ui:247
#, kde-format
msgid "Location:"
msgstr "場所:"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_4)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:256
#, kde-format
msgid "Multithreading"
msgstr "マルチスレッド"

#. i18n: ectx: property (text), widget (QLabel, label_8)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:262
#, kde-format
msgid "CPU Limit:"
msgstr "CPU の上限:"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, sliderThreadsLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:275
#, kde-format
msgid ""
"<html><head/><body><p>Krita will not use more CPU cores than selected by "
"this limit</p></body></html>"
msgstr ""
"<html><head/><body><p>Krita は、ここで指定された数を超える CPU コアを使用しま"
"せん。</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_9)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:282
#, kde-format
msgid "Frame Rendering Clones Limit"
msgstr "フレームレンダリングの複製制限"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, sliderFrameClonesLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:295
#, no-c-format, kde-format
msgid ""
"<html><head/><body><p>When rendering animation frames (into files or during "
"animation cache regeneration), Krita will make the specified number of "
"copies of your image and will work on them in parallel. Each copy will "
"demand more RAM for its storage (about 20% of the size of you image), so "
"raise this limit only if you have enough RAM installed.</p><p><br/></"
"p><p><span style=\" font-weight:600;\">Recommended value:</span> set Clones "
"Limit to the number of <span style=\" text-decoration: underline;"
"\">physical</span> (non-hyperthreaded) cores your CPU has</p></body></html>"
msgstr ""
"<html><head/><body><p>アニメーションフレームをレンダリングするとき (またはア"
"ニメーションキャッシュの再生成中に)、Krita は指定された数の画像コピーを作成"
"し、それらを並行して処理します。各コピーには格納用のメモリ (画像サイズの約"
"20%) が必要になるため、十分な RAM がインストールされている場合にのみ、この制"
"限値を上げてください。</p><p><br/></p><p><span style=\" font-weight:600;\">推"
"奨値:</span> 複製制限数は CPU に搭載された<span style=\" text-decoration: "
"underline; \"> 物理</span> (ハイパースレッドではない) コアの数</p></body></"
"html>"

#. i18n: ectx: property (text), widget (QLabel, label_11)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:302
#, kde-format
msgid "Frame Rendering Timeout"
msgstr "フレームレンダリングの中断"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, sliderFrameTimeout)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:315
#, kde-format
msgid ""
"<html><head/><body><p>The timeout for rendering one frame. If your animation "
"rendering fails regularly with a timeout, try increasing this value</"
"p><p><br/></p><p><span style=\" font-weight:600;\">Recommended value:</span> "
"30...60 seconds</p></body></html>"
msgstr ""
"<html><head/><body><p>フレームのレンダリングにおけるタイムアウトです。アニ"
"メーションのレンダリングがタイムアウトで頻繁に失敗する場合には、この値を増や"
"してみてください。</p><p><br/></p><p><span style=\" font-weight:600;\">推奨"
"値:</span> 30...60 秒</p></body></html>"

#. i18n: ectx: property (title), widget (QGroupBox, fpsGroup)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:325
#, fuzzy, kde-format
#| msgid "Frame Rate:"
msgid "Frame rate"
msgstr "フレームレート:"

#. i18n: ectx: property (text), widget (QLabel, label_fps)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:331
#, fuzzy, kde-format
#| msgctxt "@label:spinbox"
#| msgid "Frame timing:"
msgid "Frame rate limit:"
msgstr "フレームタイミング:"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, sliderFpsLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:344
#, kde-format
msgid ""
"<html><head/><body><p>Krita will try to limit the number of screen updates "
"per second to the given number. A lower number will decrease visual "
"responsiveness but increase stylus precision on some systems like macOS.<p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Krita は1秒あたりの画面更新回数を、指定された数に制限し"
"ようとします。数値を小さくすると視覚的なレスポンスは低下しますが、macOS など"
"の一部のシステムではスタイラスの精度が向上します。<p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkDetectFps)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:351
#, kde-format
msgid "Detect from screen"
msgstr ""

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_7)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:361
#, kde-format
msgid "Debug options"
msgstr "デバッグオプション"

#. i18n: ectx: property (text), widget (QCheckBox, chkOpenGLFramerateLogging)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:367
#, kde-format
msgid "Debug logging of OpenGL framerate"
msgstr "OpenGL のフレームレートのログ出力をデバッグ"

#. i18n: ectx: property (text), widget (QCheckBox, chkBrushSpeedLogging)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:374
#, kde-format
msgid "Debug logging for brush rendering speed"
msgstr "ブラシのレンダリング速度のログ出力をデバッグ"

#. i18n: ectx: property (text), widget (QCheckBox, chkDisableAVXOptimizations)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:381
#, kde-format
msgid "Disable AVX vector optimizations"
msgstr "AVX ベクターの最適化を無効にする"

#. i18n: ectx: property (text), widget (QCheckBox, chkDisableVectorOptimizations)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:388
#, kde-format
msgid "Disable all vector optimizations"
msgstr "すべてのベクターの最適化を無効にする"

#. i18n: ectx: property (text), widget (QCheckBox, chkProgressReporting)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:395
#, kde-format
msgid "Progress reporting (might affect performance)"
msgstr "進捗レポート (パフォーマンスに影響を与えるかもしれません)"

#. i18n: ectx: property (text), widget (QCheckBox, chkPerformanceLogging)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:402
#, kde-format
msgid "Performance logging"
msgstr "パフォーマンスログ出力"

#. i18n: ectx: property (text), widget (QLabel, label_7)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:415
#, kde-format
msgid ""
"<html><head/><body><p>When performance logging is enabled Krita saves timing "
"information into the <tt>&lt;working_dir&gt;/log</tt> folder. If you "
"experience performance problems and want to help us, enable this option and "
"add the contents of the directory to a bug report.</p></body></html>"
msgstr ""
"<html><head/><body><p>パフォーマンスログが有効な時、Krita は時間情報を "
"<tt>&lt;作業ディレクトリ&gt;/log</tt> フォルダーに保存します (作業ディレクト"
"リとは自動保存が保存されている場所です)。もし何か問題が発生してそのトラブルを"
"我々開発に報告してくださる場合には、このオプションを有効にしてディレクトリの"
"中の文字列をバグ報告に添付してください。</p></body></html>"

#. i18n: ectx: attribute (title), widget (QWidget, tab_3)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:442
#, kde-format
msgid "Animation Cache"
msgstr "アニメーションキャッシュ"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_3)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:448
#, kde-format
msgid "Cache Storage Backend"
msgstr "キャッシュ領域バックエンド"

#. i18n: ectx: property (toolTip), widget (QRadioButton, optInMemory)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:454
#, kde-format
msgid ""
"<html><head/><body><p>Animation frame cache will be stored in RAM completely "
"without any limitations</p><p><span style=\" font-weight:600;\">WARNING:</"
"span> please make sure your computer has enough RAM <span style=\" text-"
"decoration: underline;\">above</span> the amount you requested in General "
"tab. Otherwise you might face system freezes.</p><p>* for 1 second of "
"FullHD@25fps video you need extra 200 MiB of memory</p><p>* for 1 second of "
"4K UltraHD@25fps video you need extra 800 MiB of memory</p></body></html>"
msgstr ""
"<html><head/><body><p>アニメーションフレームキャッシュが制限なしでメモリにす"
"べて保存されます。</p> <p><span style=\" font-weight:600;\">警告:</span> パソ"
"コンに十分なメモリ容量があることを確認してください。<span style=\" text-"
"decoration: underline;\"> 全般タブで要求された量以上です</span>。そうしない"
"と、システムがフリーズする可能性があります。</p> <p>* FullHD@25fps ビデオの1"
"秒で200MiB のメモリが追加で必要です。</p> <p>* 4K UltraHD@25fps ビデオの1秒は"
"800MiB のメモリが追加で必要です。</p> </body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, optInMemory)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:457
#, kde-format
msgid "In-memory"
msgstr "メモリ内"

#. i18n: ectx: property (toolTip), widget (QRadioButton, optOnDisk)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:464
#, kde-format
msgid ""
"<html><head/><body><p>Animation frames are stored on hard disk in the same "
"folder as swap file. The cache is stored in a compressed way. Little amount "
"of extra RAM is needed.</p><p>Since data transfer speed of the hard drive is "
"low, you might want to limit cached frame size to be able to play your video "
"at 25 fps. The limit of 2500 px is usually a good choice.</p></body></html>"
msgstr ""
"<html><head/><body><p>アニメーションフレームはハードディスクのスワップファイ"
"ルとして同じフォルダに保存されます。キャッシュは圧縮して保存されます。追加の"
"メモリ容量はほとんど必要ありません。</p> <p>ハードディスクのデータ転送速度は"
"遅いため、ビデオを 25fps で再生できるように、フレームのキャッシュサイズを制限"
"することをおすすめします。通常は、2500px という制限が適しています。</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, optOnDisk)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:467
#, kde-format
msgid "On-disk"
msgstr "ディスク上"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_5)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:477
#, kde-format
msgid "Cache Generation Options"
msgstr "キャッシュ生成のオプション"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkCachedFramesSizeLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:483
#, kde-format
msgid ""
"<html><head/><body><p>Render scaled down version of the frame if the image "
"is bigger than the provided limit. Make sure you enable this option when "
"using on-disk storage backend.</p></body></html>"
msgstr ""
"<html><head/><body><p>画像が指定された制限より大きい場合に、フレームの縮小"
"バージョンをレンダリングします。on-disk storage backend を使用する場合は、必"
"ずこのオプションを有効にしてください。</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkCachedFramesSizeLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:486
#, kde-format
msgid "Limit cached frame size:"
msgstr "フレームのキャッシュサイズを制限:"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, intCachedFramesSizeLimit)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:499
#, kde-format
msgid ""
"<html><head/><body><p>Size limit after which the frames will be scaled down</"
"p><p><span style=\" font-weight:600;\">Recommended value:</span> "
"2500&nbsp;px</p></body></html>"
msgstr ""
"<html><head/><body><p>フレームが縮小されるサイズの制限値</p> <p><span "
"style=\" font-weight:600;\">推奨値:</span>2500&nbsp;px</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkUseRegionOfInterest)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:506
#, kde-format
msgid ""
"<html><head/><body><p>When the image is too big, render only currently "
"visible part of it</p></body></html>"
msgstr ""
"<html><head/><body><p>画像が大きすぎる場合は、現在表示されている部分のみをレ"
"ンダリングします。</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkUseRegionOfInterest)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:509
#, kde-format
msgid "Use region of interest"
msgstr "関心領域 (ROI) を使用"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, intRegionOfInterestMargin)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:522
#, no-c-format, kde-format
msgid ""
"<html><head/><body><p>Add extra area to the region of interest to each side "
"of the canvas.</p><p><span style=\" font-weight:600;\">Recommended value:</"
"span> 25%. The region of interest will be extended by 25% to each side.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>キャンバスの両端に ROI を追加します。</p><p><span "
"style=\" font-weight:600;\">推奨値:</span>25%。ROI は両側に25%ずつ拡張されま"
"す。</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkBackgroundCacheGeneration)
#. +> trunk6 stable6
#: libs/ui/forms/wdgperformancesettings.ui:529
#, kde-format
msgid ""
"<html><head/><body><p>Automatically prerender animation cache in background "
"when the user is idle</p></body></html>"
msgstr ""
