#. +> trunk6 stable6
#: libs/ui/forms/wdgcolorspaceselector.ui:122
#, kde-format
msgid "Install a new profile from a file."
msgstr "ファイルより新しいプロフィールをインストール"

#. i18n: ectx: property (text), widget (QPushButton, bnAdvanced)
#. +> trunk6 stable6
#: libs/ui/forms/wdgcolorspaceselector.ui:134
#, kde-format
msgid "Color Space Browser"
msgstr "色空間ブラウザ"

#. i18n: ectx: property (text), widget (QLabel, lbl_descriptionwidget)
#. +> trunk6 stable6
#: libs/ui/forms/wdgcolorspaceselectoradvanced.ui:27
#, kde-format
msgid ""
"<html><head/><body><p><a href=\"https://en.wikipedia.org/wiki/"
"Color_space\"><span style=\" font-weight:600; text-decoration: underline; "
"color:#006e28;\">Color Spaces</span></a>  determine how colors are encoded "
"in your files. Different color spaces have different properties and are used "
"for different purposes.</p></body></html>"
msgstr ""
"<html><head/><body><p><a href=\"https://ja.wikipedia.org/wiki/色空間\"><span "
"style=\" font-weight:600; text-decoration: underline; color:#006e28;\">色空間"
"</span></a>は、色がファイルでどのようにエンコードされるかを決定します。色空間"
"が違えばプロパティも異なり、それぞれが異なる目的のために用いられます。</p></"
"body></html>"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox)
#. +> trunk6 stable6
#: libs/ui/forms/wdgcolorspaceselectoradvanced.ui:51
