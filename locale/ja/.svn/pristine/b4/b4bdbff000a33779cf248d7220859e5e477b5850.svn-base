"<p><application>%1</application>: 予期されないモジュールのバージョンフォー"
"マット"

#. +> trunk6 stable6
#: plugins/extensions/pykrita/plugin/PythonPluginManager.cpp:232
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<p><application>%1</application>: No suitable version found. Required "
