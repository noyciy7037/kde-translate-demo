msgid "Filter: %1"
msgstr "フィルタ: %1"

#. i18n: ectx: property (text), widget (QLabel, label)
#. +> trunk6 stable6
#: libs/ui/dialogs/kis_dlg_hlg_import.ui:20
#, kde-format
msgid ""
"<html><head/><body><p>This is an Hybrid Log Gamma image. Krita does not "
"support sending HLG to the monitor, so for import it is recommended to "
"convert from scene linear to display linear.</p></body></html>"
msgstr ""
"<html><head/><body><p>これは Hybrid Log Gamma 画像です。Krita は HLG をモニ"
"ターに送信することをサポートしていません。そのため、インポートする際にはシー"
"ンリニアからディスプレイリニアへの変換を推奨します。</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkApplyOOTF)
#. +> trunk6 stable6
#: libs/ui/dialogs/kis_dlg_hlg_import.ui:30
#, kde-format
msgid "Apply HLG OOTF"
msgstr "HLG OOTF を適用"

