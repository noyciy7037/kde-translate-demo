#: ui/main.qml:108
#, kde-format
msgctxt "@title:group"
msgid "Data to index:"
msgstr "インデックスするデータ:"

#. +> trunk6 stable6
#: ui/main.qml:109
#, kde-format
msgctxt "@option:radio Data to index"
msgid "Nothing (disable indexing entirely)"
msgstr ""

