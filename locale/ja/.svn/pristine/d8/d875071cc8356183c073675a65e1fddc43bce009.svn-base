#. +> trunk6 stable6 stable5
#: colors.cpp:253
#, kde-format
msgid "Unable to create a temporary file."
msgstr "一時ファイルを作成できません。"

#. +> trunk6 stable6 stable5
#: colors.cpp:266
#, kde-format
msgid "Unable to download the color scheme: %1"
msgstr "カラースキームをダウンロードできません: %1"

#. +> trunk6 stable6 stable5
#: colors.cpp:284
#, kde-format
msgid "This file is not a color scheme file."
msgstr "このファイルはカラースキームファイルではありません。"

#. +> trunk6 stable6 stable5
#: colors.cpp:303
#, kde-format
msgid "Failed to create 'color-scheme' data folder."
msgstr "'color-scheme' データフォルダの作成に失敗しました。"

#. +> trunk6 stable6 stable5
#: colors.cpp:310
#, kde-format
msgid "Failed to copy color scheme into 'color-scheme' data folder."
msgstr ""
"カラースキームを 'color-scheme' データフォルダにコピーできませんでした。"

#. +> trunk6 stable6 stable5
#: colors.cpp:327
#, kde-format
msgid "Color scheme installed successfully."
msgstr "カラースキームのインストールに成功しました。"

#. i18n: ectx: label, entry (colorScheme), group (General)
#. +> trunk6 stable6 stable5
#: colorssettings.kcfg:9
#, kde-format
msgid "Color scheme name"
msgstr "カラースキームの名前"

#. i18n: ectx: label, entry (accentColor), group (General)
#. +> trunk6 stable6 stable5
#: colorssettings.kcfg:13
#, kde-format
msgid "Accent color"
msgstr "アクセントカラー"

#. i18n: ectx: label, entry (lastUsedCustomAccentColor), group (General)
#. +> trunk6 stable6 stable5
#: colorssettings.kcfg:17
#, kde-format
msgid ""
"The last used custom accent color before user switched to wallpaper "
"generated color or default color"
msgstr ""
"ユーザが壁紙アクセントカラーもしくはデフォルトの色に切り替える前、最後に使用"
"されたカスタムのアクセントカラー"

#. i18n: ectx: label, entry (accentColorFromWallpaper), group (General)
#. +> trunk6 stable6 stable5
#: colorssettings.kcfg:21
#, kde-format
msgid "Whether accent color from wallpaper should be applied"
msgstr "壁紙から抽出されたアクセントカラーを適用するかどうか"

#. +> trunk6 stable6 stable5
#: editor/kcolorschemeeditor.cpp:23
#, kde-format
msgid "KColorSchemeEditor"
msgstr "KColorSchemeEditor"

#. +> trunk6 stable6 stable5
#: editor/kcolorschemeeditor.cpp:25
#, kde-format
msgid "Utility to edit and create color schemes"
msgstr "カラースキームを編集・作成するユーティリティ"

#. +> trunk6 stable6 stable5
#: editor/kcolorschemeeditor.cpp:27
#, kde-format
msgid "Olivier Churlaud"
msgstr "Olivier Churlaud"

#. +> trunk6 stable6 stable5
#: editor/kcolorschemeeditor.cpp:27
#, kde-format
