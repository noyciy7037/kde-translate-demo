#. +> trunk6 stable6
#: ui/ComponentOverlay.qml:98
#, kde-format
msgctxt "@label %1 is a MIME type and %2 is an application name"
msgid "%1 (Currently opens in %2)"
msgstr "%1 (現在 %2 で開かれるように設定されています)"

#. +> trunk6 stable6
#: ui/ComponentOverlay.qml:111
#, kde-format
