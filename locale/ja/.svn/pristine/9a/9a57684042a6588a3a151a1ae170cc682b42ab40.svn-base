msgstr "すべてを %1 で開く"

#. +> trunk6 stable6
#: ui/ComponentOverlay.qml:130
#, kde-format
msgid ""
"This application does not advertise support for the following file types, "
"but may be able to open them anyway:"
msgstr ""
"このアプリケーションは以下のファイルタイプのサポートを明示していませんが、そ"
"れでも開けるかもしれません:"

#. +> trunk6 stable6
#: ui/ComponentOverlay.qml:147
#, kde-format
msgctxt "@action:button"
msgid "Force All to Open in %1"
msgstr "すべてを強制的に %1 で開く"

