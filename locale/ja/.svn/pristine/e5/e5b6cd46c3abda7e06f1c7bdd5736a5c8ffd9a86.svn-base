#. +> trunk6 stable6
#: desktop/kget_download.desktop:13
msgctxt "Name"
msgid "Download with KGet"
msgstr "KGet でダウンロード"

#. +> trunk6 stable6
#: desktop/org.kde.kget.desktop.cmake:8
msgctxt "Name"
msgid "KGet"
msgstr "KGet"

#. +> trunk6 stable6
#: desktop/org.kde.kget.desktop.cmake:86
msgctxt "GenericName"
msgid "Download Manager"
msgstr "ダウンロードマネージャ"

#. +> trunk6 stable6
#: desktop/org.kde.kget.desktop.cmake:163
msgctxt "Comment"
msgid "KGet is a versatile and user-friendly download manager"
msgstr ""

#. +> trunk6 stable6
#: sounds/kget.notifyrc:4
msgctxt "Comment"
msgid "KGet Download Manager"
msgstr "KGet ダウンロードマネージャ"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:66
msgctxt "Name"
msgid "Transfer Added"
msgstr "ダウンロード追加"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:127
msgctxt "Comment"
msgid "A new download has been added"
msgstr "新しいダウンロードが追加されました"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:197
msgctxt "Name"
msgid "Download Started"
msgstr "ダウンロード開始"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:260
msgctxt "Comment"
msgid "Downloading started"
msgstr "ダウンロードを開始しました"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:332
msgctxt "Name"
msgid "Download Finished"
msgstr "ダウンロード完了"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:395
msgctxt "Comment"
msgid "Downloading finished"
msgstr "ダウンロードが完了しました"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:465
msgctxt "Name"
msgid "All Downloads Finished"
msgstr "全ダウンロード完了"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:527
msgctxt "Comment"
msgid "All downloads finished"
msgstr "すべてのダウンロードが完了しました"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:597
msgctxt "Name"
msgid "Error Occurred"
msgstr "エラー発生"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:655
msgctxt "Comment"
msgid "An Error has Occurred"
msgstr "エラーが発生しました"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:718
msgctxt "Name"
msgid "Information"
msgstr "情報"

#. +> trunk6 stable6
#: sounds/kget.notifyrc:784
msgctxt "Comment"
msgid "User Notified of Information"
msgstr "お知らせする情報があります"

