#: ui/main.qml:48
#, kde-format
msgctxt "button text"
msgid "Configure Titlebar Buttons…"
msgstr "タイトルバーのボタンを設定..."

#. +> trunk6 stable6
#: ui/main.qml:54
#, kde-format
