#. +> trunk6
#: core/dplugins/bqm/convert/converttodng/converttodngplugin.cpp:62
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>This Generic tool can convert RAW images data to DNG format.</para>"
"<para>The Digital Negative is a lossless RAW image format created by Adobe.</para>"
"<para>See details about this format from <link url='https://en.wikipedia.org/wiki/Digital_Negative'>this page</link>.</para>"
msgstr ""

#. +> trunk6
#: core/dplugins/bqm/convert/converttoheif/converttoheifplugin.cpp:42
#, kde-format
msgctxt "@title"
msgid "Convert To HEIF"
msgstr ""

#. +> trunk6
#: core/dplugins/bqm/convert/converttoheif/converttoheifplugin.cpp:57
#, kde-format
msgctxt "@info"
msgid "A tool to convert images to HEIF format"
msgstr ""

#. +> trunk6
#: core/dplugins/bqm/convert/converttoheif/converttoheifplugin.cpp:62
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>This Batch Queue Manager tool can convert images data to HEIF format.</para>"
"<para>High Efficiency Image File Format (HEIF), also known as High Efficiency Image Coding (HEIC), is a file format for individual images and image sequences. It was developed by the Moving Picture Experts Group (MPEG) and it claims that twice as much information can be stored in a HEIF image as in a JPEG image of the same size, resulting in a better quality image. HEIF also supports animation, and is capable of storing more information than an animated GIF at a small fraction of the size.</para>"
"<para>See <link url='https://en.wikipedia.org/wiki/High_Efficiency_Image_File_Format'>High Efficiency Image File Format</link> for details.</para>"
msgstr ""

#. +> trunk6
#: core/dplugins/bqm/convert/converttojp2/converttojp2plugin.cpp:42
#, kde-format
