#: index.docbook:21
#, no-c-format
msgid "The http KIO worker is used by all &kde; applications to handle connections to &HTTP; servers, that is, web servers. The most common usage is to view web pages in the &konqueror; web browser."
msgstr ""

#. Tag: para
#. +> trunk6 trunk5
#: index.docbook:25
#, no-c-format
msgid "You can use the https KIO worker in &konqueror; by giving it a &URL;. <userinput>https://<replaceable>www.kde.org</replaceable></userinput>."
msgstr ""

#. Tag: para
#. +> trunk6 trunk5
#: index.docbook:28
#, no-c-format
msgid "https is http encapsulated in a SSL/TLS stream."
msgstr ""

#. Tag: para
#. +> trunk6 trunk5
#: index.docbook:29
#, no-c-format
msgid "SSL is the Secure Sockets Layer protocol, a security protocol that provides communications privacy over the Internet. The protocol allows client/server applications to communicate in a way that is designed to prevent eavesdropping, tampering, or message forgery."
msgstr ""

#. Tag: para
#. +> trunk6 trunk5
#: index.docbook:32
#, no-c-format
msgid "TLS stands for Transport Layer Security."
msgstr ""
