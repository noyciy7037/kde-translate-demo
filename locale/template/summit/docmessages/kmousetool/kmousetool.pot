msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:119
#, no-c-format
msgid "Minimum movement:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:121
#, no-c-format
msgid "The minimum movement in pixels before &kmousetool; will attempt to click the mouse."
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:127
#, no-c-format
msgid "Dwell time (1/10 sec):"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:130
#, no-c-format
msgid "The time the mouse has to pause before &kmousetool; clicks. Try increasing this time if it is hard getting used to &kmousetool;"
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:136
#, no-c-format
msgid "Smart drag"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:139
#, no-c-format
msgid "Enables or disables Smart Drag. Disabled use is easier, so this is the default."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:140
#, no-c-format
msgid "If you enable <guilabel>Smart drag</guilabel> the <guilabel>Drag time (1/10 sec):</guilabel> field becomes available. This is the time &kmousetool; waits, after it clicks down, before it clicks back up if you don't move the mouse."
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:148
#, no-c-format
msgid "Enable strokes"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:151
#, no-c-format
msgid "&kmousetool; now supports strokes. When you enable strokes, a slow move to the right and back, followed by a pause, will generate a <mousebutton>right</mousebutton> click. A slow move left and back will generate a double click. (Strokes are specified in <filename>$<envar>KDEHOME</envar>/share/config/kmousetool_strokes.txt</filename>. This file is generated by &kmousetool; the first time it is run, but can be modified afterwards.)"
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:162
#, no-c-format
msgid "Audible click"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:165
#, no-c-format
msgid "Plays a sound when &kmousetool; clicks down. This helps, especially with Smart Drag."
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:172
#, no-c-format
msgid "Start with desktop session"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:175
#, no-c-format
msgid "When this is enabled, &kmousetool; will start each time the session of the desktop starts."
msgstr ""

