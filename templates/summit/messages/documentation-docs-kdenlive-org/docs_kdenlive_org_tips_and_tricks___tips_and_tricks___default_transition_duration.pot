#. +> trunk5
#: ../../tips_and_tricks/tips_and_tricks/default_transition_duration.rst:15
msgid "Configuring the Default Transition Duration"
msgstr ""

#. +> trunk5
#: ../../tips_and_tricks/tips_and_tricks/default_transition_duration.rst:17
msgid "You can configure the default duration for all newly created transitions. In versions prior to 16.08, all new transitions were always 65 frames long - and this translated to varying default durations, depending on a project's frame rate. This new configuration option should appeal to all those users who work a lot with transitions."
msgstr ""

#. +> trunk5
#: ../../tips_and_tricks/tips_and_tricks/default_transition_duration.rst:25
msgid ":menuselection:`Menu --> Settings --> Configure Kdenlive`"
msgstr ""

#. +> trunk5
#: ../../tips_and_tricks/tips_and_tricks/default_transition_duration.rst:27
msgid "Go to :menuselection:`Menu --> Settings --> Configure Kdenlive --> Misc`. Under the heading :guilabel:`Default Durations` you will find the option to configure the default duration for newly created transitions. Enter a duration in the usual format :abbr:`hh:mm:ss:ff (hours:minutes:seconds:frames)`."
msgstr ""

#. +> trunk5
#: ../../tips_and_tricks/tips_and_tricks/default_transition_duration.rst:29
msgid "Please note that the frames (**ff**) field element will be interpreted on the basis of the current project's framerate. In contrast, the other field elements (**hh:mm:ss**) are independent of the framerate."
msgstr ""

