#. Tag: title
#. +> trunk6 stable6 stable5
#: importing-exporting.docbook:357
#, no-c-format
msgid "Exporting GCstar"
msgstr ""

#. Tag: para
#. +> trunk6 stable6 stable5
#: importing-exporting.docbook:359
#, no-c-format
msgid "<application><ulink url=\"http://www.gcstar.org\">GCstar</ulink></application> is another movie collection manager. &appname; is able to export most collection types to a GCstar data file."
msgstr ""

#. Tag: title
#. +> trunk6 stable6 stable5
#: importing-exporting.docbook:366
#, no-c-format
msgid "Exporting &XML; via &xslt;"
msgstr ""

#. Tag: para
#. +> trunk6 stable6 stable5
#: importing-exporting.docbook:368
#, no-c-format
msgid "Finally, &appname; is able to process its internal &XML; representation of the collection data through an external &XSL; stylesheet before exporting. This type of export may be useful for generating text reports or other file types."
msgstr ""

#. Tag: title
#. +> trunk6 stable6 stable5
#: importing-exporting.docbook:376
#, no-c-format
msgid "Working With Citations"
msgstr ""

#. Tag: para
#. +> trunk6 stable6 stable5
#: importing-exporting.docbook:377
#, no-c-format
msgid "When working with a <link linkend=\"bibliography\">bibliography</link>, citations for the currently selected entries may be generated and used in various other applications. A citation in bibtex format can be copied to the clipboard, and then pasted in a latex file. Bibtex citations can also be pushed to an external application such as <application>LyX</application> or <application>Kile</application> using the so-called <emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</link></emphasis>."
msgstr ""
