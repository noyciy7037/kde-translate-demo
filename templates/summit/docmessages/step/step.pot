#. Tag: para
#. +> trunk6 stable6
#: index.docbook:53
#, no-c-format
msgid "&step; is an interactive physical simulator."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:55
#, no-c-format
msgid "&step; features:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:59
#, no-c-format
msgid "Classical mechanical simulation in two dimensions"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:61
#, no-c-format
msgid "Particles, springs with damping, gravitational and coulomb forces"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:63
#, no-c-format
msgid "Rigid bodies"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:65
#, no-c-format
msgid "Collision detection (currently only discrete) and handling"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:67
#, no-c-format
msgid "Soft (deformable) bodies simulated as user-editable particles-springs system, sound waves"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:69
#, no-c-format
msgid "Molecular dynamics (currently using Lennard-Jones potential): gas and liquid, condensation and evaporation, calculation of macroscopic quantities and their variances"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:71
#, no-c-format
msgid "Units conversion and expression calculation: you can enter something like <quote>(2 days + 3 hours) * 80 km/h</quote> and it will be accepted as distance value (requires libqalculate)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:73
#, no-c-format
msgid "Errors calculation and propagation: you can enter values like <quote>1.3 Â± 0.2</quote> for any property and errors for all dependent properties will be calculated using statistical formulas"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:75
#, no-c-format
msgid "Solver error estimation: errors introduced by the solver is calculated and added to user-entered errors"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:77
#, no-c-format
msgid "Several different solvers: up to 8th order, explicit and implicit, with or without adaptive timestep (most of the solvers require GSL library)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:79
#, no-c-format
msgid "Controller tool to easily control properties during simulation (even with custom keyboard shortcuts)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:81
#, no-c-format
msgid "Tools to visualize results: graph, meter, tracer"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:83
#, no-c-format
msgid "Context information for all objects, integrated wikipedia browser"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:85
#, no-c-format
msgid "Collection of example experiments, more can be downloaded with &knewstuff;3"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:87
#, no-c-format
msgid "Integrated tutorials"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:93
#, no-c-format
msgid "Using &step;"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:95
#, no-c-format
msgid "&step; simulates a physical world. The main part of &step; (1) is the world scene in the center of &step; main window where you first place physical objects and where you see the simulation. On the left of this scene a palette (2) let you choose your physical objects. You can freely move this palette anywhere on your desktop by dragging the title bar. On the right of the scene you can see the current world description (3), its properties (4), some help to explain some words (5) and the history of the current world (6). Each of those panels can be placed elsewhere on your screen by dragging the title bar."
msgstr ""

