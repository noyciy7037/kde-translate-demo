#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3251
#, no-c-format
msgid "For each share you synchronize, a new subdirectory below this prefix will be generated. If you want to synchronize the contents of a share to a different folder, you can define it in the <link linkend=\"shares_view_synchronization\">synchronization dialog</link>."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3252
#, no-c-format
msgid "Default: <filename class=\"directory\">$HOME/smb4k_sync/</filename>"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3264
#, no-c-format
msgid "Archive mode"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3267
#, no-c-format
msgid "Option: <option>-a</option>/<option>--archive</option>, same as <option>-rlptgoD</option> (no <option>-A</option>, <option>-X</option>, <option>-U</option>, <option>-N</option>, <option>-H</option>)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3268
#, no-c-format
msgid "Switch the archive mode on. This is a quick way of saying you want recursion and want to preserve almost everything. Note that <option>-a</option> does not preserve hardlinks (<option>-H</option>), access control lists (ACLs, <option>-A</option>), extended attributes (xattrs, <option>-X</option>), access (use) times (<option>-U</option>) nor create times (<option>-N</option>). You must separately specify these options. The only exception to the above equivalence is when <option>--files-from</option> is specified, in which case <option>-r</option> is not implied."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3269
#, no-c-format
msgid "In case you do not want to run <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> in archive mode, choose the appropriate arguments in the settings yourself."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3275
#, no-c-format
msgid "Recurse into subdirectories"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3278
#, no-c-format
msgid "Option: <option>-r</option>/<option>--recursive</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3279
#, no-c-format
msgid "Recurse into subdirectories."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3285
#, no-c-format
msgid "Use relative path names"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3288
#, no-c-format
msgid "Option: <option>-R</option>/<option>--relative</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3289
#, no-c-format
msgid "Use relative path names. This means that the full path names specified on the command line are sent to the server rather than just the last parts of the file names."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3295
#, no-c-format
msgid "Do not send implied directories"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3298
#, no-c-format
msgid "Option: <option>--no-implied-dirs</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3299
#, no-c-format
msgid "This option affects the default behavior of the <option>--relative</option> option. When it is specified, the attributes of the implied directories from the source names are not included in the transfer. This means that the corresponding path elements on the destination system are left unchanged if they exist, and any missing implied directories are created with default attributes. This even allows these implied path elements to have big differences, such as being a symlink to a folder on one side of the transfer, and a real folder on the other side."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3300 index.docbook:3386
#, no-c-format
msgid "For further information you ought to read the <ulink url=\"man:/rsync\">manual page</ulink>."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3306
#, no-c-format
msgid "Transfer directories without recursing"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3309
#, no-c-format
msgid "Option: <option>-d</option>/<option>--dirs</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3310
#, no-c-format
msgid "Tell the sending side to include any directories that are encountered. Unlike <option>--recursive</option>, a folders contents is not copied unless the folder name specified is \".\" or ends with a trailing slash (&eg; \".\", \"dir/.\", \"dir/\", &etc;). Without this option or the <option>--recursive</option> option, <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> will skip all directories it encounters (and output a message to that effect for each one). If you specify both <option>--dirs</option> and <option>--recursive</option>, <option>--recursive</option> takes precedence."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3318
#, no-c-format
msgid "Backups"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3322
#, no-c-format
msgid "Make backups"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3325
#, no-c-format
msgid "Option: <option>-b</option>/<option>--backups</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3326
#, no-c-format
msgid "With this option, preexisting destination files are renamed as each file is transferred or deleted. You can control where the backup file goes and what (if any) suffix gets appended using the <option>--backup-dir</option> and <option>--suffix</option> options."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3327
#, no-c-format
msgid "Note that if you don't specify <option>--backup-dir</option>, (1) the <option>--omit-dir-times</option> option will be implied, and (2) if <option>--delete</option> is also in effect (without <option>--delete-excluded</option>), <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> will add a \"protect\" filter-rule for the backup suffix to the end of all your existing excludes (&eg; <option>-f \"P *~\"</option>). This will prevent previously backed-up files from being deleted. Note that if you are supplying your own filter rules, you may need to manually insert your own exclude/protect rule somewhere higher up in the list so that it has a high enough priority to be effective (&eg;, if your rules specify a trailing inclusion/exclusion of '*', the auto-added rule would never be reached)."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3333
#, no-c-format
msgid "Backup suffix"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3336
#, no-c-format
msgid "Option: <option>--suffix=SUFFIX</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3337
#, no-c-format
msgid "This option allows you to override the default backup suffix used with the <option>--backup</option> option. The default suffix is a <emphasis>~</emphasis> if no <option>--backup-dir</option> was specified, otherwise it is an empty string."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3338 index.docbook:3349
#, no-c-format
msgid "This option is only available if you ticked the <guilabel>Make backups</guilabel> option above."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3339
#, no-c-format
msgid "Default: not selected; SUFFIX: ~"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3344
#, no-c-format
msgid "Backup directory"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3347
#, no-c-format
msgid "Option: <option>--backup-dir=DIR</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3348
#, no-c-format
msgid "In combination with the <option>--backup</option> option, this tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to store all backups in the specified folder. This is very useful for incremental backups. You can additionally specify a backup suffix using the <option>--suffix</option> option (otherwise the files backed up in the specified folder will keep their original filenames)."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3350
#, no-c-format
msgid "Default: not selected; DIR: <envar>$HOME</envar>"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3363
#, no-c-format
msgid "File Handling"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3366 index.docbook:3864
#, no-c-format
msgid "General"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3371
#, no-c-format
msgid "Update files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3374
#, no-c-format
msgid "Option: <option>-u</option>/<option>--update</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3375
#, no-c-format
msgid "This forces <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to skip any files that exist on the destination and have a modification time that is newer than the one of the source file. (If an existing destination file has a modification time equal to the source file's, it will be updated if the sizes are different.)"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3381
#, no-c-format
msgid "Update files in place"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3384
#, no-c-format
msgid "Option: <option>--inplace</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3385
#, no-c-format
msgid "This causes <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> not to create a new copy of the file and then move it into place. Instead <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> will overwrite the existing file, meaning that the rsync algorithm cannot accomplish the full amount of network reduction it might be able to otherwise. One exception to this is if you combine the option with <option>--backup</option>, since <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> is smart enough to use the backup file as the basis file for the transfer."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3392
#, no-c-format
msgid "Handle sparse files efficiently"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3395
#, no-c-format
msgid "Option: <option>-S</option>/<option>--sparse</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3396
#, no-c-format
msgid "Try to handle sparse files efficiently so they take up less space on the destination. Conflicts with <option>--inplace</option> because it's not possible to overwrite data in a sparse fashion."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3397
#, no-c-format
msgid "Do not use this option when the destination is a &Solaris; \"tmpfs\" file system. It doesn't seem to handle seeks over null regions correctly and ends up corrupting the files."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3403
#, no-c-format
msgid "Copy files whole (no rsync algorithm)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3406
#, no-c-format
msgid "Option: <option>-W</option>/<option>--whole-file</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3407
#, no-c-format
msgid "With this option the incremental <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> algorithm is not used and the whole file is sent as-is instead. The transfer may be faster if this option is used when the bandwidth between the source and destination machines is higher than the bandwidth to disk (especially when the \"disk\" is actually a networked file system). This is the default when both the source and destination are specified as local paths."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3413
#, no-c-format
msgid "Only update files that already exist"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3416
#, no-c-format
msgid "Option: <option>--existing</option>/<option>--ignore-non-existing</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3417
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to skip updating files that do not exist yet on the destination. If this option is combined with the <option>--ignore-existing</option> option, no files will be updated (which can be useful if all you want to do is to delete missing files)."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3423
#, no-c-format
msgid "Ignore files that already exist"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3426
#, no-c-format
msgid "Option: <option>--ignore-existing</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3427
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to skip updating files that already exist on the destination. See also <option>--ignore-non-existing</option>."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3435
#, no-c-format
msgid "Links"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3440
#, no-c-format
msgid "Preserve symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3443
#, no-c-format
msgid "Option: <option>-l</option>/<option>--links</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3444
#, no-c-format
msgid "Copy symlinks as symlinks."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3450
#, no-c-format
msgid "Transform symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3453
#, no-c-format
msgid "Option: <option>-L</option>/<option>--copy-links</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3454
#, no-c-format
msgid "When symlinks are encountered, the item that they point to is copied, rather than the symlink."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3460
#, no-c-format
msgid "Transform unsafe symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3463
#, no-c-format
msgid "Option: <option>--copy-unsafe-links</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3464
#, no-c-format
msgid "Only transform \"unsafe\" symlinks. This means if a symlink is encountered that is pointing outside the copied tree, the referenced item is transferred rather than the symlink itself."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3470
#, no-c-format
msgid "Ignore unsafe symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3473
#, no-c-format
msgid "Option: <option>--safe-links</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3474
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to ignore any symbolic links which point outside the copied tree. All absolute symlinks are also ignored. Using this option in conjunction with <option>--relative</option> may give unexpected results."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3480
#, no-c-format
msgid "Munge symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3483
#, no-c-format
msgid "Option: <option>--munge-links</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3484
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to (1) modify all symlinks on the receiving side in a way that makes them unusable but recoverable, or (2) to unmunge symlinks on the sending side that had been stored in a munged state. This is useful if you do not quite trust the source of the data to not try to slip in a symlink to an unexpected place. For further information on this argument, please see the manual page of <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink>."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3490
#, no-c-format
msgid "Preserve hard links"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3493
#, no-c-format
msgid "Option: <option>-H</option>/<option>--hard-links</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3494
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to look for hard-linked files in the transfer and link together the corresponding files on the receiving side. Without this option, hard-linked files in the transfer are treated as though they were separate files."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3495
#, no-c-format
msgid "Note that <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> can only detect hard links if both parts of the link are in the list of files being sent."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3501
#, no-c-format
msgid "Copy directory symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3504
#, no-c-format
msgid "Option: <option>-k</option>/<option>--copy-dirlinks</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3505
#, no-c-format
msgid "This option causes the sending side to treat a symlink to a directory as though it were a real directory. This is useful if you dont want symlinks to non-directories to be affected, as they would be using <option>--copy-links</option>."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3511
#, no-c-format
msgid "Keep directory symlinks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3514
#, no-c-format
msgid "Option: <option>-K</option>/<option>--keep-dirlinks</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3515
#, no-c-format
msgid "This option causes the receiving side to treat a symlink to a directory as though it were a real directory, but only if it matches a real directory from the sender. Without this option, the receiver's symlink would be deleted and replaced with a real directory."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3524
#, no-c-format
msgid "File Attributes &amp; Ownership"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3526
#, no-c-format
msgid "File Attributes"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3530
#, no-c-format
msgid "Preserve permissions"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3533
#, no-c-format
msgid "Option: <option>-p</option>/<option>--perms</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3534
#, no-c-format
msgid "This option causes the receiving side to set the destination permissions to be the same as the source permissions."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3540
#, no-c-format
msgid "Preserve access control lists (ACLs)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3543
#, no-c-format
msgid "Option: <option>-A</option>/<option>--acls</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3544
#, no-c-format
msgid "Preserve access control lists. This option causes <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to update the destination ACLs to be the same as the source ACLs. The option also implies --perms. The source and destination systems must have compatible ACL entries for this option to work properly."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3550
#, no-c-format
msgid "Preserve extended attributes"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3553
#, no-c-format
msgid "Option: <option>-X</option>/<option>--xattrs</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3554
#, no-c-format
msgid "Preserve extended attributes. This option causes <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to update the destination extended attributes to be the same as the source ones."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3560
#, no-c-format
msgid "Preserve access times"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3563
#, no-c-format
msgid "Option: <option>-U</option>/<option>--atimes</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3564
#, no-c-format
msgid "Preserve access times. This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to set the access (use) times of the destination files to the same value as the source files."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3570
#, no-c-format
msgid "Preserve create times"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3573
#, no-c-format
msgid "Option: <option>-N</option>/<option>--crtimes</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3574
#, no-c-format
msgid "Preserve create times. This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to set the create times (newness) of the destination files to the same value as the source files."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3580
#, no-c-format
msgid "Preserve device and special files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3583
#, no-c-format
msgid "Option: <option>-D</option>/<option>--devices --specials</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3584
#, no-c-format
msgid "This option causes <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to transfer character and block device files as well as special files (such as named sockets and fifos) to the remote system. This option has no effect if the receiving side is not run as the super user and <option>--super</option> is not specified."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3590
#, no-c-format
msgid "Preserve times"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3593
#, no-c-format
msgid "Option: <option>-t</option>/<option>--times</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3594
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to transfer modification times along with the files and update them on the remote system."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3600
#, no-c-format
msgid "Omit directories when preserving times"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3603
#, no-c-format
msgid "Option: <option>-O</option>/<option>--omit-dir-times</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3604
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to omit directories when it is preserving modification times (see <option>--times</option>)."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3612
#, no-c-format
msgid "Ownership"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3616
#, no-c-format
msgid "Preserve owner"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3619
#, no-c-format
msgid "Option: <option>-o</option>/<option>--owner</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3620
#, no-c-format
msgid "This option causes <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to set the owner of the destination file to be the same as the one of the source file. By default, the preservation is done by name, but may fall back to using the ID number in some circumstances (see the <option>--numeric-ids</option> option for a full discussion). This option has no effect if the receiving <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> is not run as the super user and <option>--super</option> is not specified."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3626
#, no-c-format
msgid "Preserve group"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3629
#, no-c-format
msgid "Option: <option>-g</option>/<option>--group</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3630
#, no-c-format
msgid "This option causes <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to set the group of the destination file to be the same as the on of the source file. If the receiving program is not running as the super-user (or with the <option>--no-super</option> option), only groups that the receiver is a member of will be preserved."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3643
#, no-c-format
msgid "File Transfer"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3645
#, no-c-format
msgid "Compression"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3649
#, no-c-format
msgid "Compress data during transfer"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3652
#, no-c-format
msgid "Option: <option>-z</option>/<option>--compress</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3653
#, no-c-format
msgid "Compress file data during the transfer."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3659
#, no-c-format
msgid "Set compression level"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3662
#, no-c-format
msgid "Option: <option>--compress-level=NUM</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3663
#, no-c-format
msgid "Explicitly set the compression level to use. If NUM is non-zero, the <option>--compress</option> argument is implied."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3664 index.docbook:3848 index.docbook:3991
#, no-c-format
msgid "Default: not selected; NUM: 0"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3669
#, no-c-format
msgid "Skip compression for following file suffixes"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3672
#, no-c-format
msgid "Option: <option>--skip-compress=LIST</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3673
#, no-c-format
msgid "Overwrite the list of file suffixes that will not be compressed. The LIST should be one or more file suffixes (without the dot) separated by slashes. You may specify an empty string to indicate that no file should be skipped. The default list of suffixes will be replaced by this list. For further details, see the <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>manual page of rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink>."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3674
#, no-c-format
msgid "Default: not selected; LIST: empty"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3681
#, no-c-format
msgid "Files"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3685
#, no-c-format
msgid "Do not transfer any file smaller than"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3688
#, no-c-format
msgid "Option: <option>--min-size=SIZE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3689
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to avoid transferring any file that is smaller than the specified SIZE, which can help in not transferring small, junk files."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3690 index.docbook:3700
#, no-c-format
msgid "Default: not selected; SIZE: 0 kB"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3695
#, no-c-format
msgid "Do not transfer any file larger than"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3698
#, no-c-format
msgid "Option: <option>--max-size=SIZE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3699
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to avoid transferring any file that is larger than the specified SIZE."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3705
#, no-c-format
msgid "Keep partially transferred files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3708
#, no-c-format
msgid "Option: <option>--partial</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3709
#, no-c-format
msgid "By default, <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> will delete any partially transferred file if the transfer is interrupted. In some circumstances it is more desirable to keep partially transferred files. Using the <option>--partial</option> option tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to keep the partial file which should make a subsequent transfer of the rest of the file much faster."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3715
#, no-c-format
msgid "Put partially transferred files into"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3718
#, no-c-format
msgid "Option: <option>--partial-dir=DIR</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3719
#, no-c-format
msgid "A better way to keep partial files than the <option>--partial</option> option is to specify a folder DIR that will be used to hold the partial data (instead of writing it out to the destination file). On the next transfer, <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> will use a file found in this folder as data to speed up the resumption of the transfer and then delete it after it has served its purpose. Before you tick this option, you should read the <ulink url=\"man:/rsync\">manual page</ulink>."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3720
#, no-c-format
msgid "Default: not selected; DIR: <filename class=\"directory\">$HOME</filename>"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3727 index.docbook:3968 index.docbook:4008
#, no-c-format
msgid "Miscellaneous"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3731
#, no-c-format
msgid "Set bandwidth limit:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3734
#, no-c-format
msgid "Option: <option>--bwlimit=RATE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3735
#, no-c-format
msgid "Set the maximum data transfer RATE in kilobytes per second."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3736
#, no-c-format
msgid "Default: not selected; RATE: 0 kB/s"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3748
#, no-c-format
msgid "File Deletion"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3751
#, no-c-format
msgid "Files &amp; Directories"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3756
#, no-c-format
msgid "Remove synchronized source files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3759
#, no-c-format
msgid "Option: <option>--remove-source-files</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3760
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to remove from the sending side the files (meaning non-directories) that are a part of the transfer and have been successfully duplicated on the receiving side."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3766
#, no-c-format
msgid "Delete extraneous files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3769
#, no-c-format
msgid "Option: <option>--delete</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3770
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to delete extraneous files from the receiving side (ones that aren't on the sending side), but only for the directories that are being synchronized. You must have asked <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to send the whole folder (&eg; \"<filename class=\"directory\">dir</filename>\" or \"<filename class=\"directory\">dir/</filename>\") without using a wildcard for the folders contents (&eg; \"<filename class=\"directory\">dir/*</filename>\") since the wildcard is expanded by the shell and <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> thus gets a request to transfer individual files, not the files' parent folder. Files that are excluded from transfer are also excluded from being deleted unless you use the <option>--delete-excluded</option> option or mark the rules as only matching on the sending side."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3776
#, no-c-format
msgid "Delete files before transfer"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3779
#, no-c-format
msgid "Option: <option>--delete-before</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3780
#, no-c-format
msgid "Request that the file deletions on the receiving side be done before the transfer starts. This is the default if <option>--delete</option> or <option>--delete-excluded</option> is specified without one of the <option>--delete-WHEN</option> options."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3786
#, no-c-format
msgid "Delete files after transfer"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3789
#, no-c-format
msgid "Option: <option>--delete-after</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3790
#, no-c-format
msgid "Request that the file deletions on the receiving side be done after the transfer has completed."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3796
#, no-c-format
msgid "Delete files during transfer"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3799
#, no-c-format
msgid "Option: <option>--delete-during</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3800
#, no-c-format
msgid "Request that the file deletions on the receiving side be done incrementally as the transfer happens. This is a faster method than choosing the before- or after-transfer algorithm, but it is only supported beginning with <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> version 2.6.4."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3806
#, no-c-format
msgid "Delete excluded files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3809
#, no-c-format
msgid "Option: <option>--delete-excluded</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3810
#, no-c-format
msgid "In addition to deleting the files on the receiving side that are not on the sending side, this tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to also delete any files on the receiving side that are excluded (see <option>--exclude</option>)."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3816
#, no-c-format
msgid "Delete even if I/O errors occur"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3819
#, no-c-format
msgid "Option: <option>--ignore-errors</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3820
#, no-c-format
msgid "Tells <option>--delete</option> to go ahead and delete files even when there are I/O errors."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3826
#, no-c-format
msgid "Force deletion of non-void directories"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3829
#, no-c-format
msgid "Option: <option>--force</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3830
#, no-c-format
msgid "This option tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to delete a non-empty folder when it is to be replaced by a non-folder. This is only relevant if deletions are not active (see <option>--delete</option>)."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3838
#, no-c-format
msgid "Restrictions"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3843
#, no-c-format
msgid "Do not delete more than this many files"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3846
#, no-c-format
msgid "Option: <option>--max-delete=NUM</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3847
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> not to delete more than NUM files or directories (NUM must be non-zero). This is useful when mirroring very large trees to prevent disasters."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3861
#, no-c-format
msgid "Filtering"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3869
#, no-c-format
msgid "Auto-ignore files in the same way CVS does"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3872
#, no-c-format
msgid "Option: <option>-C</option>/<option>--cvs-exclude</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3873
#, no-c-format
msgid "This is a useful shorthand for excluding a broad range of files that you often don't want to transfer between systems. It uses the same algorithm that CVS uses to determine if a file should be ignored."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3879
#, no-c-format
msgid "Exclude files matching this pattern"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3882
#, no-c-format
msgid "Option: <option>--exclude=PATTERN</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3883
#, no-c-format
msgid "This option is a simplified form of the <option>--filter</option> option that defaults to an exclude rule and does not allow the full rule-parsing syntax of normal filter rules."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3884 index.docbook:3904
#, no-c-format
msgid "Default: not selected; PATTERN: empty"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3889
#, no-c-format
msgid "Read exclude patterns from"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3892
#, no-c-format
msgid "Option: <option>--exclude-from=FILE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3893
#, no-c-format
msgid "This option is related to the <option>--exclude</option> option, but it specifies a FILE that contains exclude patterns (one per line). Blank lines in the file and lines starting with ';' or '#' are ignored. You have to choose an existing file to make this option work."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3894
#, no-c-format
msgid "Default: not selected; FILE: <filename>$HOME/exclude.txt</filename>"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3899
#, no-c-format
msgid "Include files matching this pattern"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3902
#, no-c-format
msgid "Option: <option>--include=PATTERN</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3903
#, no-c-format
msgid "This option is a simplified form of the <option>--filter</option> option that defaults to an include rule and does not allow the full rule-parsing syntax of normal filter rules."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3909
#, no-c-format
msgid "Read include patterns from"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3912
#, no-c-format
msgid "Option: <option>--include-from=FILE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3913
#, no-c-format
msgid "This option is related to the <option>--include</option> option, but it specifies a FILE that contains include patterns (one per line). Blank lines in the file and lines starting with ';' or '#' are ignored. You have to choose an existing file to make this option work."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3914
#, no-c-format
msgid "Default: not selected; FILE: <filename>$HOME/include.txt</filename>"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3921
#, no-c-format
msgid "Filter Rules"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3926
#, no-c-format
msgid "Use --filter='dir-merge /.rsync-filter' filter rule"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3929
#, no-c-format
msgid "Option: <option>-F</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3930
#, no-c-format
msgid "This option tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to look for per-folder <filename>.rsync-filter</filename> files that have been sprinkled through the hierarchy and use their rules to filter the files in the transfer."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3931 index.docbook:3942
#, no-c-format
msgid "See the FILTER RULES section of the <ulink url=\"man:/rsync\">manual page</ulink> for detailed information on how this option works."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3937
#, no-c-format
msgid "Use --filter='exclude .rsync-filter' filter rule"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3940
#, no-c-format
msgid "Option: <option>-FF</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3941
#, no-c-format
msgid "This option filters out the <filename>.rsync-filter</filename> files themselves from the transfer."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3948
#, no-c-format
msgid "Custom filter rules"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3951
#, no-c-format
msgid "Option: <option>-f</option>/<option>--filter=RULE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3952
#, no-c-format
msgid "You can define one or more filter rules here. Each rule has to be prefixed with the <option>--filter=</option> or <option>-f</option> option string, because the contents of the text box will be passed to the <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> command AS IS."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3953
#, no-c-format
msgid "This option allows you to add rules to selectively exclude certain files from the list of files to be transferred. This is most useful in combination with a recursive transfer."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3954
#, no-c-format
msgid "You may use as many <option>--filter</option> options as you like to build up the list of files to exclude."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3955
#, no-c-format
msgid "See the FILTER RULES section of the <ulink url=\"man:/rsync\">manual page</ulink> for detailed information on this option."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3956
#, no-c-format
msgid "Default: not selected; RULES: empty"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:3971
#, no-c-format
msgid "Checksums"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3976
#, no-c-format
msgid "Force fixed checksum block size"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3979
#, no-c-format
msgid "Option: <option>-B</option>/<option>--block-size=SIZE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3980
#, no-c-format
msgid "This forces the block size used in the rsync algorithm to a fixed value. It is normally selected based on the size of each file being updated. See the <ulink url=\"http://rsync.samba.org/tech_report/\">technical report</ulink> for details."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3981
#, no-c-format
msgid "Default: not selected; SIZE: 0"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3986
#, no-c-format
msgid "Set block/file checksum seed"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3989
#, no-c-format
msgid "Option: <option>--checksum-seed=NUM</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3990
#, no-c-format
msgid "Set the MD4 checksum seed to the integer NUM. This 4 byte checksum seed is included in each block and file MD4 checksum calculation. By default the checksum seed is generated by the server and defaults to the current time(). This option is used to set a specific checksum seed, which is useful for applications that want repeatable block and file checksums, or in the case where the user wants a more random checksum seed. Note that setting NUM to 0 causes rsync to use the default of time() for checksum seed."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:3996
#, no-c-format
msgid "Skip files based on checksum"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:3999
#, no-c-format
msgid "Option: <option>-c</option>/<option>--checksum</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4000
#, no-c-format
msgid "This forces the sender to checksum every regular file using a 128-bit MD4 checksum. It does this during the initial file system scan as it builds the list of all available files. The receiver then checksums its version of each file (if it exists and it has the same size as its sender-side counterpart) in order to decide which files need to be updated: files with either a changed size or a changed checksum are selected for transfer. Since this whole-file checksumming of all files on both sides of the connection occurs in addition to the automatic checksum verifications that occur during a file's transfer, this option can be quite slow."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:4012
#, no-c-format
msgid "Do not cross file system boundaries"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4015
#, no-c-format
msgid "Option: <option>-x</option>/<option>--one-file-system</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4016
#, no-c-format
msgid "This tells <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> to avoid crossing a file system boundary when recursing. This does not limit the user's ability to specify items to copy from multiple file systems, just <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink>'s recursion through the hierarchy of each folder that the user specified, and also the analogous recursion on the receiving side during deletion. Also keep in mind that <ulink url=\"man:/rsync\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</manvolnum></citerefentry></ulink> treats a \"bind\" mount to the same device as being on the same file system."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:4022
#, no-c-format
msgid "Delay updates until the end of transfer"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4025
#, no-c-format
msgid "Option: <option>--delay-updates</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4026
#, no-c-format
msgid "This option puts the temporary file from each updated file into a holding folder until the end of the transfer, at which time all the files are renamed into place in rapid succession."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4027
#, no-c-format
msgid "It is strongly recommended that you read the <ulink url=\"man:/rsync\">manual page</ulink> before using this option."
msgstr ""

