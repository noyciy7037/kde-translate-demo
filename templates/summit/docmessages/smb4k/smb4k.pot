#. Tag: title
#. +> trunk6 stable6
#: index.docbook:4659
#, no-c-format
msgid "Reporting Bugs"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4661
#, no-c-format
msgid "Before filing a bug report, please try the <ulink url=\"https://sourceforge.net/projects/smb4k/files/\">latest version</ulink> of &smb4k;. Maybe your problem has already been fixed."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4662
#, no-c-format
msgid "Follow these directions for your bug report:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4664
#, no-c-format
msgid "Describe <emphasis>in detail</emphasis> what you did to receive the problem you are reporting."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4665
#, no-c-format
msgid "Provide the version of &smb4k; and &kde-frameworks;."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4666
#, no-c-format
msgid "Mention your operating system (&Linux;, FreeBSD, &etc;) and the distribution that is running on your computer."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4667
#, no-c-format
msgid "Include the full error message if an error dialog was displayed."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4668
#, no-c-format
msgid "If you experienced a crash, attach a full backtrace. For this it is recommended that you (re-)compile &smb4k; with debugging symbols. How this is done is mentioned in the <filename>README.md</filename> file shipped in the sources."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4669
#, no-c-format
msgid "Add additional data, &eg; send a screen shot if you are reporting a &GUI; related problem."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:4671
#, no-c-format
msgid "The recommended method to report a bug is to use the dialog that opens when you click the <menuchoice><guimenu>Help</guimenu><guimenuitem>Report Bug...</guimenuitem></menuchoice> menu item. But you can also go directly to the <ulink url=\"https://bugs.kde.org/enter_bug.cgi?product=Smb4k&amp;format=guided\">KDE Bugtracking System</ulink> and fill out the form."
msgstr ""

