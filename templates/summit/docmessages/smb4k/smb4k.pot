#. Tag: title
#. +> trunk6 stable6
#: index.docbook:56
#, no-c-format
msgid "Introduction"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:58
#, no-c-format
msgid "&smb4k; is an advanced network neighborhood browser and <ulink url=\"http://www.samba.org\">Samba</ulink> share mounting utility. It provides many handy features that ease your life in a &Windows;-dominated network environment."
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:60
#, no-c-format
msgid "This handbook describes &smb4k; 4.0.5 and later. To some extent, it is also correct for earlier versions."
msgstr ""

#. Tag: para
#. +> stable6
#: index.docbook:60
#, no-c-format
msgid "This handbook describes &smb4k; 4.0.6 and later. To some extent, it is also correct for earlier versions."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:63
#, no-c-format
msgid "In 2025, several security vulnerabilities were found in the KAuth mount helper program (see the <ulink url=\"https://security.opensuse.org/2025/12/10/smb4k-major-issues-in-kauth-helper.html\">report</ulink> by the SUSE Security Team) and were fixed in version 4.0.5. Since the feature set for mounts and unmounts has been restricted, these security improvements have a noticeable impact on the entire program."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:66
#, no-c-format
msgid "&smb4k; has got the following features:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:69
#, no-c-format
msgid "Scanning for (active) workgroups, hosts, and shares using &Samba;'s client library, DNS Service Discovery (DNS-SD) and, optionally, Web Services Dynamic Discovery (WS-Discovery)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:70
#, no-c-format
msgid "Support of the &CIFS; and &SMB3; file system under &Linux; as well as the SMBFS file system under BSD"
msgstr ""

