#, no-c-format
msgid "Detect printer shares"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1861
#, no-c-format
msgid "Printer shares are detected."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1867
#, no-c-format
msgid "Detect hidden shares"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1870
#, no-c-format
msgid "Hidden shares are detected. Hidden shares are ending with a $ sign, &eg; Musik$ or IPC$."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1876
#, no-c-format
msgid "Preview hidden files and directories"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1879
#, no-c-format
msgid "Show all files and directories including the hidden ones when opening a share's contents in the preview dialog."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:1892
#, no-c-format
msgid "Advanced Settings"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:1895
#, no-c-format
msgid "<title>Samba</title>"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1900
#, no-c-format
msgid "Set the SMB port to"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1903
#, no-c-format
msgid "Enabling this setting sets the remote SMB port number to communicate with a remote host to the value defined in the spin box. Under BSD, this is also the port that is used for mounting."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1904
#, no-c-format
msgid "Unless you are using a firewall or have a customized network setup, you do not need to change anything here."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1905
#, no-c-format
msgid "Default: 139"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1910
#, no-c-format
msgid "Set the encryption level to"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1913
#, no-c-format
msgid "Set the level of encryption that is used to make connections. The following settings can be chosen:"
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:1917
#, no-c-format
msgid "None"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1920
#, no-c-format
msgid "Encryption is not used."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:1925
#, no-c-format
msgid "Request"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1928
#, no-c-format
msgid "Encryption is requested."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:1933
#, no-c-format
msgid "Require"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1936
#, no-c-format
msgid "Encryption is required."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1940
#, no-c-format
msgid "Default: <guimenuitem>None</guimenuitem>"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1945
#, no-c-format
msgid "This computer is on a large network neighborhood"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1948
#, no-c-format
msgid "In the default configuration, all available master browsers are queried when the browse list is compiled. On large network neighborhoods this can be very time consuming. Enabling this setting restricts the query to three master browsers."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1954
#, no-c-format
msgid "Master browsers require authentication"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1957
#, no-c-format
msgid "If the workgroup master browsers require authentication to return the browse list, you need to check this button. This may be the case for example with some NAS devices. This setting is rarely needed and might even cause a master browser to return an empty browse list."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1963
#, no-c-format
msgid "Use Kerberos for authentication"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1966
#, no-c-format
msgid "Use Kerberos for authentication in an Active Directory environment."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1972
#, no-c-format
msgid "Use Winbind ccache for authentication"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1975
#, no-c-format
msgid "Try to use the credentials cached by Winbind."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:1982
#, no-c-format
msgid "Wake-On-LAN"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1984
#, no-c-format
msgid "To be able to use the Wake-On-LAN capability of &smb4k;, you have to enable this setting. The hosts that should to be woken up have to be defined through the <link linkend=\"network_neighborhood_browser_defining_custom_settings\">custom settings editor</link>."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:1989
#, no-c-format
msgid "Enable Wake-On-LAN features"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1992
#, no-c-format
msgid "Enable Wake-on-LAN (WOL) features. Wake-On-LAN is an ethernet computer networking standard that allows a computer to be turned on or woken up by a network message. Smb4K uses a magic packet send via a UDP socket to wake up remote servers. If you want to take advantage of the Wake-On-LAN feature, you need to enable this option."
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:1997
#, no-c-format
msgid "Waiting time"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2000
#, no-c-format
msgid "This is the waiting time in seconds between the sending of the magic Wake-On-LAN packets and the scanning of the network neighborhood or the mounting of a share."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2001
#, no-c-format
msgid "Default: 5 s"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:2017
#, no-c-format
msgid "Mounting"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2019
#, no-c-format
msgid "This configuration page contains all settings regarding the mounting of shares. The settings appearing here are depending on the operation system you are using."
msgstr ""

#. Tag: screeninfo
#. +> trunk6 stable6
#: index.docbook:2022
#, no-c-format
msgid "Screenshot of the \"Mounting\" configuration page"
msgstr ""

#. Tag: phrase
#. +> trunk6 stable6
#: index.docbook:2025
#, no-c-format
msgid "The \"Mounting\" configuration page"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2036
#, no-c-format
msgid "The settings in this tab are the same for all supported operating systems."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2044
#, no-c-format
msgid "Remount shares"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2047
#, no-c-format
msgid "Remount all your shares that were mounted when you exited the program or changed a profile. If the remounting of a share fails, Smb4K will retry the next time it is started. Shares that were mounted by other users are ignored."
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:2052
#, no-c-format
msgid "Number of remount attempts"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2055
#, no-c-format
msgid "Set the number of attempts that are made to remount shares before Smb4K gives up."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2056
#, no-c-format
msgid "Default: 1"
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:2061
#, no-c-format
msgid "Interval between remount attempts"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2064
#, no-c-format
msgid "Set the time that elapses between attempts to remount shares."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2065
#, no-c-format
msgid "Default: 5 min"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2073
#, no-c-format
msgid "Unmount all personal shares on exit"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2076
#, no-c-format
msgid "Unmount all shares that belong to you when the program exits. Shares that are owned by other users are ignored."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2082
#, no-c-format
msgid "Force unmounting of inaccessible shares"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2085
#, no-c-format
msgid "Force unmounting of inaccessible shares (&Linux; only). In case a share is inaccessible, a lazy unmount is performed. Before the actual unmounting is done, a warning dialog is shown asking to approve the unmount."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2091
#, no-c-format
msgid "Detect all shares that are mounted on the system"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2094
#, no-c-format
msgid "You will not only see the shares that were mounted and are owned by you, but also all other mounts using the SMBFS (BSD) and &CIFS; (&Linux;) file system that are present on the system."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:2107
#, no-c-format
msgid "Common Mount Settings (&Linux; only)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2109
#, no-c-format
msgid "The <guilabel>Common Mount Settings</guilabel> tab is only available under &Linux; and the listed options refer to the <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> / <ulink url=\"man:/mount.smb3\"><citerefentry><refentrytitle>mount.smb3</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> command. The settings present under BSD can be found in the <link linkend=\"configuration_page_mounting_mount_settings\">Mount Settings (BSD only)</link> section."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:2112 index.docbook:2686
#, no-c-format
msgid "Common Options"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2117
#, no-c-format
msgid "Write access"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2120
#, no-c-format
msgid "The write access to a share can be determined here. This option is independent of the file mask and the folder mask settings above. Available options are:"
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2124
#, no-c-format
msgid "read-write"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2127
#, no-c-format
msgid "Option: <option>rw</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2128
#, no-c-format
msgid "Mount the share read-write."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2133
#, no-c-format
msgid "read-only"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2136
#, no-c-format
msgid "Option: <option>ro</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2137
#, no-c-format
msgid "Mount the share read-only."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2141
#, no-c-format
msgid "Default: not selected; <guimenuitem>read-write</guimenuitem>"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2146 index.docbook:2741
#, no-c-format
msgid "Client character set"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2149
#, no-c-format
msgid "Option: <option>iocharset=CHARSET</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2150
#, no-c-format
msgid "Sets the character set used by the client side (&ie; your computer) to one of the following:"
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2154 index.docbook:2748 index.docbook:2943
#, no-c-format
msgid "default"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2157
#, no-c-format
msgid "Default character set used by the client's kernel. In this case the <option>iocharset</option> option is omitted from the command line."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2162 index.docbook:2756
#, no-c-format
msgid "iso8859-1"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2165 index.docbook:2759
#, no-c-format
msgid "ISO/IEC 8859-1:1998. This character-encoding scheme is used throughout the Americas, Western Europe, Oceania, and much of Africa."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2170 index.docbook:2764
#, no-c-format
msgid "iso8859-2"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2173 index.docbook:2767
#, no-c-format
msgid "ISO/IEC 8859-2:1999. It is informally referred to as \"Latin-2\". It is generally intended for Central or \"Eastern European\" languages that are written in the Latin script."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2178 index.docbook:2772
#, no-c-format
msgid "iso8859-3"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2181 index.docbook:2775
#, no-c-format
msgid "ISO/IEC 8859-3:1999. It is informally referred to as Latin-3 or South European. It was designed to cover Turkish, Maltese and Esperanto, though the introduction of ISO/IEC 8859-9 superseded it for Turkish."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2186 index.docbook:2780
#, no-c-format
msgid "iso8859-4"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2189 index.docbook:2783
#, no-c-format
msgid "ISO/IEC 8859-4:1998. It is informally referred to as Latin-4 or North European. It was designed to cover Estonian, Latvian, Lithuanian, Greenlandic, and Sami. It has been largely superseded by ISO/IEC 8859-10 and Unicode."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2194 index.docbook:2788
#, no-c-format
msgid "iso8859-5"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2197 index.docbook:2791
#, no-c-format
msgid "ISO/IEC 8859-5:1999. It is informally referred to as Latin/Cyrillic. It was designed to cover languages using a Cyrillic alphabet such as Bulgarian, Belarusian, Russian, Serbian and Macedonian but was never widely used."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2202 index.docbook:2796
#, no-c-format
msgid "iso8859-6"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2205 index.docbook:2799
#, no-c-format
msgid "ISO/IEC 8859-6:1999. It is informally referred to as Latin/Arabic. It was designed to cover Arabic."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2210 index.docbook:2804
#, no-c-format
msgid "iso8859-7"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2213 index.docbook:2807
#, no-c-format
msgid "ISO/IEC 8859-7:2003. It is informally referred to as Latin/Greek. It was designed to cover the modern Greek language."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2218 index.docbook:2812
#, no-c-format
msgid "iso8859-8"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2221 index.docbook:2815
#, no-c-format
msgid "ISO/IEC 8859-8:1999. It is informally referred to as Latin/Hebrew. ISO/IEC 8859-8 covers all the Hebrew letters, but no Hebrew vowel signs."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2226 index.docbook:2820
#, no-c-format
msgid "iso8859-9"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2229 index.docbook:2823
#, no-c-format
msgid "ISO/IEC 8859-9:1999. It is informally referred to as Latin-5 or Turkish. It was designed to cover the Turkish language, designed as being of more use than the ISO/IEC 8859-3 encoding."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2234 index.docbook:2828
#, no-c-format
msgid "iso8859-13"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2237 index.docbook:2831
#, no-c-format
msgid "ISO/IEC 8859-13:1998. It is informally referred to as Latin-7 or Baltic Rim. It was designed to cover the Baltic languages, and added characters used in the Polish language missing from the earlier encodings ISO 8859-4 and ISO 8859-10. Unlike these two, it does not cover the Nordic languages."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2242 index.docbook:2836
#, no-c-format
msgid "iso8859-14"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2245 index.docbook:2839
#, no-c-format
msgid "ISO/IEC 8859-14:1998. It is informally referred to as Latin-8 or Celtic. It was designed to cover the Celtic languages, such as Irish, Manx, Scottish Gaelic, Welsh, Cornish, and Breton."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2250 index.docbook:2844
#, no-c-format
msgid "iso8859-15"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2253 index.docbook:2847
#, no-c-format
msgid "ISO/IEC 8859-15:1999. It is informally referred to as Latin-9 (and for a while Latin-0). It is similar to ISO 8859-1, and thus also intended for Western European languages, but replaces some less common symbols with the euro sign and some letters that were deemed necessary."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2258 index.docbook:2852
#, no-c-format
msgid "utf8"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2261 index.docbook:2855
#, no-c-format
msgid "Unicode (or Universal Coded Character Set) Transformation Format  8-bit. UTF-8 is used by many &Linux; distributions as default character set, and is, in addition, by far the most common encoding for the World Wide Web."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2266 index.docbook:2860
#, no-c-format
msgid "koi8-r"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2269 index.docbook:2863
#, no-c-format
msgid "KOI8-R (RFC 1489) is an 8-bit character encoding, derived from the KOI-8 encoding by the programmer Andrei Chernov in 1993 and designed to cover Russian, which uses a Cyrillic alphabet."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2274 index.docbook:2868
#, no-c-format
msgid "koi8-u"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2277 index.docbook:2871
#, no-c-format
msgid "KOI8-U (RFC 2319) is an 8-bit character encoding, designed to cover Ukrainian, which uses a Cyrillic alphabet."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2282 index.docbook:2876
#, no-c-format
msgid "koi8-ru"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2285 index.docbook:2879
#, no-c-format
msgid "KOI8-RU is an 8-bit character encoding, designed to cover Russian, Ukrainian, and Belarusian which use a Cyrillic alphabet."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2290 index.docbook:2884 index.docbook:3135
#, no-c-format
msgid "cp1251"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2293 index.docbook:2887
#, no-c-format
msgid "Windows-1251 is an 8-bit character encoding, designed to cover languages that use the Cyrillic script such as Russian, Bulgarian, Serbian Cyrillic and other languages. In Linux, the encoding is known as cp1251."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2298 index.docbook:2892
#, no-c-format
msgid "gb2312"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2301 index.docbook:2895
#, no-c-format
msgid "GB/T 2312-1980 is a key official character set of the People's Republic of China, used for Simplified Chinese characters. GB2312 is the registered internet name for EUC-CN, which is its usual encoded form. GB/T 2312-1980 has been superseded by GBK and GB18030, which include additional characters, but GB/T 2312 remains in widespread use as a subset of those encodings."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2306 index.docbook:2900
#, no-c-format
msgid "big5"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2309 index.docbook:2903
#, no-c-format
msgid "Big-5 or Big5 is a Chinese character encoding method used in Taiwan, Hong Kong, and Macau for traditional Chinese characters. The People's Republic of China (PRC), which uses simplified Chinese characters, uses the GB 18030 character set instead."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2314 index.docbook:2908
#, no-c-format
msgid "euc-jp"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2317 index.docbook:2911
#, no-c-format
msgid "EUC-JP is a variable-width encoding used to represent the elements of three Japanese character set standards, namely JIS X 0208, JIS X 0212, and JIS X 0201."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2322 index.docbook:2916
#, no-c-format
msgid "euc-kr"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2325 index.docbook:2919
#, no-c-format
msgid "EUC-KR is a variable-width encoding to represent Korean text using two coded character sets, KS X 1001 (formerly KS C 5601) and either ISO 646:KR (KS X 1003, formerly KS C 5636) or US-ASCII, depending on variant. KS X 2901 (formerly KS C 5861) stipulates the encoding and RFC 1557 dubbed it as EUC-KR."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:2330 index.docbook:2924
#, no-c-format
msgid "tis-620"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2333 index.docbook:2927
#, no-c-format
msgid "Thai Industrial Standard 620-2533, commonly referred to as TIS-620, is the most common character set and character encoding for the Thai language."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2337
#, no-c-format
msgid "Default: not selected; CHARSET: <guimenuitem>default</guimenuitem>"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:2344
#, no-c-format
msgid "&CIFS; Unix Extensions Support"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2348
#, no-c-format
msgid "All or most of the servers support the &CIFS; Unix extensions"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2351
#, no-c-format
msgid "Option: none"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2352
#, no-c-format
msgid "Most versions of &Samba; support the &CIFS; Unix or POSIX extensions. For these servers, some options are not needed, because the right values are negotiated during the mount process. For other servers, you might want to uncheck this option, so that predefined values can be passed to the server. Please note that if your computer is located in a &Windows; dominated network neighborhood with only a few &Samba; servers, you can safely uncheck this option and define custom settings for the &Samba; servers."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2353
#, no-c-format
msgid "In case you uncheck this option, consider to switch on permission checks under <link linkend=\"configuration_page_mounting_advanced_mount_settings\">Advanced Mount Settings</link>."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2359 index.docbook:2691
#, no-c-format
msgid "Set the user and group ID"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2362
#, no-c-format
msgid "Options: <option>uid=UID</option> and <option>gid=GID</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2363 index.docbook:2695
#, no-c-format
msgid "&smb4k; uses your user and group ID for mounting if this setting is enabled. They are displayed here for information purposes only and cannot be changed."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2364 index.docbook:2375 index.docbook:2386 index.docbook:2696
#, no-c-format
msgid "In case the support for the &CIFS; Unix extensions is selected, this setting is disabled."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2365 index.docbook:2697
#, no-c-format
msgid "Default: selected; UID: your UID, GID: your GID"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2370 index.docbook:2705
#, no-c-format
msgid "File mode"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2373
#, no-c-format
msgid "Option: <option>file_mode=MODE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2374
#, no-c-format
msgid "Sets the permissions that are applied to files. The value is given in octal and may have 3 or 4 digits. The SUID, SGID and sticky bit are not allowed. To learn more about the file mode (file_mode), you should read the <ulink url=\"man:/mount(8)\"><citerefentry><refentrytitle>mount</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> and <ulink url=\"man:/umask(2)\"><citerefentry><refentrytitle>umask</refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> manual pages."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2376 index.docbook:2387
#, no-c-format
msgid "Default: selected; ARG: 0755"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2381 index.docbook:2715
#, no-c-format
msgid "Directory mode"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2384
#, no-c-format
msgid "Option: <option>dir_mode=MODE</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2385
#, no-c-format
msgid "Sets the permissions that are applied to directories. The value is given in octal and may have 3 or 4 digits. The SUID, SGID and sticky bit are not allowed. To learn more about the directory mode (dir_mode), you should read the <ulink url=\"man:/mount(8)\"><citerefentry><refentrytitle>mount</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> and <ulink url=\"man:/umask(2)\"><citerefentry><refentrytitle>umask</refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> manual pages."
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:2399
#, no-c-format
msgid "Advanced Mount Settings (&Linux; only)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2401
#, no-c-format
msgid "The <guilabel>Advanced Mount Settings</guilabel> tab is only available under &Linux; and the listed options refer to the <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> / <ulink url=\"man:/mount.smb3\"><citerefentry><refentrytitle>mount.smb3</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> command. The settings present under BSD can be found in the <link linkend=\"configuration_page_mounting_mount_settings\">Mount Settings (BSD only)</link> section."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2405
#, no-c-format
msgid "Definitely assign the UID"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2408
#, no-c-format
msgid "Option: <option>forceuid</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2409
#, no-c-format
msgid "Instruct the client (i.e. your side) to ignore any user ID (UID) provided by the server for files and directories and to always assign the owner to be the value of the transmitted UID."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2415
#, no-c-format
msgid "Definitely assign the GID"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2418
#, no-c-format
msgid "Option: <option>forcegid</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2419
#, no-c-format
msgid "Instruct the client (i.e. your side) to ignore any group ID (GID) provided by the server for files and directories and to always assign the owner to be the value of the transmitted GID."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2425
#, no-c-format
msgid "Do permission checks"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2428
#, no-c-format
msgid "Option: <option>perm</option> or <option>noperm</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2429
#, no-c-format
msgid "The client side checks if you have the correct UID and GID to manipulate files and directories on the share. This is in addition to the normal ACL check on the target machine done by the server software. You most definitely want to switch this feature off, if the server(s) support the &CIFS; Unix extensions and you are, hence, not allowed to fully access the share."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2435
#, no-c-format
msgid "Attempt to set UID and GID"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2438
#, no-c-format
msgid "Option: <option>setuids</option> or <option>nosetuids</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2439
#, no-c-format
msgid "If the &CIFS; Unix extensions are negotiated with the server the client side will attempt to set the effective UID and GID of the local process on newly created files, directories, and devices. If this feature is turned off, the default UID and GID defined for the share will be used. It is recommended that you read the manual page of <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> before you change this setting."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2445
#, no-c-format
msgid "Use server inode numbers"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2448
#, no-c-format
msgid "Option: <option>serverino</option> or <option>noserverino</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2449
#, no-c-format
msgid "Use inode numbers (unique persistent file identifiers) returned by the server instead of automatically generating temporary inode numbers on the client side. This parameter has no effect if the server does not support returning inode numbers or similar. It is recommended that you read the manual page of <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> before you change this setting."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2455
#, no-c-format
msgid "Translate reserved characters"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2458
#, no-c-format
msgid "Option: <option>mapchars</option> or <option>nomapchars</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2459
#, no-c-format
msgid "Translate six of the seven reserved characters (not backslash, but including the colon, question mark, pipe, asterisk, greater than, and less than characters) to the remap range (above 0xF000), which also allows the client side to recognize files created with such characters by &Windows;s POSIX emulation. This can also be useful when mounting to most versions of &Samba;. This has no effect if the server does not support Unicode."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2465
#, no-c-format
msgid "Do not send byte range lock requests"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2468
#, no-c-format
msgid "Option: <option>nobrl</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2469
#, no-c-format
msgid "Do not send byte range lock requests to the server. This is necessary for certain applications that break with cifs style mandatory byte range locks (and most cifs servers do not yet support requesting advisory byte range locks)."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2475
#, no-c-format
msgid "SMB protocol version"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2478
#, no-c-format
msgid "Option: <option>vers=VERS</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2479
#, no-c-format
msgid "Define which version of the SMB protocol is to be used. Normally, this option does not need to be enabled because the protocol version is negotiated between the client and the server."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2480 index.docbook:2559
#, no-c-format
msgid "The following values are allowed:"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2484
#, no-c-format
msgid "1.0 (Classic &CIFS;/SMBv1 protocol)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2487
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the classic &CIFS;/SMBv1 protocol."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2492
#, no-c-format
msgid "2.0 (Windows Vista SP1/Windows Server 2008)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2495
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the SMBv2.002 protocol. This was initially introduced in &Microsoft; &Windows; Vista Service Pack 1 and &Windows; Server 2008."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2496
#, no-c-format
msgid "Please note that the initial release version of &Microsoft; &Windows; Vista spoke a slightly different dialect (2.000) that is not supported."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2501
#, no-c-format
msgid "2.1 (Windows 7/Windows Server 2008R2)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2504
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the SMBv2.1 protocol that was introduced in &Microsoft; &Windows; 7 and &Windows; Server 2008R2."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2509
#, no-c-format
msgid "3.0 (Windows 8/Windows Server 2012)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2512
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the SMBv3.0 protocol that was introduced in &Microsoft; &Windows; 8 and &Windows; Server 2012."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2517
#, no-c-format
msgid "3.0.2 (Windows 8.1/Windows Server 2012R2)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2520
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the SMBv3.0.2 protocol that was introduced in &Microsoft; &Windows; 8.1 and &Windows; Server 2012R2."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2526
#, no-c-format
msgid "3.1.1 (Windows Server 2016)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2529
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the SMBv3.1.1 protocol that was introduced in &Microsoft; &Windows; Server 2016."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2534
#, no-c-format
msgid "3 (Version 3.0 and above)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2537
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use the SMBv3.0 protocol version and above."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2542
#, no-c-format
msgid "default (Negotiate the highest version)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2545
#, no-c-format
msgid "This causes <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to try to negotiate the highest SMBv2+ version supported by both the client and server."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2549
#, no-c-format
msgid "Default: not selected; VERS: <guibutton>default (Negotiate the highest version)</guibutton>"
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2554
#, no-c-format
msgid "Cache mode"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2557
#, no-c-format
msgid "Option: <option>cache=ARG</option>"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:2558
#, no-c-format
msgid "Define how read and write requests are handled. In case you choose to not cache file data at all, the client never utilizes the cache for normal reads and writes. It always accesses the server directly to satisfy a read or write request. If you choose to follow the &CIFS;/SMB2 protocol strictly, the cache is only trusted if the client holds an oplock. If the client does not hold an oplock, then the client bypasses the cache and accesses the server directly to satisfy a read or write request. Choosing to allow loose caching semantics can sometimes provide better performance on the expense of cache coherency. This option might cause data corruption, if several clients access the same set of files on the server at the same time. Because of this, the strict cache mode is recommended."
msgstr ""

#. Tag: guibutton
#. +> trunk6 stable6
#: index.docbook:2563
#, no-c-format
msgid "Do not cache file data at all"
msgstr ""

