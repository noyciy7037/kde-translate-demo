#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:1778
#, no-c-format
msgid "Minimal SMB protocol version:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1781 index.docbook:1816
#, no-c-format
msgid "The following protocol versions can be set:"
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:1785 index.docbook:1820
#, no-c-format
msgid "NT1 (Classic CIFS/SMBv1 protocol)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1788 index.docbook:1823
#, no-c-format
msgid "This is the classic version of the protocol. It is used by &Windows; NT and is known as CIFS or SMBv1. It is considered to be unsafe and was disabled in the latest &Samba; and &Windows; versions."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:1793 index.docbook:1828
#, no-c-format
msgid "SMB2 (Windows Vista and above)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1796 index.docbook:1831
#, no-c-format
msgid "This is the re-implementation of the SMB protocol. It is used by &Windows; Vista and above."
msgstr ""

#. Tag: guimenuitem
#. +> trunk6 stable6
#: index.docbook:1801 index.docbook:1836
#, no-c-format
msgid "SMB3 (Windows 8 and above)"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1804
#, no-c-format
msgid "This is the SMBv3 protocol version. It features several improvements of the functionality and performance of SMBv2 as well as several security enhancements. This protocol version is used by &Windows; 8 and above."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1808
#, no-c-format
msgid "Default: <guimenuitem>SMB2 (Windows Vista and above)</guimenuitem>"
msgstr ""

#. Tag: guilabel
#. +> trunk6 stable6
#: index.docbook:1813
#, no-c-format
msgid "Maximal SMB protocol version:"
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1839
#, no-c-format
msgid "This is the SMBv3 protocol version. It features serveral improvements of the functionality and performance of SMBv2 as well as serveral security enhancements. This protocol version is used by &Windows; 8 and above."
msgstr ""

#. Tag: para
#. +> trunk6 stable6
#: index.docbook:1843
#, no-c-format
msgid "Default: <guimenuitem>SMB3 (Windows 8 and above)</guimenuitem>"
msgstr ""

#. Tag: title
#. +> trunk6 stable6
#: index.docbook:1853 index.docbook:2039 index.docbook:3259
#, no-c-format
msgid "Behavior"
msgstr ""

