msgid ""
"&vfs; &compare; &occupied-space; &splitter; &checksum; <sect1 id=\"send-email\"> "
"<title>Send Files by Email</title>"
" "
"<para>Select a file and use <menuchoice> <guimenu>Right-Click menu</guimenu> <guimenuitem>Send by Email</guimenuitem> </menuchoice>. Selecting this option will open a new &kmail; window with the file already attached. Just fill in the subject and recipient(s) and send it. Of course, &kmail; must be properly configured.</para>"
" </sect1> &profiles;"
msgstr ""

